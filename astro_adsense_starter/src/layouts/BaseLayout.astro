---
import AdSenseScript from '../components/AdSenseScript.astro';
import { getLangFromUrl, useTranslations, localizeUrl, switchLocalePath, stripLocale, isLocalized, locales, localeNames } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  robots?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (path: string) => localizeUrl(path, lang);

const {
  title = 'Fight Prophet',
  description = 'AI-powered sports analytics and prediction insights',
  robots = 'index, follow',
} = Astro.props as Props;

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://fightprophet.com').replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL('/branding/fightprophet_logo_white.png', siteUrl).toString();
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION || '';
const kofiWidgetEnabled = import.meta.env.PUBLIC_KOFI_WIDGET_ENABLED === 'true';
const kofiSupportUrl = import.meta.env.PUBLIC_KOFI_SUPPORT_URL || 'https://ko-fi.com/fightprophet';

const predictionsEmojiUrl = '/branding/b91c1c-predictions-emoji-rail.png';
const fighterCardsEmojiUrl = '/branding/b91c1c-fighterscard-emoji-rail.png';
const beltEmojiUrl = '/branding/b91c1c-belt-emoji-rail.png';
const eventsEmojiUrl = '/branding/b91c1c-events-emoji-rail.png';
const rankingsEmojiUrl = '/branding/b91c1c-goat-emoji-rail.png';
const labEmojiUrl = '/branding/b91c1c-lab-emoji-rail.png';
const termsEmojiUrl = '/branding/b91c1c-terms-emoji-rail.png';
const aboutEmojiUrl = '/branding/b91c1c-about-emoji.png';
const betsEmojiUrl = '/branding/b91c1c-bets-emoji.png';
const madeInColombiaEmojiUrl = '/branding/b91c1c-madeincolombia-emoji.png';
const earProEmojiUrl = '/branding/b91c1c-earpro-emoji.png';

// Compare against the locale-stripped path so /ru/predictions/ matches /predictions/.
const currentPath = (Astro.url.pathname.replace(/^\/ru(?=\/|$)/, '') || '/');
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/' || currentPath === '/rankings' || currentPath === '/rankings/';
  return currentPath.startsWith(href);
};
// Only show the routed language switcher / alternate links where a translated
// page exists, so we never link to a non-existent localized page.
const hasTranslation = isLocalized(stripLocale(Astro.url.pathname));
const localeLinks = locales.map((code) => ({
  code,
  label: localeNames[code],
  href: switchLocalePath(Astro.url, code),
  active: code === lang,
}));

const organizationId = `${siteUrl}/#organization`;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': organizationId,
    name: 'Fight Prophet',
    url: siteUrl,
    logo: ogImageUrl,
    sameAs: [
      'https://www.linkedin.com/company/fight-prophet',
      'https://github.com/datatomas/fightprophet',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    name: 'Fight Prophet',
    url: siteUrl,
    publisher: { '@id': organizationId },
    inLanguage: 'en',
  },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <link rel="canonical" href={canonicalUrl} />
    {hasTranslation && (
      <>
        {localeLinks.map((l) => (
          <link rel="alternate" hreflang={l.code} href={new URL(l.href, siteUrl).toString()} />
        ))}
        <link rel="alternate" hreflang="x-default" href={new URL(switchLocalePath(Astro.url, 'en'), siteUrl).toString()} />
      </>
    )}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/png" sizes="32x32" media="(prefers-color-scheme: dark)" href="/branding/white_ear_favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" media="(prefers-color-scheme: light)" href="/branding/ear_favicon_transparent.png" />
    <link rel="icon" type="image/x-icon" media="(prefers-color-scheme: dark)" href="/branding/white_ear_favicon.ico" />
    <link rel="icon" type="image/x-icon" media="(prefers-color-scheme: light)" href="/branding/ear_favicon_transparent.ico" />
    <link id="dynamic-favicon" rel="icon" type="image/png" sizes="32x32" href="/branding/ear_favicon_transparent.png" />
    <meta name="theme-color" content="#09090b" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-R7PND3T858"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-R7PND3T858');
    </script>
    <AdSenseScript />
    <script is:inline>
      (() => {
        const updateFavicon = () => {
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const favicon = document.getElementById('dynamic-favicon');
          if (!favicon) return;
          favicon.setAttribute('href', prefersDark ? '/branding/white_ear_favicon.png' : '/branding/ear_favicon_transparent.png');
        };
        updateFavicon();
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        if (typeof media.addEventListener === 'function') media.addEventListener('change', updateFavicon);
        else if (typeof media.addListener === 'function') media.addListener(updateFavicon);
      })();
    </script>
  </head>
  <body>

    <!-- Backdrop (mobile only) -->
    <div class="fp-rail-backdrop" id="fp-rail-backdrop" hidden></div>
    <!-- Left rail -->
    <aside class="fp-app-rail-shell" id="fp-app-rail-shell" aria-label="Site navigation">
      <button type="button" class="fp-rail-close" id="fp-rail-close" aria-label="Close navigation">×</button>
      <div class="fp-app-rail">
        <a href="/" class="fp-app-rail-logo-wrap">
          <img src="/branding/fightprophet_logo_white.png" alt="Fight Prophet" class="fp-app-rail-logo" loading="lazy" />
        </a>

        <!-- Legacy client-side translator (es/pt/en). Hidden on pages that have
             real routed translations (those use the .fp-locale-pill switcher). -->
        {!hasTranslation && (
          <div class="fp-lang-switch fp-lang-switch-rail" aria-label="Language selector">
            <button type="button" class="fp-lang-btn" data-lang="es" title="Español">🇨🇴</button>
            <button type="button" class="fp-lang-btn" data-lang="pt" title="Português">🇧🇷</button>
            <button type="button" class="fp-lang-btn" data-lang="en" title="English">🇺🇸</button>
          </div>
        )}

        <div class="fp-app-rail-heading">Bet wisely with Fight Prophet</div>
        <div class="fp-app-rail-subheading">AI-powered MMA fight predictions</div>
        <a class="fp-app-rail-support" href={kofiSupportUrl} target="_blank" rel="noopener noreferrer">
          <span class="fp-app-rail-support-icon">
            <img src={betsEmojiUrl} alt="" width="30" height="30" loading="lazy" aria-hidden="true" />
          </span>
          <span class="fp-app-rail-support-copy">
            <span class="fp-app-rail-support-title">Support Fight Prophet</span>
            <span class="fp-app-rail-support-text">Buy me a coffee</span>
          </span>
        </a>
        <div class="fp-app-rail-section-label">Navigate</div>

        <nav class="fp-app-rail-nav" aria-label="Site sections">
          <a class={`fp-app-rail-nav-link${isActive('/') ? ' is-active is-primary-nav' : ''}`} href={L('/')}><span class="fp-app-rail-nav-copy"><img src={rankingsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.home')}</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/predictions/') ? ' is-active' : ''}`} href={L('/predictions/')}><span class="fp-app-rail-nav-copy"><img src={predictionsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.predictions')}</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/fighter-card/') ? ' is-active' : ''}`} href={L('/fighter-card/')}><span class="fp-app-rail-nav-copy"><img src={fighterCardsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.fighterCards')}</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/belt-holders/') ? ' is-active' : ''}`} href={L('/belt-holders/')}><span class="fp-app-rail-nav-copy"><img src={beltEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.beltHolders')}</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/events-history/') ? ' is-active' : ''}`} href={L('/events-history/')}><span class="fp-app-rail-nav-copy"><img src={eventsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.eventsHistory')}</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/fight-lab/') ? ' is-active' : ''}`} href={L('/fight-lab/')}><span class="fp-app-rail-nav-copy"><img src={labEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.fightLab')}</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/betting-education/') ? ' is-active' : ''}`} href={L('/betting-education/')}><span class="fp-app-rail-nav-copy"><img src={betsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.bettingEducation')}</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/about/') ? ' is-active' : ''}`} href={L('/about/')}><span class="fp-app-rail-nav-copy"><img src={aboutEmojiUrl} alt="" class="fp-app-rail-nav-icon is-about-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.about')}</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/terms/') ? ' is-active' : ''}`} href={L('/terms/')}><span class="fp-app-rail-nav-copy"><img src={termsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>{t('nav.terms')}</span></span></a>
          {hasTranslation && (
            <div class="fp-locale-pill" role="group" aria-label={t('lang.label')}>
              {localeLinks.map((l) => (
                <a class={l.active ? 'is-active' : ''} href={l.href} hreflang={l.code}>{l.label}</a>
              ))}
            </div>
          )}
        </nav>

        <!-- Footer -->
        <div class="fp-app-rail-footer">
          <img src="/branding/fightprophet_ear_white.png" alt="" class="fp-app-rail-mini-mark" loading="lazy" aria-hidden="true" />
          <div class="fp-app-rail-divider"></div>
          <div class="fp-app-rail-links is-footer">
            <a class="fp-app-rail-link is-muted" href="https://www.linkedin.com/company/fight-prophet" target="_blank" rel="noopener noreferrer">Business LinkedIn</a>
            <a class="fp-app-rail-link is-muted" href="https://www.linkedin.com/in/datatomas/" target="_blank" rel="noopener noreferrer">Founder LinkedIn</a>
            <a class="fp-app-rail-link is-muted" href="https://github.com/datatomas/fightprophet" target="_blank" rel="noopener noreferrer">Business GitHub</a>
            <a class="fp-app-rail-link is-muted" href="/about/">About</a>
            <a class="fp-app-rail-link is-muted" href="/contact/">Contact</a>
            <a class="fp-app-rail-link is-muted" href="/terms/">Terms</a>
            <a class="fp-app-rail-link is-muted" href="/privacy/">Privacy</a>
          </div>
        </div>
      </div>
    </aside>

    <!-- Page content -->
    <div class="fp-layout-wrap">
      <!-- Mobile top bar — only visible on small screens, part of normal flow so nothing overlaps -->
      <div class="fp-mobile-topbar" id="fp-mobile-topbar">
        <button
          type="button"
          class="fp-rail-toggle"
          id="fp-rail-toggle"
          aria-controls="fp-app-rail-shell"
          aria-expanded="false"
          aria-label="Open navigation"
        >
          <span aria-hidden="true">☰</span>
        </button>
      </div>
      <main>
        <slot />
      </main>
      <footer class="fp-site-footer">
        <nav class="fp-site-footer-nav" aria-label="Site sections">
          <a href={L('/')}>{t('footer.home')}</a>
          <a href={L('/predictions/')}>{t('nav.predictions')}</a>
          <a href={L('/#fp-newsletter')}>{t('footer.newsletter')}</a>
          <a href={L('/fight-lab/')}>{t('nav.fightLab')}</a>
          <a href={L('/rankings/')}>{t('footer.rankings')}</a>
          <a href={L('/belt-holders/')}>{t('nav.beltHolders')}</a>
          <a href={L('/fighter-card/')}>{t('nav.fighterCards')}</a>
          <a href={L('/events-history/')}>{t('nav.eventsHistory')}</a>
          <a href={L('/betting-education/')}>{t('nav.bettingEducation')}</a>
          <a href={L('/editorial-policy/')}>{t('footer.editorialPolicy')}</a>
          <a href={L('/responsible-use/')}>{t('footer.responsibleUse')}</a>
          <a href={L('/about/')}>{t('nav.about')}</a>
          <a href={L('/contact/')}>{t('footer.contact')}</a>
          <a href={L('/privacy/')}>{t('footer.privacy')}</a>
          <a href={L('/terms/')}>{t('nav.terms')}</a>
        </nav>
        <p class="fp-site-footer-meta">{t('footer.meta')}</p>
        <div class="fp-footer-marks">
          <img src={earProEmojiUrl} alt="" class="fp-footer-emoji-mark" loading="lazy" decoding="async" width="136" height="136" aria-hidden="true" />
          <img src={madeInColombiaEmojiUrl} alt="Made in Colombia" class="fp-made-in-mark" loading="lazy" decoding="async" width="136" height="136" />
        </div>
      </footer>
    </div>

    {kofiWidgetEnabled && (
      <>
        <script src="https://storage.ko-fi.com/cdn/scripts/overlay-widget.js" is:inline></script>
        <script is:inline>
          if (window.kofiWidgetOverlay) {
            window.kofiWidgetOverlay.draw('fightprophet', {
              'type': 'floating-chat',
              'floating-chat.donateButton.text': 'Support Us',
              'floating-chat.donateButton.background-color': '#d9534f',
              'floating-chat.donateButton.text-color': '#fff'
            });
          }
        </script>
      </>
    )}
  </body>
</html>

<script is:inline>
  (() => {
    const DESKTOP_BP = 901;
    const FP_LANG_KEY = 'fp_lang';

    const rail = document.getElementById('fp-app-rail-shell');
    const toggle = document.getElementById('fp-rail-toggle');
    const closeBtn = document.getElementById('fp-rail-close');
    const backdrop = document.getElementById('fp-rail-backdrop');
    const body = document.body;

    const isMobile = () => window.innerWidth < DESKTOP_BP;

    const setOpen = (open) => {
      if (!rail) return;
      rail.dataset.railOpen = open ? 'true' : 'false';
      if (toggle) {
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
      }
      if (backdrop) backdrop.hidden = !open;
      body.style.overflow = open && isMobile() ? 'hidden' : '';
    };

    if (toggle) toggle.addEventListener('click', () => setOpen(rail && rail.dataset.railOpen !== 'true'));
    if (closeBtn) closeBtn.addEventListener('click', () => setOpen(false));
    if (backdrop) backdrop.addEventListener('click', () => setOpen(false));

    if (rail) {
      rail.addEventListener('click', (event) => {
        if (event.target instanceof HTMLAnchorElement && isMobile()) setOpen(false);
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && rail && rail.dataset.railOpen === 'true') setOpen(false);
    });

    const desktopQuery = window.matchMedia('(min-width: ' + DESKTOP_BP + 'px)');
    const handleViewport = () => {
      if (desktopQuery.matches) { setOpen(false); body.style.overflow = ''; }
    };
    handleViewport();
    if (typeof desktopQuery.addEventListener === 'function') desktopQuery.addEventListener('change', handleViewport);
    else if (typeof desktopQuery.addListener === 'function') desktopQuery.addListener(handleViewport);

    // ── Language preference ────────────────────────────────────────────
    const SUPPORTED_LANGS = ['en', 'es', 'pt'];
    const normalizeLang = (raw) => {
      const v = (raw || '').trim().toLowerCase();
      return SUPPORTED_LANGS.includes(v) ? v : '';
    };
    const cookieDomain = (() => {
      const host = window.location.hostname || '';
      if (/(^|\.)fightprophet\.com$/i.test(host)) return '.fightprophet.com';
      return '';
    })();
    const readCookie = (name) => {
      const prefix = name + '=';
      for (const raw of (document.cookie || '').split(';')) {
        const c = raw.trim();
        if (c.startsWith(prefix)) {
          try { return decodeURIComponent(c.slice(prefix.length)); } catch { return c.slice(prefix.length); }
        }
      }
      return '';
    };
    const writeCookie = (name, value) => {
      const oneYear = 60 * 60 * 24 * 365;
      const parts = [
        name + '=' + encodeURIComponent(value),
        'Path=/',
        'Max-Age=' + oneYear,
        'SameSite=Lax',
      ];
      if (cookieDomain) parts.push('Domain=' + cookieDomain);
      if (window.location.protocol === 'https:') parts.push('Secure');
      document.cookie = parts.join('; ');
    };

    const queryLang = normalizeLang(new URLSearchParams(window.location.search).get('lang'));
    const cookieLang = normalizeLang(readCookie(FP_LANG_KEY));
    const localLang = normalizeLang(localStorage.getItem(FP_LANG_KEY));
    const initialLang = queryLang || cookieLang || localLang || 'en';

    const persistLang = (lang) => {
      const safe = normalizeLang(lang) || 'en';
      try { localStorage.setItem(FP_LANG_KEY, safe); } catch (e) { /* no-op */ }
      writeCookie(FP_LANG_KEY, safe);
    };

    const MADE_IN_COPY = {
      en: 'Made in Colombia',
      es: 'Hecho en Colombia',
      pt: 'Feito na Colômbia',
    };

    const applyLangChrome = (lang) => {
      const safe = normalizeLang(lang) || 'en';
      document.querySelectorAll('.fp-lang-btn').forEach((btn) => {
        btn.classList.toggle('is-active', btn.dataset.lang === safe);
      });
      document.documentElement.lang = safe;
      document.querySelectorAll('[data-i18n-made-in]').forEach((el) => {
        el.textContent = MADE_IN_COPY[safe] || MADE_IN_COPY.en;
      });
    };

    persistLang(initialLang);
    applyLangChrome(initialLang);

    let currentLang = initialLang;
    const announceLang = (lang) => {
      currentLang = lang;
      window.dispatchEvent(new CustomEvent('fp-lang-change', { detail: { lang } }));
    };

    document.querySelectorAll('.fp-lang-btn[data-lang]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = normalizeLang(btn.dataset.lang) || 'en';
        persistLang(lang);
        applyLangChrome(lang);
        announceLang(lang);
        // Also call the home page translator directly in case the event doesn't cross module boundaries
        const homeLang = window['__fpHomeLang'];
        if (typeof homeLang === 'function') homeLang(lang);
      });
    });

  })();
</script>

<style>
  :global(:root) {
    --fp-rail-width: 260px;
    --fp-shell-max: 1720px;
  }

  :global(html) {
    background-color: #030304;
    color-scheme: dark;
  }

  :global(html, body) {
    margin: 0;
    font-family: Inter, system-ui, sans-serif;
    background: #09090b;
    color: #f4f4f5;
  }

  :global(body) {
    position: relative;
    min-height: 100vh;
    isolation: isolate;
  }

  :global(body)::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(9, 9, 11, 0.52) 0%, rgba(9, 9, 11, 0.68) 32%, rgba(9, 9, 11, 0.8) 100%),
      url('/background.png') center top / cover fixed no-repeat;
    z-index: -3;
    pointer-events: none;
  }

  :global(body)::after {
    content: '';
    position: fixed;
    left: 50%;
    top: 53%;
    width: min(32vw, 420px);
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    background: url('/branding/fightprophet_ear_white.png') center center / contain no-repeat;
    opacity: 0.12;
    filter: drop-shadow(0 0 22px rgba(220, 38, 38, 0.15));
    z-index: -2;
    pointer-events: none;
  }

  /* ── Mobile top bar (hidden on desktop) ───────────────────────────── */
  .fp-mobile-topbar {
    display: none;
    align-items: center;
    padding: 0.5rem 0.75rem;
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(9, 9, 11, 0.88);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid rgba(220, 38, 38, 0.18);
  }

  /* ── Rail toggle button ────────────────────────────────────────────── */
  .fp-rail-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.6rem;
    border: 1px solid rgba(220, 38, 38, 0.45);
    background: linear-gradient(160deg, rgba(35, 20, 20, 0.94), rgba(22, 22, 26, 0.94));
    color: #fef2f2;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35), 0 0 8px rgba(220, 38, 38, 0.15);
    flex-shrink: 0;
  }

  /* ── Backdrop (mobile only) ───────────────────────────────────────── */
  .fp-rail-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
    z-index: 50;
  }
  /* ── Close button (inside rail, mobile only) ──────────────────────── */
  .fp-rail-close {
    display: none;
    position: absolute;
    top: 0.55rem;
    right: 0.6rem;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid rgba(220, 38, 38, 0.45);
    background: rgba(15, 15, 18, 0.88);
    color: #fef2f2;
    font-size: 1.32rem;
    line-height: 1;
    cursor: pointer;
    z-index: 2;
  }

  /* ── Left rail shell ──────────────────────────────────────────────── */
  .fp-app-rail-shell {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    height: 100dvh;
