---
import { buildAppPageUrl } from '../lib/app-url';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fight Prophet',
  description = 'AI-powered sports analytics and prediction insights',
} = Astro.props as Props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://fightprophet.com';
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.fightprophet.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL('/branding/fightprophet_logo_white.png', siteUrl).toString();

const withPage = (slug: string) => buildAppPageUrl(appUrl, slug);
const predictionsEmojiUrl = '/branding/b91c1c-predictions-emoji-rail.png';
const fighterCardsEmojiUrl = '/branding/b91c1c-fighterscard-emoji-rail.png';
const beltEmojiUrl = '/branding/b91c1c-belt-emoji-rail.png';
const eventsEmojiUrl = '/branding/b91c1c-events-emoji-rail.png';
const rankingsEmojiUrl = '/branding/b91c1c-goat-emoji-rail.png';
const labEmojiUrl = '/branding/b91c1c-lab-emoji-rail.png';
const termsEmojiUrl = '/branding/b91c1c-terms-emoji-rail.png';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/' || currentPath === '/rankings' || currentPath === '/rankings/';
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href={appUrl} crossorigin />
    <link rel="dns-prefetch" href={appUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/png" sizes="32x32" media="(prefers-color-scheme: dark)" href="/branding/white_ear_favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" media="(prefers-color-scheme: light)" href="/branding/ear_favicon_transparent.png" />
    <link rel="icon" type="image/x-icon" media="(prefers-color-scheme: dark)" href="/branding/white_ear_favicon.ico" />
    <link rel="icon" type="image/x-icon" media="(prefers-color-scheme: light)" href="/branding/ear_favicon_transparent.ico" />
    <link id="dynamic-favicon" rel="icon" type="image/png" sizes="32x32" href="/branding/ear_favicon_transparent.png" />
    <meta name="theme-color" content="#09090b" />
    <title>{title}</title>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5085788292969536" crossorigin="anonymous"></script>
    <script is:inline define:vars={{ appUrl }}>
      (() => {
        if (typeof window === 'undefined') return;
        const warm = () => {
          try {
            fetch(appUrl + '/_stcore/health', {
              mode: 'no-cors', credentials: 'omit', cache: 'no-store', keepalive: true,
            }).catch(() => {});
          } catch (e) { /* no-op */ }
        };
        if ('requestIdleCallback' in window) requestIdleCallback(warm, { timeout: 2500 });
        else setTimeout(warm, 1500);
      })();
    </script>
    <script is:inline>
      (() => {
        const updateFavicon = () => {
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const favicon = document.getElementById('dynamic-favicon');
          if (!favicon) return;
          favicon.setAttribute('href', prefersDark ? '/branding/white_ear_favicon.png' : '/branding/ear_favicon_transparent.png');
        };
        updateFavicon();
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        if (typeof media.addEventListener === 'function') media.addEventListener('change', updateFavicon);
        else if (typeof media.addListener === 'function') media.addListener(updateFavicon);
      })();
    </script>
  </head>
  <body>

    <!-- Backdrop (mobile only) -->
    <div class="fp-rail-backdrop" id="fp-rail-backdrop" hidden></div>
    <div class="fp-app-transition" id="fp-app-transition" aria-hidden="true" hidden>
      <div class="fp-app-transition-card">
        <div class="fp-app-transition-spinner" aria-hidden="true"></div>
        <strong>Opening Fight Prophet App</strong>
        <span>Loading predictions, rankings, and fighter data…</span>
      </div>
    </div>

    <!-- Left rail -->
    <aside class="fp-app-rail-shell" id="fp-app-rail-shell" aria-label="Site navigation">
      <button type="button" class="fp-rail-close" id="fp-rail-close" aria-label="Close navigation">×</button>
      <div class="fp-app-rail">
        <a href="/" class="fp-app-rail-logo-wrap">
          <img src="/branding/fightprophet_logo_white.png" alt="Fight Prophet" class="fp-app-rail-logo" loading="lazy" />
        </a>

        <!-- Language switcher -->
        <div class="fp-lang-switch fp-lang-switch-rail" aria-label="Language selector">
          <button type="button" class="fp-lang-btn" data-lang="es" title="Español">🇨🇴</button>
          <button type="button" class="fp-lang-btn" data-lang="pt" title="Português">🇧🇷</button>
          <button type="button" class="fp-lang-btn" data-lang="en" title="English">🇺🇸</button>
        </div>

        <div class="fp-app-rail-heading">Bet wisely with Fight Prophet</div>
        <div class="fp-app-rail-subheading">AI-powered MMA fight predictions</div>
        <div class="fp-app-rail-section-label">Navigate</div>

        <!-- App nav — Home (rankings) is the entry point; the rest open the Streamlit app -->
        <nav class="fp-app-rail-nav" aria-label="App sections">
          <a class={`fp-app-rail-nav-link${isActive('/') ? ' is-active is-primary-nav' : ''}`} href="/"><span class="fp-app-rail-nav-copy"><img src={rankingsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>Home &amp; Rankings</span></span></a>
          <a class="fp-app-rail-nav-link" href={withPage('predictions')}><span class="fp-app-rail-nav-copy"><img src={predictionsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>Predictions</span></span></a>
          <a class="fp-app-rail-nav-link" href={withPage('fighter-card')}><span class="fp-app-rail-nav-copy"><img src={fighterCardsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>Fighter Cards</span></span></a>
          <a class="fp-app-rail-nav-link" href={withPage('belt-holders')}><span class="fp-app-rail-nav-copy"><img src={beltEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>Belt Holders</span></span></a>
          <a class="fp-app-rail-nav-link" href={withPage('events-history')}><span class="fp-app-rail-nav-copy"><img src={eventsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>Events History</span></span></a>
          <a class="fp-app-rail-nav-link" href={withPage('fight-lab')}><span class="fp-app-rail-nav-copy"><img src={labEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>Fight Lab</span></span></a>
          <a class={`fp-app-rail-nav-link${isActive('/terms/') ? ' is-active' : ''}`} href="/terms/"><span class="fp-app-rail-nav-copy"><img src={termsEmojiUrl} alt="" class="fp-app-rail-nav-icon" loading="lazy" aria-hidden="true" /><span>Terms &amp; Conditions</span></span></a>
        </nav>

        <!-- Footer -->
        <div class="fp-app-rail-footer">
          <img src="/branding/fightprophet_ear_white.png" alt="" class="fp-app-rail-mini-mark" loading="lazy" aria-hidden="true" />
          <div class="fp-app-rail-divider"></div>
          <div class="fp-app-rail-links is-footer">
            <a class="fp-app-rail-link is-muted" href="https://www.linkedin.com/company/fight-prophet" target="_blank" rel="noopener noreferrer">Business LinkedIn</a>
            <a class="fp-app-rail-link is-muted" href="https://www.linkedin.com/in/datatomas/" target="_blank" rel="noopener noreferrer">Founder LinkedIn</a>
            <a class="fp-app-rail-link is-muted" href="https://github.com/datatomas/fight_prophet" target="_blank" rel="noopener noreferrer">Business GitHub</a>
            <a class="fp-app-rail-link is-muted" href="/terms/">Terms</a>
            <a class="fp-app-rail-link is-muted" href="/privacy/">Privacy</a>
          </div>
        </div>
      </div>
    </aside>

    <!-- Page content -->
    <div class="fp-layout-wrap">
      <!-- Mobile top bar — only visible on small screens, part of normal flow so nothing overlaps -->
      <div class="fp-mobile-topbar" id="fp-mobile-topbar">
        <button
          type="button"
          class="fp-rail-toggle"
          id="fp-rail-toggle"
          aria-controls="fp-app-rail-shell"
          aria-expanded="false"
          aria-label="Open navigation"
        >
          <span aria-hidden="true">☰</span>
        </button>
      </div>
      <main>
        <slot />
      </main>
      <footer class="fp-site-footer">
        <nav class="fp-site-footer-nav" aria-label="Site sections">
          <a href="/">Home</a>
          <a href={withPage('predictions')}>Predictions</a>
          <a href={withPage('fight-lab')}>Fight Lab</a>
          <a href="/#fp-rankings">Rankings</a>
          <a href={withPage('belt-holders')}>Belt Holders</a>
          <a href={withPage('fighter-card')}>Fighter Cards</a>
          <a href={withPage('events-history')}>Events History</a>
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
        </nav>
        <p class="fp-site-footer-meta">© Fight Prophet · Information and education only — not financial advice.</p>
      </footer>
    </div>

  </body>
</html>

<script is:inline define:vars={{ appUrl }}>
  (() => {
    const RAIL_WIDTH = 260;
    const DESKTOP_BP = 901;
    const FP_LANG_KEY = 'fp_lang';

    const layout = document.querySelector('.fp-layout-wrap') as HTMLElement | null;
    const rail = document.getElementById('fp-app-rail-shell') as HTMLElement | null;
    const toggle = document.getElementById('fp-rail-toggle') as HTMLButtonElement | null;
    const closeBtn = document.getElementById('fp-rail-close') as HTMLButtonElement | null;
    const backdrop = document.getElementById('fp-rail-backdrop') as HTMLElement | null;
    const transition = document.getElementById('fp-app-transition') as HTMLElement | null;
    const body = document.body;
    const appOrigin = (() => {
      try {
        return new URL(appUrl).origin;
      } catch {
        return '';
      }
    })();
    let warmStarted = false;

    const isMobile = () => window.innerWidth < DESKTOP_BP;
    const canWarm = () => Boolean(appOrigin);
    const warmApp = () => {
      if (!canWarm() || warmStarted) return;
      warmStarted = true;
      try {
        fetch(appOrigin + '/_stcore/health', {
          mode: 'no-cors',
          credentials: 'omit',
          cache: 'no-store',
          keepalive: true,
        }).catch(() => {});
      } catch {
        // no-op
      }
    };
    const showAppTransition = () => {
      if (!transition) return;
      transition.hidden = false;
      transition.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => {
        transition.dataset.visible = 'true';
      });
    };
    const isPrimaryNavClick = (event: MouseEvent) =>
      event.button === 0 && !event.metaKey && !event.ctrlKey && !event.shiftKey && !event.altKey;
    const isAppLink = (anchor: HTMLAnchorElement) => {
      if (!canWarm()) return false;
      try {
        return new URL(anchor.href, window.location.href).origin === appOrigin;
      } catch {
        return false;
      }
    };

    const setOpen = (open: boolean) => {
      if (!rail) return;
      rail.dataset.railOpen = open ? 'true' : 'false';
      if (toggle) {
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
      }
      if (backdrop) backdrop.hidden = !open;
      body.style.overflow = open && isMobile() ? 'hidden' : '';
    };

    if (toggle) toggle.addEventListener('click', () => setOpen(rail?.dataset.railOpen !== 'true'));
    if (closeBtn) closeBtn.addEventListener('click', () => setOpen(false));
    if (backdrop) backdrop.addEventListener('click', () => setOpen(false));

    if (rail) {
      rail.addEventListener('click', (event) => {
        if (event.target instanceof HTMLAnchorElement && isMobile()) setOpen(false);
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && rail?.dataset.railOpen === 'true') setOpen(false);
    });

    const desktopQuery = window.matchMedia(`(min-width: ${DESKTOP_BP}px)`);
    const handleViewport = () => {
      if (desktopQuery.matches) {
        setOpen(false);
        body.style.overflow = '';
      }
    };
    handleViewport();
    if (typeof desktopQuery.addEventListener === 'function') desktopQuery.addEventListener('change', handleViewport);
    else if (typeof desktopQuery.addListener === 'function') (desktopQuery as any).addListener(handleViewport);

    // Language button active state (full applyLanguage is in index.astro for home content)
    const initLangButtons = (lang: string) => {
      document.querySelectorAll<HTMLButtonElement>('.fp-lang-btn').forEach((btn) => {
        btn.classList.toggle('is-active', btn.dataset.lang === lang);
      });
      document.documentElement.lang = lang;
    };

    const storedLang = localStorage.getItem(FP_LANG_KEY) || 'en';
    initLangButtons(storedLang);

    document.querySelectorAll<HTMLButtonElement>('.fp-lang-btn[data-lang]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = btn.dataset.lang || 'en';
        localStorage.setItem(FP_LANG_KEY, lang);
        initLangButtons(lang);
      });
    });

    document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((anchor) => {
      if (!isAppLink(anchor)) return;

      const earlyWarm = () => warmApp();
      anchor.addEventListener('mouseenter', earlyWarm, { passive: true });
      anchor.addEventListener('focus', earlyWarm, { passive: true });
      anchor.addEventListener('touchstart', earlyWarm, { passive: true });
      anchor.addEventListener('click', (event) => {
        warmApp();
        if (!isPrimaryNavClick(event)) return;
        showAppTransition();
      });
    });
  })();
</script>

<style>
  :global(:root) {
    --fp-rail-width: 260px;
    --fp-shell-max: 1720px;
  }

  :global(html, body) {
    margin: 0;
    font-family: Inter, system-ui, sans-serif;
    background: #09090b;
    color: #f4f4f5;
  }

  :global(body) {
    position: relative;
    min-height: 100vh;
    isolation: isolate;
  }

  :global(body)::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(9, 9, 11, 0.52) 0%, rgba(9, 9, 11, 0.68) 32%, rgba(9, 9, 11, 0.8) 100%),
      url('/background.png') center top / cover fixed no-repeat;
    z-index: -3;
    pointer-events: none;
  }

  :global(body)::after {
    content: '';
    position: fixed;
    left: 50%;
    top: 53%;
    width: min(32vw, 420px);
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    background: url('/branding/fightprophet_ear_white.png') center center / contain no-repeat;
    opacity: 0.12;
    filter: drop-shadow(0 0 22px rgba(220, 38, 38, 0.15));
    z-index: -2;
    pointer-events: none;
  }

  /* ── Mobile top bar (hidden on desktop) ───────────────────────────── */
  .fp-mobile-topbar {
    display: none;
    align-items: center;
    padding: 0.5rem 0.75rem;
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(9, 9, 11, 0.88);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid rgba(220, 38, 38, 0.18);
  }

  /* ── Rail toggle button ────────────────────────────────────────────── */
  .fp-rail-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.6rem;
    border: 1px solid rgba(220, 38, 38, 0.45);
    background: linear-gradient(160deg, rgba(35, 20, 20, 0.94), rgba(22, 22, 26, 0.94));
    color: #fef2f2;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35), 0 0 8px rgba(220, 38, 38, 0.15);
    flex-shrink: 0;
  }

  /* ── Backdrop (mobile only) ───────────────────────────────────────── */
  .fp-rail-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
    z-index: 50;
  }

  .fp-app-transition {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    background: rgba(9, 9, 11, 0.3);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 180ms ease;
    pointer-events: none;
  }

  .fp-app-transition[data-visible="true"] {
    opacity: 1;
  }

  .fp-app-transition-card {
    display: grid;
    gap: 0.45rem;
    min-width: min(92vw, 320px);
    padding: 1rem 1.05rem;
    border-radius: 1rem;
    border: 1px solid rgba(248, 113, 113, 0.34);
    background: linear-gradient(155deg, rgba(18, 18, 22, 0.94), rgba(45, 18, 18, 0.88));
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.34), 0 0 28px rgba(220, 38, 38, 0.14);
    color: #f4f4f5;
    text-align: center;
  }

  .fp-app-transition-card strong {
    font-size: 0.96rem;
    letter-spacing: 0.02em;
  }

  .fp-app-transition-card span {
    font-size: 0.84rem;
    color: #d4d4d8;
  }

  .fp-app-transition-spinner {
    width: 1.8rem;
    height: 1.8rem;
    margin: 0 auto 0.1rem;
    border-radius: 999px;
    border: 2px solid rgba(255, 255, 255, 0.16);
    border-top-color: #f87171;
    animation: fp-app-transition-spin 700ms linear infinite;
  }

  @keyframes fp-app-transition-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ── Close button (inside rail, mobile only) ──────────────────────── */
  .fp-rail-close {
    display: none;
    position: absolute;
    top: 0.55rem;
    right: 0.6rem;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid rgba(220, 38, 38, 0.45);
    background: rgba(15, 15, 18, 0.88);
    color: #fef2f2;
    font-size: 1.32rem;
    line-height: 1;
    cursor: pointer;
    z-index: 2;
  }

  /* ── Left rail shell ──────────────────────────────────────────────── */
  .fp-app-rail-shell {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    height: 100dvh;
    width: var(--fp-rail-width);
    z-index: 60;
    background: linear-gradient(180deg, rgba(14, 14, 18, 0.98), rgba(22, 12, 12, 0.96));
    border-right: 1px solid rgba(220, 38, 38, 0.22);
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.35), inset -1px 0 0 rgba(127, 29, 29, 0.28);
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    box-sizing: border-box;
  }

  .fp-app-rail {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.1rem 0.95rem 1.6rem;
    min-height: 100%;
  }

  .fp-app-rail-logo-wrap {
    display: block;
    line-height: 0;
  }

  .fp-app-rail-logo {
    width: min(220px, 100%);
    height: auto;
    object-fit: contain;
  }

  /* Language switch — always fills the full rail content width */
  .fp-lang-switch {
    display: flex;
    width: 100%;
    gap: 0.28rem;
    background: rgba(15, 15, 18, 0.64);
    border: 1px solid rgba(113, 113, 122, 0.42);
    border-radius: 9999px;
    padding: 0.25rem;
    box-sizing: border-box;
  }
  :global(.fp-lang-btn) {
    /* Each button takes an equal share of the container width and stays square */
    flex: 1 1 0;
    min-width: 0;
    aspect-ratio: 1 / 1;
    border: 0;
    background: transparent;
    color: #f4f4f5;
    border-radius: 9999px;
    cursor: pointer;
    font-size: clamp(1rem, 4.5cqi, 1.5rem);
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    box-sizing: border-box;
  }
  :global(.fp-lang-btn.is-active) {
    background: linear-gradient(160deg, #ef4444, #b91c1c);
    /* ring sits outside the box model — never displaces sibling buttons */
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.5);
  }
  .fp-app-rail-heading {
    margin: 0.3rem 0 0.15rem;
    color: #f4f4f5;
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }
  .fp-app-rail-subheading {
    margin: 0 0 0.9rem;
    color: #a1a1aa;
    font-size: 0.84rem;
    line-height: 1.45;
  }
  .fp-app-rail-section-label {
    margin: 0 0 0.35rem;
    color: #a1a1aa;
    font-size: 0.9rem;
    line-height: 1.35;
  }

  /* Site nav */
  .fp-app-rail-nav {
    display: grid;
    gap: 0.22rem;
  }
  .fp-app-rail-nav-copy {
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr);
    align-items: center;
    column-gap: 0.9rem;
    width: 100%;
  }
  .fp-app-rail-nav-icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
    justify-self: center;
    opacity: 0.95;
    filter: brightness(1.45) saturate(1.45) contrast(1.18) drop-shadow(0 0 6px rgba(220, 38, 38, 0.26));
    transition: filter 120ms ease, transform 120ms ease, opacity 120ms ease;
  }

  .fp-app-rail-nav-link {
    display: flex;
    align-items: center;
    padding: 0.52rem 0.7rem;
    border-radius: 0.65rem;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    color: #d4d4d8;
    transition: background 80ms ease, border-color 80ms ease;
  }
  .fp-app-rail-nav-link:hover {
    background: rgba(220, 38, 38, 0.12);
    border-color: rgba(220, 38, 38, 0.22);
    color: #fef2f2;
  }
  .fp-app-rail-nav-link:hover .fp-app-rail-nav-icon {
