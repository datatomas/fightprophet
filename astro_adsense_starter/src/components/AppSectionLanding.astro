---
import { buildAppPageUrl } from '../lib/app-url';
import AdSlot from './AdSlot.astro';

interface Bullet {
  title: string;
  body: string;
}

interface Props {
  pageSlug: string;
  heading: string;
  intro: string;
  bullets: Bullet[];
  whatYouWillSee: string[];
  ctaLabel?: string;
  noAd?: boolean;
}

const {
  pageSlug,
  heading,
  intro,
  bullets,
  whatYouWillSee,
  ctaLabel = 'Open in Fight Prophet App',
  noAd = false,
} = Astro.props as Props;

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.fightprophet.com';
const targetUrl = buildAppPageUrl(appUrl, pageSlug);
---

<article class="fp-landing">
  <header class="fp-landing-header">
    <div class="fp-landing-header-inner">
      <a class="fp-landing-breadcrumb" href="/">← Fight Prophet</a>
      <h1>{heading}</h1>
      <p class="fp-landing-intro">{intro}</p>
    </div>
  </header>

  <div class="fp-landing-grid">
    <section class="fp-landing-section">
      <h2>What this section covers</h2>
      <ul class="fp-landing-bullets">
        {bullets.map((b) => (
          <li>
            <strong>{b.title}.</strong> {b.body}
          </li>
        ))}
      </ul>
    </section>

    <section class="fp-landing-section">
      <h2>What you will see when you open it</h2>
      <ul class="fp-landing-list">
        {whatYouWillSee.map((line) => <li>{line}</li>)}
      </ul>
    </section>
  </div>

  {!noAd && <AdSlot slot="1234567890" />}

  <section class="fp-landing-section fp-landing-disclaimer">
    <h2>Important note</h2>
    <p>
      Fight Prophet is provided for information and education only. Model outputs reflect
      historical patterns and probability estimates — not guaranteed outcomes — and should
      never be treated as financial advice.
    </p>
  </section>

  <footer class="fp-landing-footer">
    <a class="fp-btn fp-btn-primary" href={targetUrl}>{ctaLabel}</a>
  </footer>
</article>

<style>
  .fp-landing {
    display: grid;
    gap: 1.1rem;
  }
  .fp-landing-header {
    position: relative;
    background: linear-gradient(155deg, rgba(20, 20, 22, 0.96) 0%, rgba(40, 20, 20, 0.84) 100%);
    border: 1px solid rgba(220, 38, 38, 0.28);
    border-radius: 1.05rem;
    padding: 1.6rem 1.4rem;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04), 0 10px 26px rgba(0, 0, 0, 0.28), 0 0 22px rgba(220, 38, 38, 0.12);
  }
  .fp-landing-header::after {
    content: '';
    position: absolute;
    inset: -10% -15% -15% -15%;
    background: url('/branding/cageiconmma.png') center center / 88% auto no-repeat;
    opacity: 0.13;
    pointer-events: none;
    z-index: 0;
  }
  .fp-landing-header-inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.55rem;
    max-width: 60ch;
  }
  .fp-landing-breadcrumb {
    display: inline-block;
    color: #fca5a5;
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 0.1rem;
  }
  .fp-landing-breadcrumb:hover {
    color: #fef2f2;
  }
  .fp-landing-header h1 {
    margin: 0;
    font-size: clamp(1.7rem, 4.4vw, 2.4rem);
    line-height: 1.1;
    color: #fef2f2;
    text-shadow: 0 0 12px rgba(220, 38, 38, 0.32);
  }
  .fp-landing-intro {
    margin: 0;
    color: #e4e4e7;
    line-height: 1.6;
  }
  .fp-landing-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.4rem;
  }
  .fp-landing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }
  .fp-landing-section {
    background: linear-gradient(150deg, rgba(22, 22, 26, 0.9), rgba(36, 36, 42, 0.68));
    border: 1px solid rgba(113, 113, 122, 0.42);
    border-radius: 0.9rem;
    padding: 1rem 1.1rem;
    color: #d4d4d8;
    line-height: 1.6;
  }
  .fp-landing-section h2 {
    margin: 0 0 0.55rem;
    font-size: 1.02rem;
    color: #fef2f2;
    letter-spacing: 0.01em;
  }
  .fp-landing-bullets,
  .fp-landing-list {
    margin: 0;
    padding-left: 1.15rem;
  }
  .fp-landing-bullets li,
  .fp-landing-list li {
    margin-bottom: 0.45rem;
  }
  .fp-landing-bullets strong {
    color: #fca5a5;
    font-weight: 700;
  }
  .fp-landing-disclaimer {
    border-color: rgba(220, 38, 38, 0.28);
    background: linear-gradient(150deg, rgba(35, 20, 20, 0.72), rgba(22, 22, 26, 0.90));
  }
  .fp-landing-footer {
    display: flex;
    justify-content: center;
    padding: 0.4rem 0 1rem;
  }
  .fp-btn {
    border: 1px solid rgba(220, 38, 38, 0.45);
    border-radius: 0.65rem;
    padding: 0.6rem 0.95rem;
    text-decoration: none;
    color: #f4f4f5;
    background: linear-gradient(160deg, rgba(45, 24, 24, 0.65), rgba(39, 39, 42, 0.45));
    font-weight: 650;
    font-size: 0.95rem;
    box-shadow: 0 0 12px rgba(220, 38, 38, 0.14);
  }
  .fp-btn-primary {
    background: linear-gradient(160deg, #ef4444, #dc2626);
    color: #ffffff;
    border-color: rgba(248, 113, 113, 0.65);
    box-shadow: 0 0 14px rgba(239, 68, 68, 0.35);
  }
  @media (max-width: 760px) {
    .fp-landing-grid {
      grid-template-columns: 1fr;
    }
    .fp-landing-header {
      padding: 1.3rem 1.1rem;
    }
    .fp-landing-header::after {
      inset: -6% -8% -10% -8%;
      background-size: 100% auto;
    }
  }
</style>
