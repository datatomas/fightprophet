---
const subscribeEndpoint =
  import.meta.env.PUBLIC_BUTTONDOWN_SUBSCRIBE_URL ||
  'https://buttondown.com/api/emails/embed-subscribe/fightprophet';
const archiveUrl = 'https://buttondown.com/fightprophet';
---

<section id="fp-newsletter" class="fp-newsletter" aria-labelledby="fp-newsletter-title">
  <div class="fp-newsletter-mark" aria-hidden="true">
    <img src="/branding/fightprophet_ear_white.png" alt="" loading="lazy" />
  </div>
  <div class="fp-newsletter-copy">
    <p class="fp-section-label" id="i18n-newsletter-label">Fight Prophet Weekly</p>
    <h2 id="fp-newsletter-title">Get the next fight-card readout.</h2>
    <p id="i18n-newsletter-copy">
      Weekly MMA predictions, ranking movement, fighter-card updates, and model notes from Uppercut Analytics.
    </p>
  </div>
  <form
    action={subscribeEndpoint}
    method="post"
    class="fp-newsletter-form embeddable-buttondown-form"
    aria-describedby="fp-newsletter-disclaimer"
  >
    <label for="bd-email" class="fp-newsletter-label" id="i18n-newsletter-input-label">Email address</label>
    <div class="fp-newsletter-controls">
      <input
        type="email"
        name="email"
        id="bd-email"
        autocomplete="email"
        placeholder="Enter your email"
        required
      />
      <button type="submit" id="i18n-newsletter-submit">Subscribe</button>
    </div>
    <p id="fp-newsletter-disclaimer" class="fp-newsletter-disclaimer">
      Information and education only. Not financial or betting advice.
    </p>
    <a class="fp-newsletter-powered" href={archiveUrl} target="_blank" rel="noopener noreferrer">
      Powered by Buttondown.
    </a>
  </form>
</section>

<style>
  .fp-newsletter {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) minmax(280px, 440px);
    gap: 1rem;
    align-items: center;
    padding: 1rem 0;
    border-top: 1px solid rgba(220, 38, 38, 0.26);
    border-bottom: 1px solid rgba(113, 113, 122, 0.28);
    background:
      linear-gradient(90deg, rgba(127, 29, 29, 0.18), transparent 56%),
      rgba(9, 9, 11, 0.34);
  }

  .fp-newsletter-mark {
    display: grid;
    place-items: center;
    width: 4.2rem;
    height: 4.2rem;
    margin-left: 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(248, 113, 113, 0.34);
    background: radial-gradient(circle, rgba(185, 28, 28, 0.28), rgba(24, 24, 27, 0.68));
    box-shadow: inset 0 0 16px rgba(248, 113, 113, 0.12);
  }

  .fp-newsletter-mark img {
    width: 2.8rem;
    height: 2.8rem;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(248, 113, 113, 0.24));
  }

  .fp-newsletter-copy {
    min-width: 0;
  }

  .fp-newsletter-copy h2 {
    margin: 0.18rem 0 0;
    color: #fef2f2;
    font-size: clamp(1.05rem, 2.1vw, 1.32rem);
    line-height: 1.25;
    font-weight: 800;
  }

  .fp-newsletter-copy p:last-child {
    margin: 0.38rem 0 0;
    color: #d4d4d8;
    font-size: 0.9rem;
    line-height: 1.5;
    max-width: 58ch;
  }

  .fp-newsletter-form {
    display: grid;
    gap: 0.44rem;
    margin-right: 0.85rem;
  }

  .fp-newsletter-label {
    color: #fef2f2;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .fp-newsletter-controls {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.45rem;
  }

  .fp-newsletter-controls input {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding: 0.72rem 0.8rem;
    color: #f4f4f5;
    background: rgba(24, 24, 27, 0.82);
    border: 1px solid rgba(113, 113, 122, 0.48);
    border-radius: 0.7rem;
    font: inherit;
    outline: none;
  }

  .fp-newsletter-controls input:focus {
    border-color: rgba(248, 113, 113, 0.72);
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.18);
  }

  .fp-newsletter-controls button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.72rem 1rem;
    color: #ffffff;
    background: linear-gradient(160deg, #ef4444, #b91c1c);
    border: 1px solid rgba(248, 113, 113, 0.64);
    border-radius: 0.7rem;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
    white-space: nowrap;
  }

  .fp-newsletter-controls button:hover {
    box-shadow: 0 0 18px rgba(239, 68, 68, 0.28);
  }

  .fp-newsletter-disclaimer,
  .fp-newsletter-powered {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .fp-newsletter-disclaimer {
    color: #a1a1aa;
  }

  .fp-newsletter-powered {
    color: #71717a;
    text-decoration: none;
    justify-self: start;
  }

  .fp-newsletter-powered:hover {
    color: #fca5a5;
  }

  @media (max-width: 980px) {
    .fp-newsletter {
      grid-template-columns: auto minmax(0, 1fr);
      align-items: start;
    }

    .fp-newsletter-form {
      grid-column: 1 / -1;
      margin: 0 0.85rem;
    }
  }

  @media (max-width: 560px) {
    .fp-newsletter {
      grid-template-columns: 1fr;
      gap: 0.7rem;
      padding: 0.95rem 0;
    }

    .fp-newsletter-mark {
      margin: 0 0.85rem;
      width: 3.6rem;
      height: 3.6rem;
    }

    .fp-newsletter-mark img {
      width: 2.35rem;
      height: 2.35rem;
    }

    .fp-newsletter-copy {
      margin: 0 0.85rem;
    }

    .fp-newsletter-controls {
      grid-template-columns: 1fr;
    }
  }
</style>
