---
import type { CountryEntry, CountryMasterIndex } from '../lib/country-master';

interface Props {
  name: string;
  fighterId?: string;
  country?: string;
  weightClass?: string;
  isChampion?: boolean;
  finishRate?: number | null;
  subRate?: number | null;
  winStreak?: number | null;
  lossStreak?: number | null;
  wins?: number | null;
  losses?: number | null;
  points?: number | null;
  rank?: number | null;
  globalRank?: number | null;
  divisionRank?: number | null;
  compact?: boolean;
}

const {
  name,
  fighterId = '',
  country = '',
  weightClass = '',
  isChampion = false,
  finishRate = null,
  subRate = null,
  winStreak = null,
  lossStreak = null,
  wins = null,
  losses = null,
  points = null,
  rank = null,
  globalRank = null,
  divisionRank = null,
  compact = false,
} = Astro.props as Props;

const profileUrl = `/fighter-card/?fighter=${encodeURIComponent(name)}`;
const countryIndex = ((Astro.locals.countryMaster as CountryMasterIndex | undefined)?.byAlias ?? {});

function normalizeCountryKey(value: string): string {
  return value.trim().toUpperCase();
}

function initials(n: string): string {
  return n
    .split(/\s+/)
    .map((p) => p[0])
    .filter(Boolean)
    .slice(0, 2)
    .join('')
    .toUpperCase();
}

function fmtPct(v: number | null | undefined): string {
  if (v == null || Number.isNaN(v)) return '—';
  const pct = v <= 1 ? v * 100 : v;
  return `${Math.round(pct)}%`;
}

function fmtInt(v: number | null | undefined): string {
  if (v == null || Number.isNaN(v)) return '—';
  return String(Math.trunc(v));
}

function fmtCompact(v: number | null | undefined): string {
  if (v == null || Number.isNaN(v)) return '—';
  const abs = Math.abs(v);
  if (abs >= 1000) return `${(v / 1000).toFixed(abs >= 10000 ? 0 : 1)}K`;
  if (abs >= 100) return String(Math.round(v));
  if (abs >= 10) return v.toFixed(1);
  return v.toFixed(2);
}

function divisionAbbrev(wc: string): string {
  if (!wc) return '';
  const map: Record<string, string> = {
    'flyweight': 'FLW',
    'bantamweight': 'BW',
    'featherweight': 'FW',
    'lightweight': 'LW',
    'welterweight': 'WW',
    'middleweight': 'MW',
    'light heavyweight': 'LHW',
    'heavyweight': 'HW',
    'strawweight': 'SW',
    "women's strawweight": 'WSW',
    "women's flyweight": 'WFLW',
    "women's bantamweight": 'WBW',
    "women's featherweight": 'WFW',
  };
  const key = wc.toLowerCase().trim();
  if (key in map) return map[key];
  return wc.split(/\s+/).map((p) => p[0]).join('').toUpperCase().slice(0, 4);
}

function countryRecord(value: string): CountryEntry | undefined {
  const key = normalizeCountryKey(value);
  if (!key) return undefined;
  return countryIndex[key];
}

function canonicalCountry(value: string): string {
  const record = countryRecord(value);
  if (record) return record.canonical_name;
  return value.trim();
}

function countryShort(value: string): string {
  const record = countryRecord(value);
  if (record?.iso2) return record.iso2;
  const canonical = canonicalCountry(value);
  if (!canonical) return '';
  return canonical
    .split(/\s+/)
    .map((p) => p[0])
    .filter(Boolean)
    .join('')
    .slice(0, 3)
    .toUpperCase();
}

function flagFor(value: string): string {
  const code = countryRecord(value)?.iso2 ?? value.trim().toUpperCase();
  if (!/^[A-Z]{2}$/.test(code)) return '';
  return String.fromCodePoint(...[...code].map((ch) => ch.charCodeAt(0) + 127397));
}

const canonicalCountryValue = canonicalCountry(country);
const flag = flagFor(country);
const countryCompact = countryShort(country);
const init = initials(name);
const wcAbbr = divisionAbbrev(weightClass);
const divisionLabel = weightClass.trim();
const recordLabel = wins != null && losses != null ? `${fmtInt(wins)}-${fmtInt(losses)}` : '';
const pointsLabel = fmtCompact(points);
const resolvedGlobalRank = globalRank ?? rank;
const resolvedDivisionRank = divisionRank ?? (globalRank != null ? rank : null);

const typeLine = [divisionLabel || 'MMA Fighter', canonicalCountryValue]
  .filter(Boolean)
  .join(' / ');
---

<a class={`fp-card ${isChampion ? 'is-champ' : 'is-default'}${compact ? ' is-compact' : ''}`} href={profileUrl} data-fighter-id={fighterId}>
  <div class="fp-card-frame" aria-hidden="true"></div>

  <div class="fp-card-top">
    <div class="fp-card-rating">
      {resolvedGlobalRank != null || resolvedDivisionRank != null ? (
        <>
          {resolvedGlobalRank != null && (
            <>
              <span class="fp-card-rating-num">#{resolvedGlobalRank}</span>
              <span class="fp-card-rating-pos">P4P</span>
            </>
          )}
          {resolvedDivisionRank != null && wcAbbr && (
            <span class="fp-card-rating-sub">{wcAbbr} #{resolvedDivisionRank}</span>
          )}
        </>
      ) : isChampion ? (
        <>
          <span class="fp-card-rating-num">C</span>
          {wcAbbr && <span class="fp-card-rating-pos">{wcAbbr}</span>}
        </>
      ) : (
        <>
          <span class="fp-card-rating-num">{recordLabel || fmtInt(wins)}</span>
          {wcAbbr && <span class="fp-card-rating-pos">{wcAbbr}</span>}
        </>
      )}
    </div>
    {flag && <span class="fp-card-flag" title={canonicalCountryValue}>{flag}</span>}
  </div>

  <header class="fp-card-banner">
    <span class="fp-card-name">{name}</span>
  </header>

  <div class="fp-card-portrait">
    <span class="fp-card-portrait-silhouette" aria-hidden="true">👤</span>
    <span class="fp-card-initials" aria-hidden="true">{init}</span>
    {isChampion && <span class="fp-card-crown" aria-label="Current champion">👑</span>}
  </div>

  <div class="fp-card-type-bar">[ {typeLine} ]</div>

  <div class="fp-card-desc">
    <div class="fp-card-stat-row">
      <span class="fp-card-stat"><em>FIN</em><b>{fmtPct(finishRate)}</b></span>
      <span class="fp-card-stat"><em>SUB</em><b>{fmtPct(subRate)}</b></span>
      <span class="fp-card-stat"><em>W★</em><b>{fmtInt(winStreak)}</b></span>
      <span class="fp-card-stat"><em>L✗</em><b>{fmtInt(lossStreak)}</b></span>
    </div>
    <div class="fp-card-atkdef">
      <span class="fp-card-atk">PTS/{pointsLabel}</span>
      <span class="fp-card-sep">·</span>
      <span class="fp-card-def">REC/{recordLabel || `${fmtInt(wins)}-${fmtInt(losses)}`}</span>
    </div>
  </div>

  <span class="fp-card-country-fallback" aria-hidden="true" data-country={countryCompact}></span>
</a>

<style>
  /* Yu-Gi-Oh-inspired card */
  .fp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-inline: auto;
    aspect-ratio: 59 / 86;
    min-height: 188px;
    text-decoration: none;
    color: #fef2f2;
    border-radius: 0.42rem;
    padding: 0.34rem 0.36rem 0.36rem;
    overflow: hidden;
    transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease;
    isolation: isolate;
  }
  .fp-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: -1;
  }
  .fp-card-frame {
    position: absolute;
    inset: 0.18rem;
    border-radius: 0.28rem;
    z-index: 0;
    pointer-events: none;
  }
  .fp-card.is-default::before {
    background: linear-gradient(160deg, #ef4444 0%, #b91c1c 35%, #7f1d1d 70%, #2a0808 100%);
  }
  .fp-card.is-default .fp-card-frame {
    background:
      radial-gradient(110% 80% at 50% 0%, rgba(220, 38, 38, 0.18), transparent 70%),
      linear-gradient(180deg, #1a0c0c 0%, #100808 100%);
    border: 1px solid rgba(185, 28, 28, 0.7);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.55),
      inset 0 0 18px rgba(0, 0, 0, 0.5);
  }
  .fp-card.is-champ::before {
    background: linear-gradient(160deg, #ffe27a 0%, #d09312 30%, #6c4404 60%, #2a1908 100%);
  }
  .fp-card.is-champ .fp-card-frame {
    background:
      radial-gradient(110% 80% at 50% 0%, rgba(255, 240, 170, 0.28), transparent 70%),
      linear-gradient(180deg, #4a311a 0%, #1c1207 100%);
    border: 1px solid rgba(255, 240, 170, 0.72);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.45),
      inset 0 0 22px rgba(255, 220, 140, 0.18);
  }
  .fp-card:hover {
    transform: translateY(-2px) scale(1.01);
  }
  .fp-card.is-default:hover {
    box-shadow: 0 0 18px rgba(255, 180, 80, 0.34);
  }
  .fp-card.is-champ:hover {
    box-shadow: 0 0 22px rgba(255, 220, 130, 0.55);
  }

  /* NAME BANNER */
  .fp-card-banner {
    position: relative;
    z-index: 2;
    padding: 0.18rem 0.32rem;
    background: linear-gradient(180deg, #ef4444 0%, #b91c1c 60%, #7f1d1d 100%);
    border: 1px solid rgba(248, 113, 113, 0.65);
    border-radius: 0.22rem;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.22), 0 1px 0 rgba(0, 0, 0, 0.3);
    text-align: center;
  }
  .is-champ .fp-card-banner {
    background: linear-gradient(180deg, #fff0a8 0%, #d6a32a 50%, #8a5905 100%);
    border-color: rgba(255, 235, 170, 0.6);
  }
  .fp-card-name {
    display: -webkit-box;
    min-height: 1.5em;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.08;
    color: #fff5f5;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.4);
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    text-wrap: balance;
  }
  .is-champ .fp-card-name {
    color: #1a0e00;
    text-shadow: 0 1px 0 rgba(255, 230, 160, 0.55);
  }

  /* TOP ROW — rating chip on left, flag on right */
  .fp-card-top {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.32rem;
    margin: 0 0 0.18rem;
    min-height: 1.5rem;
  }

  /* PORTRAIT WINDOW */
  .fp-card-portrait {
    position: relative;
    z-index: 2;
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 0.04rem;
    border: 1.5px solid rgba(185, 28, 28, 0.75);
    border-radius: 0.16rem;
    background:
      radial-gradient(circle at 50% 35%, rgba(248, 113, 113, 0.16), transparent 56%),
      linear-gradient(180deg, #2a1010 0%, #0f0606 100%);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.5),
      inset 0 -10px 18px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    min-height: 64px;
  }
  .is-champ .fp-card-portrait {
    border-color: rgba(255, 240, 170, 0.85);
    background:
      radial-gradient(circle at 50% 35%, rgba(255, 240, 200, 0.24), transparent 58%),
      linear-gradient(180deg, #4a3214 0%, #1a1108 100%);
  }
  .fp-card-portrait-silhouette {
    font-size: 2.6rem;
    opacity: 0.18;
    line-height: 1;
    filter: blur(0.35px);
  }
  .is-champ .fp-card-portrait-silhouette {
    opacity: 0.24;
  }
  .fp-card-initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    color: rgba(254, 226, 226, 0.95);
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.7);
  }
  .is-champ .fp-card-initials {
    color: rgba(255, 240, 200, 0.95);
  }
  .fp-card-crown {
    position: absolute;
    top: 0.18rem;
    left: 0.22rem;
    font-size: 0.78rem;
    line-height: 1;
    z-index: 3;
    text-shadow: 0 0 4px rgba(0, 0, 0, 0.6);
  }
  .fp-card-flag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1.55rem;
    line-height: 1;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(185, 28, 28, 0.6);
    border-radius: 999px;
    padding: 0.18rem 0.5rem;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .is-champ .fp-card-flag {
    border-color: rgba(255, 220, 140, 0.55);
  }

  /* RANK CHIP — kept as .fp-card-rating so JS in index.astro still works */
  .fp-card-rating {
    position: relative;
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 0.34rem;
    padding: 0.2rem 0.46rem;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(185, 28, 28, 0.65);
    border-radius: 0.42rem;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.4);
    line-height: 1;
    min-width: 0;
    flex-shrink: 1;
    overflow: hidden;
  }
  .is-champ .fp-card-rating {
    background: linear-gradient(180deg, rgba(255, 240, 170, 0.92), rgba(180, 120, 30, 0.85));
    border-color: rgba(255, 240, 170, 0.85);
  }
  .fp-card-rating-num {
    font-size: 0.86rem;
    font-weight: 900;
    color: #fee2e2;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
  }
  .is-champ .fp-card-rating-num {
    color: #1a0e00;
    text-shadow: 0 1px 0 rgba(255, 240, 170, 0.55);
  }
  .fp-card-rating-pos {
    font-size: 0.48rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(252, 165, 165, 0.92);
  }
  .is-champ .fp-card-rating-pos {
    color: rgba(31, 19, 0, 0.78);
  }
  .fp-card-rating-sub {
    margin: 0;
    padding: 0.1rem 0.32rem;
    font-size: 0.48rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
    color: rgba(254, 226, 226, 0.95);
    background: rgba(0, 0, 0, 0.4);
    box-shadow: inset 0 0 0 1px rgba(185, 28, 28, 0.45);
    white-space: nowrap;
  }
  .is-champ .fp-card-rating-sub {
    color: rgba(31, 19, 0, 0.92);
    background: rgba(255, 240, 200, 0.45);
    box-shadow: inset 0 0 0 1px rgba(77, 50, 0, 0.18);
  }

  /* TYPE BAR — Yu-Gi-Oh "[Warrior / Effect]" feel */
  .fp-card-type-bar {
    position: relative;
    z-index: 2;
    margin: 0.18rem 0 0.14rem;
    padding: 0.2rem 0.26rem;
    background: linear-gradient(180deg, #3a1414 0%, #180808 100%);
    border-top: 1px solid rgba(185, 28, 28, 0.65);
    border-bottom: 1px solid rgba(185, 28, 28, 0.65);
    font-size: 0.58rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(252, 165, 165, 0.95);
    text-align: center;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .is-champ .fp-card-type-bar {
    background: linear-gradient(180deg, #3c2a14 0%, #1a1107 100%);
    border-top-color: rgba(255, 220, 140, 0.55);
    border-bottom-color: rgba(255, 220, 140, 0.55);
    color: rgba(255, 240, 180, 0.95);
  }

  /* DESCRIPTION / STATS / ATK-DEF */
  .fp-card-desc {
    position: relative;
    z-index: 2;
    background: linear-gradient(180deg, rgba(185, 28, 28, 0.12), rgba(0, 0, 0, 0.22));
    border: 1px solid rgba(185, 28, 28, 0.32);
    border-radius: 0.2rem;
    padding: 0.26rem 0.3rem 0.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
  }
  .is-champ .fp-card-desc {
    background: linear-gradient(180deg, rgba(255, 240, 170, 0.14), rgba(40, 24, 4, 0.32));
    border-color: rgba(255, 240, 170, 0.36);
  }
  .fp-card-stat-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.12rem 0.42rem;
    font-size: 0.7rem;
  }
  .fp-card-stat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.24rem;
    line-height: 1;
  }
  .fp-card-stat em {
    font-style: normal;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: rgba(252, 165, 165, 0.92);
  }
  .fp-card-stat b {
    font-weight: 900;
    color: #fef2f2;
    font-size: 0.82rem;
  }
  .is-champ .fp-card-stat em {
    color: rgba(255, 240, 180, 0.92);
  }
  .is-champ .fp-card-stat b {
    color: #fff5d6;
  }
  .fp-card-atkdef {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
    padding-top: 0.2rem;
    border-top: 1px solid rgba(185, 28, 28, 0.4);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.04em;
  }
  .is-champ .fp-card-atkdef {
    border-top-color: rgba(255, 220, 140, 0.32);
  }
  .fp-card-atk { color: #ff9a9a; }
  .fp-card-def { color: #cbd5ff; }
  .fp-card-sep { color: rgba(252, 165, 165, 0.65); }
  .is-champ .fp-card-atk { color: #ffb38a; }
  .is-champ .fp-card-def { color: #9ec9ff; }
  .is-champ .fp-card-sep { color: rgba(255, 220, 140, 0.6); }

  .fp-card-country-fallback { display: none; }

  /* COMPACT (used on the home deck) */
  .fp-card.is-compact {
    aspect-ratio: 59 / 86;
    min-height: calc(166px * var(--fp-card-scale, 1));
    padding: calc(0.26rem * var(--fp-card-scale, 1)) calc(0.28rem * var(--fp-card-scale, 1)) calc(0.28rem * var(--fp-card-scale, 1));
    border-radius: 0.32rem;
  }
  .fp-card.is-compact .fp-card-frame {
    inset: calc(0.13rem * var(--fp-card-scale, 1));
    border-radius: 0.22rem;
  }
  .fp-card.is-compact .fp-card-top {
    margin: 0 0 calc(0.12rem * var(--fp-card-scale, 1));
    min-height: calc(1.22rem * var(--fp-card-scale, 1));
    gap: 0.22rem;
  }
  .fp-card.is-compact .fp-card-banner {
    padding: calc(0.13rem * var(--fp-card-scale, 1)) calc(0.22rem * var(--fp-card-scale, 1));
  }
  .fp-card.is-compact .fp-card-name {
    font-size: calc(0.76rem * var(--fp-card-font-scale, 1));
    line-height: 1.05;
  }
  .fp-card.is-compact .fp-card-portrait {
    min-height: calc(58px * var(--fp-card-scale, 1));
  }
  .fp-card.is-compact .fp-card-portrait-silhouette {
    font-size: calc(2.05rem * var(--fp-card-scale, 1));
  }
  .fp-card.is-compact .fp-card-initials {
    font-size: calc(1.12rem * var(--fp-card-font-scale, 1));
  }
  .fp-card.is-compact .fp-card-crown {
    font-size: 0.64rem;
    top: 0.12rem;
    left: 0.18rem;
  }
  .fp-card.is-compact .fp-card-flag {
    font-size: calc(1.08rem * var(--fp-card-font-scale, 1));
    padding: 0.08rem 0.28rem;
  }
  .fp-card.is-compact .fp-card-rating {
    flex-wrap: wrap;
    padding: 0.12rem 0.28rem;
    gap: 0.14rem 0.2rem;
    border-radius: 0.28rem;
    max-width: calc(100% - 1.78rem);
  }
  .fp-card.is-compact .fp-card-rating-num {
    font-size: calc(0.84rem * var(--fp-card-font-scale, 1));
  }
  .fp-card.is-compact .fp-card-rating-pos {
    font-size: calc(0.46rem * var(--fp-card-font-scale, 1));
  }
  .fp-card.is-compact .fp-card-rating-sub {
    font-size: calc(0.44rem * var(--fp-card-font-scale, 1));
    padding: 0.07rem 0.22rem;
  }
  .fp-card.is-compact .fp-card-type-bar {
    margin: calc(0.13rem * var(--fp-card-scale, 1)) 0 calc(0.1rem * var(--fp-card-scale, 1));
    padding: 0.13rem 0.18rem;
    font-size: calc(0.52rem * var(--fp-card-font-scale, 1));
    letter-spacing: 0.04em;
  }
  .fp-card.is-compact .fp-card-desc {
    padding: calc(0.18rem * var(--fp-card-scale, 1)) calc(0.2rem * var(--fp-card-scale, 1)) calc(0.2rem * var(--fp-card-scale, 1));
    gap: calc(0.15rem * var(--fp-card-scale, 1));
  }
  .fp-card.is-compact .fp-card-stat-row {
    font-size: calc(0.66rem * var(--fp-card-font-scale, 1));
    gap: 0.1rem 0.28rem;
  }
  .fp-card.is-compact .fp-card-stat b {
    font-size: calc(0.8rem * var(--fp-card-font-scale, 1));
  }
  .fp-card.is-compact .fp-card-atkdef {
    font-size: calc(0.72rem * var(--fp-card-font-scale, 1));
    padding-top: 0.16rem;
    gap: 0.22rem;
    justify-content: space-between;
  }

  @media (max-width: 640px) {
    .fp-card-name {
      font-size: 0.64rem;
    }
    .fp-card-stat-row {
      font-size: 0.6rem;
    }
    .fp-card-stat b {
      font-size: 0.7rem;
    }
    .fp-card-atkdef {
      font-size: 0.7rem;
    }
  }
</style>
