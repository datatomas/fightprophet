---
interface Props {
  name: string;
  fighterId?: string;
  country?: string;
  weightClass?: string;
  isChampion?: boolean;
  finishRate?: number | null;
  subRate?: number | null;
  winStreak?: number | null;
  lossStreak?: number | null;
  wins?: number | null;
  losses?: number | null;
  appUrl?: string;
}

const {
  name,
  fighterId = '',
  country = '',
  weightClass = '',
  isChampion = false,
  finishRate = null,
  subRate = null,
  winStreak = null,
  lossStreak = null,
  wins = null,
  losses = null,
  appUrl = 'https://app.fightprophet.com',
} = Astro.props as Props;

const profileUrl = `${appUrl}${appUrl.includes('?') ? '&' : '?'}page=fighter-profile&fighter=${encodeURIComponent(name)}`;

function initials(n: string): string {
  return n
    .split(/\s+/)
    .map((p) => p[0])
    .filter(Boolean)
    .slice(0, 2)
    .join('')
    .toUpperCase();
}

function fmtPct(v: number | null | undefined): string {
  if (v == null || Number.isNaN(v)) return '—';
  const pct = v <= 1 ? v * 100 : v;
  return `${Math.round(pct)}%`;
}

function fmtInt(v: number | null | undefined): string {
  if (v == null || Number.isNaN(v)) return '—';
  return String(Math.trunc(v));
}

function divisionAbbrev(wc: string): string {
  if (!wc) return '';
  const map: Record<string, string> = {
    'flyweight': 'FLW',
    'bantamweight': 'BW',
    'featherweight': 'FW',
    'lightweight': 'LW',
    'welterweight': 'WW',
    'middleweight': 'MW',
    'light heavyweight': 'LHW',
    'heavyweight': 'HW',
    'strawweight': 'SW',
    "women's strawweight": 'WSW',
    "women's flyweight": 'WFLW',
    "women's bantamweight": 'WBW',
    "women's featherweight": 'WFW',
  };
  const key = wc.toLowerCase().trim();
  if (key in map) return map[key];
  return wc.split(/\s+/).map((p) => p[0]).join('').toUpperCase().slice(0, 4);
}

function flagFor(c: string): string {
  if (!c) return '';
  const map: Record<string, string> = {
    usa: '🇺🇸',
    'united states': '🇺🇸',
    us: '🇺🇸',
    'united states of america': '🇺🇸',
    brazil: '🇧🇷',
    br: '🇧🇷',
    russia: '🇷🇺',
    'russian federation': '🇷🇺',
    mexico: '🇲🇽',
    canada: '🇨🇦',
    ireland: '🇮🇪',
    australia: '🇦🇺',
    'new zealand': '🇳🇿',
    china: '🇨🇳',
    japan: '🇯🇵',
    'south korea': '🇰🇷',
    korea: '🇰🇷',
    england: '🇬🇧',
    'united kingdom': '🇬🇧',
    uk: '🇬🇧',
    'great britain': '🇬🇧',
    france: '🇫🇷',
    germany: '🇩🇪',
    spain: '🇪🇸',
    italy: '🇮🇹',
    poland: '🇵🇱',
    netherlands: '🇳🇱',
    sweden: '🇸🇪',
    norway: '🇳🇴',
    kazakhstan: '🇰🇿',
    kyrgyzstan: '🇰🇬',
    georgia: '🇬🇪',
    azerbaijan: '🇦🇿',
    nigeria: '🇳🇬',
    'south africa': '🇿🇦',
    cameroon: '🇨🇲',
    ecuador: '🇪🇨',
    peru: '🇵🇪',
    argentina: '🇦🇷',
    colombia: '🇨🇴',
    chile: '🇨🇱',
    philippines: '🇵🇭',
    thailand: '🇹🇭',
    indonesia: '🇮🇩',
    'czech republic': '🇨🇿',
    czechia: '🇨🇿',
    moldova: '🇲🇩',
    romania: '🇷🇴',
    suriname: '🇸🇷',
    cuba: '🇨🇺',
    'dominican republic': '🇩🇴',
    iceland: '🇮🇸',
    finland: '🇫🇮',
    denmark: '🇩🇰',
    austria: '🇦🇹',
    belgium: '🇧🇪',
    portugal: '🇵🇹',
    'saudi arabia': '🇸🇦',
    iran: '🇮🇷',
  };
  return map[c.toLowerCase().trim()] || '';
}

const flag = flagFor(country);
const init = initials(name);
const wcAbbr = divisionAbbrev(weightClass);
const recordLabel = wins != null && losses != null ? `${fmtInt(wins)}-${fmtInt(losses)}` : '';
---

<a class={`fp-card ${isChampion ? 'is-champ' : 'is-default'}`} href={profileUrl} target="_blank" rel="noopener" data-fighter-id={fighterId}>
  {isChampion && <span class="fp-card-crown" aria-label="Current champion">👑</span>}
  <div class="fp-card-top">
    <div class="fp-card-rating">
      <span class="fp-card-rating-num">{recordLabel || fmtInt(wins)}</span>
      {wcAbbr && <span class="fp-card-rating-pos">{wcAbbr}</span>}
    </div>
    {flag && <span class="fp-card-flag" title={country}>{flag}</span>}
  </div>
  <div class="fp-card-portrait" aria-hidden="true">
    <span class="fp-card-portrait-silhouette">👤</span>
    <span class="fp-card-initials">{init}</span>
  </div>
  <div class="fp-card-name">{name}</div>
  <div class="fp-card-stats">
    <div class="fp-card-stat"><span class="fp-card-stat-label">FIN</span><span class="fp-card-stat-val">{fmtPct(finishRate)}</span></div>
    <div class="fp-card-stat"><span class="fp-card-stat-label">SUB</span><span class="fp-card-stat-val">{fmtPct(subRate)}</span></div>
    <div class="fp-card-stat"><span class="fp-card-stat-label">W★</span><span class="fp-card-stat-val">{fmtInt(winStreak)}</span></div>
    <div class="fp-card-stat"><span class="fp-card-stat-label">L✗</span><span class="fp-card-stat-val">{fmtInt(lossStreak)}</span></div>
  </div>
</a>

<style>
  .fp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    aspect-ratio: 5 / 7;
    min-height: 240px;
    text-decoration: none;
    color: #fef2f2;
    border-radius: 0.85rem;
    padding: 0.55rem 0.55rem 0.65rem;
    overflow: hidden;
    transition: transform 120ms ease, box-shadow 120ms ease;
    isolation: isolate;
  }
  .fp-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: -1;
  }
  .fp-card.is-champ::before {
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(255, 215, 0, 0.45), transparent 65%),
      linear-gradient(160deg, #f7d046 0%, #b8860b 38%, #6b4e00 100%);
    box-shadow: inset 0 0 0 1.5px rgba(255, 235, 150, 0.55), 0 0 18px rgba(245, 158, 11, 0.32);
  }
  .fp-card.is-default::before {
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(160, 174, 192, 0.35), transparent 65%),
      linear-gradient(160deg, #2a2f38 0%, #161a20 70%, #0c0d10 100%);
    box-shadow: inset 0 0 0 1px rgba(220, 38, 38, 0.32), 0 0 12px rgba(220, 38, 38, 0.16);
  }
  .fp-card:hover {
    transform: translateY(-2px);
  }
  .fp-card.is-champ:hover {
    box-shadow: 0 0 22px rgba(245, 158, 11, 0.5);
  }
  .fp-card.is-default:hover {
    box-shadow: 0 0 18px rgba(220, 38, 38, 0.42);
  }

  .fp-card-crown {
    position: absolute;
    top: 0.4rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.92rem;
    line-height: 1;
    z-index: 2;
    text-shadow: 0 0 6px rgba(0, 0, 0, 0.55);
  }

  .fp-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.4rem;
  }
  .fp-card-rating {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    gap: 0.05rem;
  }
  .fp-card-rating-num {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: #fef2f2;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
  }
  .is-champ .fp-card-rating-num {
    color: #1f1300;
    text-shadow: 0 1px 0 rgba(255, 235, 150, 0.6);
  }
  .fp-card-rating-pos {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }
  .is-champ .fp-card-rating-pos {
    color: rgba(31, 19, 0, 0.8);
  }
  .fp-card-flag {
    font-size: 1.22rem;
    line-height: 1;
    background: rgba(0, 0, 0, 0.32);
    border-radius: 0.4rem;
    padding: 0.2rem 0.34rem;
  }

  .fp-card-portrait {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    margin: 0.25rem 0 0.35rem;
  }
  .fp-card-portrait-silhouette {
    font-size: 3.6rem;
    opacity: 0.18;
    line-height: 1;
    filter: blur(0.5px);
  }
  .is-champ .fp-card-portrait-silhouette {
    opacity: 0.22;
  }
  .fp-card-initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.7);
  }
  .is-champ .fp-card-initials {
    color: rgba(31, 19, 0, 0.92);
    text-shadow: 0 1px 2px rgba(255, 235, 150, 0.6);
  }

  .fp-card-name {
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-align: center;
    line-height: 1.15;
    margin-bottom: 0.4rem;
    word-break: break-word;
    overflow-wrap: break-word;
  }
  .is-champ .fp-card-name {
    color: #1f1300;
  }
  .is-default .fp-card-name {
    color: #fef2f2;
  }

  .fp-card-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.18rem 0.28rem;
    background: rgba(0, 0, 0, 0.32);
    border-radius: 0.55rem;
    padding: 0.32rem 0.4rem;
  }
  .is-champ .fp-card-stats {
    background: rgba(31, 19, 0, 0.28);
  }
  .fp-card-stat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.25rem;
    line-height: 1;
  }
  .fp-card-stat-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.72);
  }
  .is-champ .fp-card-stat-label {
    color: rgba(31, 19, 0, 0.72);
  }
  .fp-card-stat-val {
    font-size: 0.78rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.96);
  }
  .is-champ .fp-card-stat-val {
    color: rgba(31, 19, 0, 0.96);
  }
</style>
