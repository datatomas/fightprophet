---
interface Props {
  slot: string;
  format?: string;
  responsive?: boolean;
  className?: string;
}

const {
  slot,
  format = 'auto',
  responsive = true,
  className = '',
} = Astro.props as Props;

const enabled = import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const client = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? '';
const hasRealSlot = !!slot && slot !== '1234567890';
const shouldRender = enabled && client.startsWith('ca-pub-') && hasRealSlot;
---

{shouldRender && (
  <div class={`ad-slot ${className}`.trim()}>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={client}
      data-ad-slot={slot}
      data-ad-format={format}
      data-full-width-responsive={responsive ? 'true' : 'false'}
    ></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}

<style>
  .ad-slot {
    margin: 1rem 0;
    min-height: 90px;
  }
</style>
