---
import BaseLayout from '../layouts/BaseLayout.astro';
import { runtimeEnvFromLocals } from '../lib/country-master';
import { getAllModelsPredictionsData } from '../lib/dashboard-data';

const runtimeEnv = runtimeEnvFromLocals(Astro.locals);
const allModels = await getAllModelsPredictionsData(runtimeEnv);
const pageJson = JSON.stringify(allModels).replace(/</g, '\\u003c');

// Default to catboost for KPIs (matches Streamlit default)
const fights = allModels.catboost;
const totalFights = fights.length;
const eventCount = new Set(fights.map((f) => f.event_name)).size;
const strongSignals = fights.filter((f) => f.signal_strength === 'STRONG').length;
const recommendedBets = fights.filter((f) => f.recommended_bet).length;
const hasData = totalFights > 0;
---

<BaseLayout
  title="MMA Predictions — Upcoming UFC Fights | Fight Prophet"
  description="AI-powered MMA predictions for upcoming UFC fights — model probability vs market probability, confidence signals, and edge analysis for the next events."
>
  <article class="fp-pred-page">

    <!-- ── HERO ── -->
    <header class="fp-tool-hero">
      <a class="fp-tool-breadcrumb" href="/">← Fight Prophet</a>
      <p class="fp-section-label">Upcoming Predictions</p>
      <h1>MMA Predictions</h1>
      <p class="fp-hero-copy">
        Fight Prophet uses machine learning trained on previous UFC fights to estimate how matchups may play out.
        Start with <strong>CatBoost</strong> for the clearest default view, then compare with the other models if you want a second opinion.
      </p>
    </header>

    {hasData ? (
      <>
        <!-- ── KPI STRIP ── -->
        <div class="kpi-strip" data-kpi-strip>
          <div class="kpi-strip-item">
            <div class="kpi-strip-icon">
              <img src="/branding/b91c1c-fights-emoji.png" alt="Fights" width="46" height="46" />
            </div>
            <div class="kpi-strip-label">Total Fights</div>
            <div class="kpi-strip-value" data-kpi-fights>{totalFights.toLocaleString()}</div>
          </div>
          <div class="kpi-strip-item">
            <div class="kpi-strip-icon">
              <img src="/branding/b91c1c-predictions-emoji.png" alt="Events" width="46" height="46" />
            </div>
            <div class="kpi-strip-label">Events</div>
            <div class="kpi-strip-value" data-kpi-events>{eventCount.toLocaleString()}</div>
          </div>
          <div class="kpi-strip-item">
            <div class="kpi-strip-icon">
              <img src="/branding/b91c1c-signals-emoji.png" alt="Strong signals" width="46" height="46" />
            </div>
            <div class="kpi-strip-label">Strong Signals</div>
            <div class="kpi-strip-value" data-kpi-strong>{strongSignals.toLocaleString()}</div>
          </div>
          <div class="kpi-strip-item">
            <div class="kpi-strip-icon">
              <img src="/branding/b91c1c-bets-emoji.png" alt="Recommended bets" width="46" height="46" />
            </div>
            <div class="kpi-strip-label">Recommended Bets</div>
            <div class="kpi-strip-value" data-kpi-recs>{recommendedBets.toLocaleString()}</div>
          </div>
        </div>

        <!-- ── MODEL GUIDE ── -->
        <div class="fp-model-guide">
          <div class="fp-model-guide-eyebrow">Available model views</div>
          <div class="fp-model-guide-title">Welcome to Fight Prophet predictions</div>
          <div class="fp-model-guide-copy">
            Fight Prophet uses machine learning trained on previous UFC fights to estimate how matchups may play out.
            Start with CatBoost for the clearest default view, then compare it with the other models if you want a second opinion.
          </div>
          <div class="fp-model-guide-grid">
            <div class="fp-model-guide-item">
              <div class="fp-model-guide-item-label">CatBoost</div>
              <div class="fp-model-guide-item-copy">Gradient boosting optimised for structured / tabular MMA features.</div>
            </div>
            <div class="fp-model-guide-item">
              <div class="fp-model-guide-item-label">Ensemble</div>
              <div class="fp-model-guide-item-copy">Combines multiple learners to reduce single-model bias.</div>
            </div>
            <div class="fp-model-guide-item">
              <div class="fp-model-guide-item-label">LogReg</div>
              <div class="fp-model-guide-item-copy">Interpretable baseline that stabilises directional probability checks.</div>
            </div>
          </div>
          <div class="fp-model-guide-reco">⭐ Best starting point: CatBoost</div>
        </div>

        <!-- ── CONTROLS ── -->
        <section class="fp-tool-controls" aria-label="Prediction filters">
          <!-- model picker -->
          <div class="fp-model-picker" role="group" aria-label="Select model">
            <button type="button" class="fp-model-btn is-active" data-model="catboost">CatBoost</button>
            <button type="button" class="fp-model-btn" data-model="ensemble">Ensemble</button>
            <button type="button" class="fp-model-btn" data-model="logreg">LogReg</button>
          </div>
          <label>
            <span>Event</span>
            <select data-pred-event>
              <option value="__all__">All events</option>
            </select>
          </label>
          <label>
            <span>Signal</span>
            <select data-pred-signal>
              <option value="All">All signals</option>
              <option value="STRONG">Strong</option>
              <option value="MEDIUM">Medium</option>
              <option value="WEAK">Weak</option>
            </select>
          </label>
        </section>

        <!-- ── FIGHT CARDS ── -->
        <div class="fp-predictions-feed" data-predictions-feed aria-live="polite"></div>
      </>
    ) : (
      <section class="fp-empty-state">
        <strong>Predictions are temporarily unavailable.</strong>
        <span>The upcoming cards feed reads from the exported dashboard parquet. Check back once the next event card export has landed.</span>
      </section>
    )}
  </article>

  <script type="application/json" id="fp-all-models-data" set:html={pageJson}></script>
</BaseLayout>

<script is:inline>
  (() => {
    const dataNode = document.getElementById('fp-all-models-data');
    if (!dataNode) return;
    const allModels = JSON.parse(dataNode.textContent || '{}');
    if (!allModels.catboost) return;

    const feed = document.querySelector('[data-predictions-feed]');
    const eventSel = document.querySelector('[data-pred-event]');
    const signalSel = document.querySelector('[data-pred-signal]');
    const modelBtns = document.querySelectorAll('[data-model]');
    const kpiFights = document.querySelector('[data-kpi-fights]');
    const kpiEvents = document.querySelector('[data-kpi-events]');
    const kpiStrong = document.querySelector('[data-kpi-strong]');
    const kpiRecs = document.querySelector('[data-kpi-recs]');

    let currentModel = 'catboost';

    // ── Helpers ──────────────────────────────────────────────────────────────
    const esc = (v) =>
      String(v ?? '').replace(/[&<>"']/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));

    const fmtPct = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      const pct = Number(v) <= 1 ? Number(v) * 100 : Number(v);
      return `${Math.round(pct)}%`;
    };

    const fmtInt = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      return String(Math.trunc(Number(v)));
    };

    const fmtProb = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      const num = Number(v);
      return `${Math.round((num <= 1 ? num * 100 : num) * 10) / 10}%`;
    };

    const fmtEdge = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      const num = Number(v);
      const shown = Math.round((num <= 1 && num >= -1 ? num * 100 : num) * 10) / 10;
      return `${shown > 0 ? '+' : ''}${shown}%`;
    };

    const fmtOdds = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      const num = Number(v);
      return num > 0 ? `+${Math.round(num)}` : String(Math.round(num));
    };

    const wcAbbr = (wc) => {
      const map = {
        flyweight: 'FLW', bantamweight: 'BW', featherweight: 'FW', lightweight: 'LW',
        welterweight: 'WW', middleweight: 'MW', 'light heavyweight': 'LHW', heavyweight: 'HW',
        strawweight: 'SW', "women's strawweight": 'WSW', "women's flyweight": 'WFLW',
        "women's bantamweight": 'WBW', "women's featherweight": 'WFW',
      };
      if (!wc) return '';
      return map[wc.toLowerCase().trim()] || wc.split(/\s+/).map((p) => p[0]).join('').toUpperCase().slice(0, 4);
    };

    const initials = (name) =>
      String(name || '').split(/\s+/).map((p) => p[0]).filter(Boolean).slice(0, 2).join('').toUpperCase();

    const signalIcon = (sig) => {
      const s = String(sig || '').toUpperCase();
      if (s === 'STRONG') return `<img src="/branding/b91c1c-signals-emoji.png" alt="Strong" width="16" height="16" class="fp-inline-icon" />`;
      if (s === 'MEDIUM') return `<img src="/branding/b91c1c-signals-mid-emoji.png" alt="Medium" width="16" height="16" class="fp-inline-icon" />`;
      return `<img src="/branding/b91c1c-signals-low-emoji.png" alt="Weak" width="18" height="18" class="fp-inline-icon" />`;
    };

    // ── Fighter card HTML (mirrors Streamlit _build_fighter_card_html) ────────
    function buildCardHtml(name, country, flag, wc, isChamp, status, wins, losses, finRate, subRate, wStreak, lStreak) {
      const init = initials(name);
      const abbr = wcAbbr(wc);
      const wTxt = fmtInt(wins);
      const lTxt = fmtInt(losses);
      const record = wTxt !== '—' && lTxt !== '—' ? `${wTxt}-${lTxt}` : (wTxt !== '—' ? wTxt : '—');
      const typeLine = esc([wc || 'MMA Fighter', country].filter(Boolean).join(' / '));
      const cardCls = isChamp ? 'fp-card is-champ is-compact' : 'fp-card is-default is-compact';
      const profileHref = `/fighter-card/?fighter=${encodeURIComponent(name || '')}`;
      const statusLower = String(status || '').toLowerCase();
      const statusHtml = statusLower
        ? `<span class="fp-card-status fp-card-status--${esc(statusLower)}">${esc(statusLower)}</span>`
        : '';
      const flagHtml = flag ? `<span class="fp-card-flag" title="${esc(country)}">${esc(flag)}</span>` : '';
      const topRightHtml = (statusHtml || flagHtml)
        ? `<div class="fp-card-top-right">${statusHtml}${flagHtml}</div>`
        : '';
      const crownHtml = isChamp ? `<span class="fp-card-crown" aria-label="Champion">👑</span>` : '';
      const ratingPos = abbr ? `<span class="fp-card-rating-pos">${esc(abbr)}</span>` : '';

      return `<a class="${cardCls}" href="${esc(profileHref)}">
        <div class="fp-card-frame"></div>
        <div class="fp-card-top">
          <div class="fp-card-rating">
            <span class="fp-card-rating-num">${esc(record)}</span>
            ${ratingPos}
          </div>
          ${topRightHtml}
        </div>
        <header class="fp-card-banner"><span class="fp-card-name">${esc(name || '')}</span></header>
        <div class="fp-card-portrait">
          <span class="fp-card-portrait-silhouette" aria-hidden="true">👤</span>
          <span class="fp-card-initials" aria-hidden="true">${esc(init)}</span>
          ${crownHtml}
        </div>
        <div class="fp-card-type-bar">[ ${typeLine} ]</div>
        <div class="fp-card-desc">
          <div class="fp-card-stat-row">
            <span class="fp-card-stat"><em>FIN</em><b>${esc(fmtPct(finRate))}</b></span>
            <span class="fp-card-stat"><em>SUB</em><b>${esc(fmtPct(subRate))}</b></span>
            <span class="fp-card-stat"><em>W★</em><b>${esc(fmtInt(wStreak))}</b></span>
            <span class="fp-card-stat"><em>L✗</em><b>${esc(fmtInt(lStreak))}</b></span>
          </div>
          <div class="fp-card-atkdef">
            <span class="fp-card-atk">ATK/${esc(wTxt)}</span>
            <span class="fp-card-sep">·</span>
            <span class="fp-card-def">DEF/${esc(lTxt)}</span>
          </div>
        </div>
        <span class="fp-card-country-fallback" aria-hidden="true"></span>
      </a>`;
    }

    // ── Matchup shell (mirrors _render_fight_card) ────────────────────────────
    function buildMatchupHtml(fight) {
      const signal = String(fight.signal_strength || '');
      const signalKey = signal.toLowerCase();
      const signalCls = { strong: 'fp-matchup-signal--strong', medium: 'fp-matchup-signal--medium', weak: 'fp-matchup-signal--weak' }[signalKey] || 'fp-matchup-signal--neutral';
      const signalLabel = signal.toUpperCase() || 'SIGNAL';

      const fName = fight.fighter_name_display || '';
      const oName = fight.opponent_name_display || '';
      const modelProb = fight.model_prob;
      const fighterProb = modelProb;
      const opponentProb = modelProb != null ? 1 - modelProb : null;
      const likelyWinner = modelProb != null && modelProb < 0.5 ? oName : fName;
      const likelyProb = modelProb != null ? (modelProb < 0.5 ? 1 - modelProb : modelProb) : null;
      const betOnFighter = fight.bet_on_name === fName;
      const marketBetSide = fight.market_prob != null ? (betOnFighter ? fight.market_prob : 1 - fight.market_prob) : null;
      const fProbW = Math.max(0, Math.min((fighterProb || 0) * 100, 100));
      const oProbW = Math.max(0, Math.min((opponentProb || 0) * 100, 100));
      const matchupLabel = fight.weight_class || 'Fight Matchup';

      const isUnderdog = marketBetSide != null && marketBetSide < 0.5;
      const valueLabel = isUnderdog ? 'Underdog value angle' : 'Best value bet';
      const recChip = fight.recommended_bet
        ? ` <span class="fp-rec-chip"><img src="/branding/b91c1c-bets-emoji.png" alt="" width="14" height="14" class="fp-inline-icon" /> Recommended</span>`
        : '';

      const fCard = buildCardHtml(fName, fight.fighter_country, fight.fighter_flag, fight.weight_class, fight.fighter_is_champion, fight.fighter_status, fight.fighter_wins, fight.fighter_losses, fight.fighter_finish_rate, fight.fighter_sub_rate, fight.fighter_win_streak, fight.fighter_loss_streak);
      const oCard = buildCardHtml(oName, fight.opponent_country, fight.opponent_flag, fight.weight_class, fight.opponent_is_champion, fight.opponent_status, fight.opponent_wins, fight.opponent_losses, fight.opponent_finish_rate, fight.opponent_sub_rate, fight.opponent_win_streak, fight.opponent_loss_streak);

      const pickSummary = likelyWinner
        ? `<div class="fp-pick-summary">
            <div class="fp-pick-winner">
              <strong>MODEL PREDICTION TO WIN:</strong>
              ${esc(likelyWinner)}
              <span class="fp-pick-confidence">(${fmtProb(likelyProb)})</span>
            </div>
            ${fight.bet_on_name ? `
              <div class="fp-pick-value">
                ${signalIcon(signal)} <b>${esc(valueLabel)}:</b> ${esc(fight.bet_on_name)}
                &nbsp;|&nbsp; Edge: <code>${esc(fmtEdge(fight.edge))}</code>
                &nbsp;|&nbsp; Market: <code>${esc(fmtProb(marketBetSide))}</code>
                &nbsp;|&nbsp; Signal: <b>${esc(signalLabel)}</b>${recChip}
              </div>` : ''}
            <div class="fp-pick-note">Model probabilities reflect historical patterns — check the disclaimer before acting on any output.</div>
          </div>`
        : '';

      return `<section class="fp-matchup-shell">
        <div class="fp-matchup-head">
          <div class="fp-matchup-head-copy">
            <div class="fp-matchup-eyebrow">${esc(matchupLabel)}</div>
          </div>
          <div class="fp-matchup-signal ${esc(signalCls)}">${signalIcon(signal)} ${esc(signalLabel)}</div>
        </div>
        <div class="fp-matchup-grid">
          <div class="fp-fighter-pane">
            ${fCard}
            <div class="fp-odds-chip">
              <span class="fp-odds-chip-label">Odds</span>${esc(fmtOdds(fight.fighter_odds))}
            </div>
          </div>
          <div class="fp-versus-core">
            <div class="fp-versus-mark">⚔️</div>
            <div class="fp-versus-title">Model probabilities</div>
            <div class="fp-prob-stack">
              <div class="fp-prob-row">
                <div class="fp-prob-meta">
                  <span class="fp-prob-name">${esc(fName)}</span>
                  <span class="fp-prob-value">${esc(fmtProb(fighterProb))}</span>
                </div>
                <div class="fp-prob-track"><div class="fp-prob-fill" style="width:${fProbW.toFixed(1)}%;"></div></div>
              </div>
              <div class="fp-prob-row">
                <div class="fp-prob-meta">
                  <span class="fp-prob-name">${esc(oName)}</span>
                  <span class="fp-prob-value">${esc(fmtProb(opponentProb))}</span>
                </div>
                <div class="fp-prob-track"><div class="fp-prob-fill fp-prob-fill--alt" style="width:${oProbW.toFixed(1)}%;"></div></div>
              </div>
            </div>
          </div>
          <div class="fp-fighter-pane">
            ${oCard}
            <div class="fp-odds-chip">
              <span class="fp-odds-chip-label">Odds</span>${esc(fmtOdds(fight.opponent_odds))}
            </div>
          </div>
        </div>
        ${pickSummary}
      </section>`;
    }

    // ── Populate event dropdown from current model data ───────────────────────
    function refreshEventDropdown(fights) {
      const current = eventSel?.value || '__all__';
      const names = [...new Set(fights.map((f) => f.event_name).filter(Boolean))];
      if (eventSel) {
        eventSel.innerHTML = '<option value="__all__">All events</option>';
        for (const name of names) {
          const opt = document.createElement('option');
          opt.value = name;
          opt.textContent = name;
          if (name === current) opt.selected = true;
          eventSel.append(opt);
        }
      }
    }

    // ── Update KPI strip ──────────────────────────────────────────────────────
    function updateKpis(fights) {
      const total = fights.length;
      const evs = new Set(fights.map((f) => f.event_name)).size;
      const strong = fights.filter((f) => f.signal_strength === 'STRONG').length;
      const recs = fights.filter((f) => f.recommended_bet).length;
      if (kpiFights) kpiFights.textContent = total.toLocaleString();
      if (kpiEvents) kpiEvents.textContent = evs.toLocaleString();
      if (kpiStrong) kpiStrong.textContent = strong.toLocaleString();
      if (kpiRecs) kpiRecs.textContent = recs.toLocaleString();
    }

    // ── Filtered fights for current state ────────────────────────────────────
    function filteredFights() {
      const fights = Array.isArray(allModels[currentModel]) ? allModels[currentModel] : [];
      const ev = String(eventSel?.value || '__all__');
      const sig = String(signalSel?.value || 'All');
      return fights.filter((f) =>
        (ev === '__all__' || f.event_name === ev) &&
        (sig === 'All' || f.signal_strength === sig),
      );
    }

    // ── Render fight feed ─────────────────────────────────────────────────────
    function render() {
      const rows = filteredFights();
      if (!rows.length) {
        feed.innerHTML = '<p class="fp-list-empty">No fights match the current filters.</p>';
        return;
      }
      const byEvent = new Map();
      for (const f of rows) {
        if (!byEvent.has(f.event_name)) byEvent.set(f.event_name, []);
        byEvent.get(f.event_name).push(f);
      }
      let html = '';
      for (const [evName, evFights] of byEvent.entries()) {
        const first = evFights[0];
        const meta = [first.event_date, first.location].filter(Boolean).join(' · ');
        html += `<div class="fp-event-group">
          <header class="fp-event-group-head">
            <h2>${esc(evName)}</h2>
            ${meta ? `<p>${esc(meta)}</p>` : ''}
          </header>
          ${evFights.map(buildMatchupHtml).join('')}
        </div>`;
      }
      feed.innerHTML = html;
    }

    // ── Model picker ──────────────────────────────────────────────────────────
    modelBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        currentModel = btn.getAttribute('data-model') || 'catboost';
        modelBtns.forEach((b) => b.classList.toggle('is-active', b === btn));
        const allFights = Array.isArray(allModels[currentModel]) ? allModels[currentModel] : [];
        refreshEventDropdown(allFights);
        updateKpis(allFights);
        render();
      });
    });

    eventSel?.addEventListener('change', render);
    signalSel?.addEventListener('change', render);

    // Initial render
    const initialFights = Array.isArray(allModels.catboost) ? allModels.catboost : [];
    refreshEventDropdown(initialFights);
    render();
  })();
</script>

<!-- ── Global card CSS (exact port of Streamlit _FIGHTER_CARD_CSS) ── -->
<style is:global>
  .fp-card{position:relative;display:flex;flex-direction:column;width:100%;max-width:252px;margin-inline:auto;aspect-ratio:59/86;min-height:188px;border-radius:0.5rem;padding:0.34rem 0.36rem 0.36rem;overflow:hidden;isolation:isolate;color:#fef2f2;font-family:Inter,system-ui,sans-serif;text-decoration:none;transition:transform 180ms cubic-bezier(0.2,0.7,0.3,1),box-shadow 180ms ease,filter 180ms ease;will-change:transform;}
  .fp-card::before{content:'';position:absolute;inset:0;border-radius:inherit;z-index:-1;}
  /* Sheen overlay swept on hover */
  .fp-card::after{content:'';position:absolute;top:-40%;left:-30%;width:60%;height:180%;background:linear-gradient(115deg,transparent 35%,rgba(255,255,255,0.14) 50%,transparent 65%);transform:translateX(-180%) rotate(8deg);transition:transform 700ms cubic-bezier(0.2,0.7,0.3,1);pointer-events:none;z-index:5;mix-blend-mode:overlay;}
  .fp-card:hover::after{transform:translateX(280%) rotate(8deg);}
  .fp-card-frame{position:absolute;inset:0.18rem;border-radius:0.34rem;z-index:0;pointer-events:none;}
  .fp-card.is-default{box-shadow:0 6px 16px rgba(0,0,0,0.42),0 0 0 1px rgba(127,29,29,0.4);}
  .fp-card.is-default::before{background:linear-gradient(160deg,#ef4444 0%,#b91c1c 35%,#7f1d1d 70%,#2a0808 100%);}
  .fp-card.is-default .fp-card-frame{background:radial-gradient(110% 80% at 50% 0%,rgba(220,38,38,0.22),transparent 70%),linear-gradient(180deg,#1a0c0c 0%,#100808 100%);border:1px solid rgba(185,28,28,0.78);box-shadow:inset 0 0 0 1px rgba(0,0,0,0.6),inset 0 0 22px rgba(0,0,0,0.55),inset 0 0 60px rgba(220,38,38,0.08);}
  .fp-card.is-champ{box-shadow:0 6px 18px rgba(0,0,0,0.42),0 0 0 1px rgba(180,120,30,0.55),0 0 24px rgba(255,200,80,0.12);animation:fp-champ-pulse 4.5s ease-in-out infinite;}
  .fp-card.is-champ::before{background:linear-gradient(160deg,#ffe27a 0%,#d09312 30%,#6c4404 60%,#2a1908 100%);}
  .fp-card.is-champ .fp-card-frame{background:radial-gradient(110% 80% at 50% 0%,rgba(255,240,170,0.32),transparent 70%),linear-gradient(180deg,#4a311a 0%,#1c1207 100%);border:1px solid rgba(255,240,170,0.82);box-shadow:inset 0 0 0 1px rgba(0,0,0,0.5),inset 0 0 28px rgba(255,220,140,0.22);}
  .fp-card:hover{transform:translateY(-4px) scale(1.025);}
  .fp-card.is-default:hover{box-shadow:0 14px 28px rgba(0,0,0,0.55),0 0 26px rgba(255,180,80,0.42),0 0 0 1px rgba(248,113,113,0.55);}
  .fp-card.is-champ:hover{box-shadow:0 14px 30px rgba(0,0,0,0.55),0 0 32px rgba(255,220,130,0.75),0 0 0 1px rgba(255,240,170,0.7);}

  @keyframes fp-champ-pulse{
