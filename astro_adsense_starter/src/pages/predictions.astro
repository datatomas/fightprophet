---
import BaseLayout from '../layouts/BaseLayout.astro';
import { runtimeEnvFromLocals } from '../lib/country-master';
import { getUpcomingPredictionsData } from '../lib/dashboard-data';

const runtimeEnv = runtimeEnvFromLocals(Astro.locals);
const predictionsData = await getUpcomingPredictionsData(runtimeEnv);
const pageJson = JSON.stringify(predictionsData).replace(/</g, '\\u003c');

const fights = predictionsData.fights;
const totalFights = fights.length;
const eventCount = new Set(fights.map((f) => f.event_name)).size;
const strongSignals = fights.filter((f) => f.signal_strength === 'STRONG').length;
const recommendedBets = fights.filter((f) => f.recommended_bet).length;
---

<BaseLayout
  title="MMA Predictions — Upcoming UFC Fights | Fight Prophet"
  description="AI-powered MMA predictions for upcoming UFC fights — model probability vs market probability, confidence signals, and edge analysis for the next events."
>
  <article class="fp-predictions-page">
    <header class="fp-tool-hero">
      <a class="fp-tool-breadcrumb" href="/">← Fight Prophet</a>
      <p class="fp-section-label">Predictions</p>
      <h1>MMA Predictions</h1>
      <p>
        AI-generated predictions for upcoming MMA bouts. Model probability vs market line, confidence signals, and per-fight edge — all from the same pipeline that powers the analytics dashboard.
      </p>
      {totalFights > 0 && (
        <div class="fp-kpi-strip" aria-label="Upcoming card summary">
          <span><strong>{totalFights.toLocaleString()}</strong> upcoming fights</span>
          <span><strong>{eventCount.toLocaleString()}</strong> {eventCount === 1 ? 'event' : 'events'}</span>
          <span><strong>{strongSignals.toLocaleString()}</strong> strong signals</span>
          <span><strong>{recommendedBets.toLocaleString()}</strong> recommended bets</span>
        </div>
      )}
    </header>

    {totalFights > 0 ? (
      <>
        <section class="fp-tool-controls" aria-label="Prediction filters">
          <label>
            <span>Event</span>
            <select data-pred-event>
              <option value="__all__">All events</option>
            </select>
          </label>
          <label>
            <span>Signal</span>
            <select data-pred-signal>
              <option value="All">All signals</option>
              <option value="STRONG">Strong</option>
              <option value="MEDIUM">Medium</option>
              <option value="WEAK">Weak</option>
            </select>
          </label>
        </section>

        <div class="fp-predictions-feed" data-predictions-feed aria-live="polite"></div>
      </>
    ) : (
      <section class="fp-empty-state">
        <strong>Predictions are temporarily unavailable.</strong>
        <span>The upcoming cards feed reads from the exported dashboard parquet. Check back once the next event card export has landed.</span>
      </section>
    )}
  </article>

  <script type="application/json" id="fp-predictions-data" set:html={pageJson}></script>
</BaseLayout>

<script is:inline>
  (() => {
    const dataNode = document.getElementById('fp-predictions-data');
    if (!dataNode) return;
    const payload = JSON.parse(dataNode.textContent || '{"fights":[]}');
    const fights = Array.isArray(payload.fights) ? payload.fights : [];
    if (!fights.length) return;

    const eventSel = document.querySelector('[data-pred-event]');
    const signalSel = document.querySelector('[data-pred-signal]');
    const feed = document.querySelector('[data-predictions-feed]');

    // Populate event options
    const eventNames = [...new Set(fights.map((f) => f.event_name).filter(Boolean))];
    for (const name of eventNames) {
      const opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name;
      eventSel?.append(opt);
    }

    const esc = (v) =>
      String(v ?? '').replace(/[&<>"']/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));

    const fmtPct = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      const pct = Number(v) <= 1 ? Number(v) * 100 : Number(v);
      return `${Math.round(pct)}%`;
    };

    const fmtInt = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      return String(Math.trunc(Number(v)));
    };

    const fmtProb = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      const num = Number(v);
      return `${Math.round((num <= 1 ? num * 100 : num) * 10) / 10}%`;
    };

    const fmtEdge = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      const num = Number(v);
      const shown = Math.round((num <= 1 && num >= -1 ? num * 100 : num) * 10) / 10;
      return `${shown > 0 ? '+' : ''}${shown}%`;
    };

    const fmtOdds = (v) => {
      if (v == null || Number.isNaN(Number(v))) return '—';
      const num = Number(v);
      return num > 0 ? `+${Math.round(num)}` : String(Math.round(num));
    };

    const wcAbbr = (wc) => {
      const map = {
        flyweight: 'FLW', bantamweight: 'BW', featherweight: 'FW', lightweight: 'LW',
        welterweight: 'WW', middleweight: 'MW', 'light heavyweight': 'LHW', heavyweight: 'HW',
        strawweight: 'SW', "women's strawweight": 'WSW', "women's flyweight": 'WFLW',
        "women's bantamweight": 'WBW', "women's featherweight": 'WFW',
      };
      if (!wc) return '';
      const key = wc.toLowerCase().trim();
      return map[key] || wc.split(/\s+/).map((p) => p[0]).join('').toUpperCase().slice(0, 4);
    };

    const initials = (name) =>
      String(name || '').split(/\s+/).map((p) => p[0]).filter(Boolean).slice(0, 2).join('').toUpperCase();

    function buildCardHtml(name, country, flag, wc, isChamp, wins, losses, finRate, subRate, wStreak, lStreak) {
      const init = initials(name);
      const abbr = wcAbbr(wc);
      const record = wins != null && losses != null ? `${fmtInt(wins)}-${fmtInt(losses)}` : '';
      const typeLine = esc([wc || 'MMA Fighter', country].filter(Boolean).join(' / '));
      const cardCls = isChamp ? 'fp-card is-champ is-compact' : 'fp-card is-default is-compact';
      const profileHref = `/fighter-card/?fighter=${encodeURIComponent(name || '')}`;
      const ratingInner = isChamp
        ? `<span class="fp-card-rating-num">C</span>${abbr ? `<span class="fp-card-rating-pos">${esc(abbr)}</span>` : ''}`
        : `<span class="fp-card-rating-num">${esc(record || fmtInt(wins))}</span>${abbr ? `<span class="fp-card-rating-pos">${esc(abbr)}</span>` : ''}`;
      return `<a class="${cardCls}" href="${esc(profileHref)}">
        <div class="fp-card-frame"></div>
        <div class="fp-card-top">
          <div class="fp-card-rating">${ratingInner}</div>
          ${flag ? `<span class="fp-card-flag" title="${esc(country)}">${esc(flag)}</span>` : ''}
        </div>
        <header class="fp-card-banner"><span class="fp-card-name">${esc(name || '')}</span></header>
        <div class="fp-card-portrait">
          <span class="fp-card-portrait-silhouette" aria-hidden="true">👤</span>
          <span class="fp-card-initials" aria-hidden="true">${esc(init)}</span>
          ${isChamp ? '<span class="fp-card-crown" aria-label="Champion">👑</span>' : ''}
        </div>
        <div class="fp-card-type-bar">[ ${typeLine} ]</div>
        <div class="fp-card-desc">
          <div class="fp-card-stat-row">
            <span class="fp-card-stat"><em>FIN</em><b>${esc(fmtPct(finRate))}</b></span>
            <span class="fp-card-stat"><em>SUB</em><b>${esc(fmtPct(subRate))}</b></span>
            <span class="fp-card-stat"><em>W★</em><b>${esc(fmtInt(wStreak))}</b></span>
            <span class="fp-card-stat"><em>L✗</em><b>${esc(fmtInt(lStreak))}</b></span>
          </div>
          <div class="fp-card-atkdef">
            <span class="fp-card-atk">FIN/${esc(fmtPct(finRate))}</span>
            <span class="fp-card-sep">·</span>
            <span class="fp-card-def">REC/${esc(record || '—')}</span>
          </div>
        </div>
      </a>`;
    }

    function buildMatchupHtml(fight) {
      const signal = String(fight.signal_strength || '');
      const signalKey = signal.toLowerCase();
      const signalCls = { strong: 'fp-matchup-signal--strong', medium: 'fp-matchup-signal--medium', weak: 'fp-matchup-signal--weak' }[signalKey] || 'fp-matchup-signal--neutral';
      const signalLabel = signal.toUpperCase() || 'SIGNAL';

      const fName = fight.fighter_name_display || '';
      const oName = fight.opponent_name_display || '';
      const modelProb = fight.model_prob;
      const fighterProb = modelProb;
      const opponentProb = modelProb != null ? 1 - modelProb : null;
      const likelyWinner = modelProb != null && modelProb < 0.5 ? oName : fName;
      const likelyProb = modelProb != null ? (modelProb < 0.5 ? 1 - modelProb : modelProb) : null;
      const betOnFighter = fight.bet_on_name === fName;
      const marketBetSide = fight.market_prob != null ? (betOnFighter ? fight.market_prob : 1 - fight.market_prob) : null;
      const fProbW = Math.max(0, Math.min((fighterProb || 0) * 100, 100));
      const oProbW = Math.max(0, Math.min((opponentProb || 0) * 100, 100));
      const matchupLabel = fight.weight_class || 'Fight Matchup';

      const isUnderdog = marketBetSide != null && marketBetSide < 0.5;
      const valueLabel = isUnderdog ? 'Underdog value angle' : 'Best value bet';
      const recChip = fight.recommended_bet ? ' <span class="fp-rec-chip">✅ Recommended</span>' : '';

      const fCard = buildCardHtml(fName, fight.fighter_country, fight.fighter_flag, fight.weight_class, fight.fighter_is_champion, fight.fighter_wins, fight.fighter_losses, fight.fighter_finish_rate, fight.fighter_sub_rate, fight.fighter_win_streak, fight.fighter_loss_streak);
      const oCard = buildCardHtml(oName, fight.opponent_country, fight.opponent_flag, fight.weight_class, fight.opponent_is_champion, fight.opponent_wins, fight.opponent_losses, fight.opponent_finish_rate, fight.opponent_sub_rate, fight.opponent_win_streak, fight.opponent_loss_streak);

      const pickSummary = likelyWinner
        ? `<div class="fp-pick-summary">
            <div class="fp-pick-winner"><strong>MODEL PREDICTION TO WIN:</strong> ${esc(likelyWinner)} <span class="fp-pick-confidence">(${fmtProb(likelyProb)})</span></div>
            ${fight.bet_on_name ? `<div class="fp-pick-value">⚡ <b>${esc(valueLabel)}:</b> ${esc(fight.bet_on_name)} &nbsp;|&nbsp; Edge: <code>${esc(fmtEdge(fight.edge))}</code> &nbsp;|&nbsp; Market: <code>${esc(fmtProb(marketBetSide))}</code> &nbsp;|&nbsp; Signal: <b>${esc(signalLabel)}</b>${recChip}</div>` : ''}
            <div class="fp-pick-note">Model probabilities reflect historical patterns — check the disclaimer for full context.</div>
          </div>`
        : '';

      return `<section class="fp-matchup-shell">
        <div class="fp-matchup-head">
          <div class="fp-matchup-head-copy">
            <div class="fp-matchup-eyebrow">${esc(matchupLabel)}</div>
          </div>
          <div class="fp-matchup-signal ${esc(signalCls)}">⚡ ${esc(signalLabel)}</div>
        </div>
        <div class="fp-matchup-grid">
          <div class="fp-fighter-pane">
            ${fCard}
            <div class="fp-odds-chip"><span class="fp-odds-chip-label">Odds</span>${esc(fmtOdds(fight.fighter_odds))}</div>
          </div>
          <div class="fp-versus-core">
            <div class="fp-versus-mark">⚔️</div>
            <div class="fp-versus-title">MODEL PROBS</div>
            <div class="fp-prob-stack">
              <div class="fp-prob-row">
                <div class="fp-prob-meta">
                  <span class="fp-prob-name">${esc(fName)}</span>
                  <span class="fp-prob-value">${esc(fmtProb(fighterProb))}</span>
                </div>
                <div class="fp-prob-track"><div class="fp-prob-fill" style="width:${fProbW.toFixed(1)}%;"></div></div>
              </div>
              <div class="fp-prob-row">
                <div class="fp-prob-meta">
                  <span class="fp-prob-name">${esc(oName)}</span>
                  <span class="fp-prob-value">${esc(fmtProb(opponentProb))}</span>
                </div>
                <div class="fp-prob-track"><div class="fp-prob-fill fp-prob-fill--alt" style="width:${oProbW.toFixed(1)}%;"></div></div>
              </div>
            </div>
          </div>
          <div class="fp-fighter-pane">
            ${oCard}
            <div class="fp-odds-chip"><span class="fp-odds-chip-label">Odds</span>${esc(fmtOdds(fight.opponent_odds))}</div>
          </div>
        </div>
        ${pickSummary}
      </section>`;
    }

    function filteredFights() {
      const ev = String(eventSel?.value || '__all__');
      const sig = String(signalSel?.value || 'All');
      return fights.filter((f) =>
        (ev === '__all__' || f.event_name === ev) &&
        (sig === 'All' || f.signal_strength === sig),
      );
    }

    function render() {
      const rows = filteredFights();
      if (!rows.length) {
        feed.innerHTML = '<p class="fp-list-empty">No fights match the current filters.</p>';
        return;
      }

      const byEvent = new Map();
      for (const f of rows) {
        if (!byEvent.has(f.event_name)) byEvent.set(f.event_name, []);
        byEvent.get(f.event_name).push(f);
      }

      let html = '';
      for (const [evName, evFights] of byEvent.entries()) {
        const first = evFights[0];
        const meta = [first.event_date, first.location].filter(Boolean).join(' · ');
        html += `<div class="fp-event-group">
          <header class="fp-event-group-head">
            <h2>${esc(evName)}</h2>
            ${meta ? `<p>${esc(meta)}</p>` : ''}
          </header>
          ${evFights.map(buildMatchupHtml).join('')}
        </div>`;
      }
      feed.innerHTML = html;
    }

    eventSel?.addEventListener('change', render);
    signalSel?.addEventListener('change', render);
    render();
  })();
</script>

<style is:global>
  /* === Fighter card (Yu-Gi-Oh style) — mirrors FighterCard.astro for dynamic renders === */
  .fp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-inline: auto;
    aspect-ratio: 59 / 86;
    min-height: 188px;
    text-decoration: none;
    color: #fef2f2;
    border-radius: 0.42rem;
    padding: 0.34rem 0.36rem 0.36rem;
    overflow: hidden;
    transition: transform 120ms ease, box-shadow 120ms ease;
    isolation: isolate;
  }
  .fp-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: -1;
  }
  .fp-card-frame {
    position: absolute;
    inset: 0.18rem;
    border-radius: 0.28rem;
    z-index: 0;
    pointer-events: none;
  }
  .fp-card.is-default::before {
    background: linear-gradient(160deg, #ef4444 0%, #b91c1c 35%, #7f1d1d 70%, #2a0808 100%);
  }
  .fp-card.is-default .fp-card-frame {
    background: radial-gradient(110% 80% at 50% 0%, rgba(220,38,38,0.18), transparent 70%), linear-gradient(180deg, #1a0c0c 0%, #100808 100%);
    border: 1px solid rgba(185,28,28,0.7);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.55), inset 0 0 18px rgba(0,0,0,0.5);
  }
  .fp-card.is-champ::before {
    background: linear-gradient(160deg, #ffe27a 0%, #d09312 30%, #6c4404 60%, #2a1908 100%);
  }
  .fp-card.is-champ .fp-card-frame {
    background: radial-gradient(110% 80% at 50% 0%, rgba(255,240,170,0.28), transparent 70%), linear-gradient(180deg, #4a311a 0%, #1c1207 100%);
    border: 1px solid rgba(255,240,170,0.72);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.45), inset 0 0 22px rgba(255,220,140,0.18);
  }
  .fp-card:hover { transform: translateY(-2px) scale(1.01); }
  .fp-card.is-default:hover { box-shadow: 0 0 18px rgba(255,180,80,0.34); }
  .fp-card.is-champ:hover { box-shadow: 0 0 22px rgba(255,220,130,0.55); }

  .fp-card-banner {
    position: relative;
    z-index: 2;
    padding: 0.18rem 0.32rem;
    background: linear-gradient(180deg, #ef4444 0%, #b91c1c 60%, #7f1d1d 100%);
    border: 1px solid rgba(248,113,113,0.65);
    border-radius: 0.22rem;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.22), 0 1px 0 rgba(0,0,0,0.3);
    text-align: center;
  }
  .fp-card.is-champ .fp-card-banner {
    background: linear-gradient(180deg, #fff0a8 0%, #d6a32a 50%, #8a5905 100%);
    border-color: rgba(255,235,170,0.6);
  }
  .fp-card-name {
    display: -webkit-box;
    min-height: 1.5em;
    font-size: 0.74rem;
    font-weight: 900;
    line-height: 1.08;
    color: #fff5f5;
    text-shadow: 0 1px 0 rgba(0,0,0,0.4);
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    text-wrap: balance;
  }
  .fp-card.is-champ .fp-card-name { color: #1a0e00; text-shadow: 0 1px 0 rgba(255,230,160,0.55); }

  .fp-card-top {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.32rem;
    margin: 0 0 0.18rem;
    min-height: 1.5rem;
  }
  .fp-card-portrait {
    position: relative;
    z-index: 2;
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 0.04rem;
    border: 1.5px solid rgba(185,28,28,0.75);
    border-radius: 0.16rem;
    background: radial-gradient(circle at 50% 35%, rgba(248,113,113,0.16), transparent 56%), linear-gradient(180deg, #2a1010 0%, #0f0606 100%);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.5), inset 0 -10px 18px rgba(0,0,0,0.45);
    overflow: hidden;
    min-height: 64px;
  }
  .fp-card.is-champ .fp-card-portrait {
    border-color: rgba(255,240,170,0.85);
    background: radial-gradient(circle at 50% 35%, rgba(255,240,200,0.24), transparent 58%), linear-gradient(180deg, #4a3214 0%, #1a1108 100%);
  }
  .fp-card-portrait-silhouette { font-size: 2.6rem; opacity: 0.18; line-height: 1; filter: blur(0.35px); }
  .fp-card.is-champ .fp-card-portrait-silhouette { opacity: 0.24; }
  .fp-card-initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    color: rgba(254,226,226,0.95);
    text-shadow: 0 2px 6px rgba(0,0,0,0.7);
  }
  .fp-card.is-champ .fp-card-initials { color: rgba(255,240,200,0.95); }
  .fp-card-crown { position: absolute; top: 0.18rem; left: 0.22rem; font-size: 0.78rem; line-height: 1; z-index: 3; text-shadow: 0 0 4px rgba(0,0,0,0.6); }
  .fp-card-flag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1.55rem;
    line-height: 1;
    background: rgba(0,0,0,0.45);
    border: 1px solid rgba(185,28,28,0.6);
    border-radius: 999px;
    padding: 0.18rem 0.5rem;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06);
  }
  .fp-card.is-champ .fp-card-flag { border-color: rgba(255,220,140,0.55); }
  .fp-card-rating {
    position: relative;
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 0.34rem;
    padding: 0.2rem 0.46rem;
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(185,28,28,0.65);
    border-radius: 0.42rem;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.4);
    line-height: 1;
    min-width: 0;
    flex-shrink: 1;
    overflow: hidden;
  }
  .fp-card.is-champ .fp-card-rating { background: linear-gradient(180deg, rgba(255,240,170,0.92), rgba(180,120,30,0.85)); border-color: rgba(255,240,170,0.85); }
  .fp-card-rating-num { font-size: 0.86rem; font-weight: 900; color: #fee2e2; text-shadow: 0 1px 2px rgba(0,0,0,0.6); }
  .fp-card.is-champ .fp-card-rating-num { color: #1a0e00; text-shadow: 0 1px 0 rgba(255,240,170,0.55); }
  .fp-card-rating-pos { font-size: 0.48rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(252,165,165,0.92); }
  .fp-card.is-champ .fp-card-rating-pos { color: rgba(31,19,0,0.78); }
  .fp-card-type-bar {
    position: relative;
    z-index: 2;
    margin: 0.18rem 0 0.14rem;
    padding: 0.2rem 0.26rem;
    background: linear-gradient(180deg, #3a1414 0%, #180808 100%);
    border-top: 1px solid rgba(185,28,28,0.65);
    border-bottom: 1px solid rgba(185,28,28,0.65);
    font-size: 0.58rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(252,165,165,0.95);
    text-align: center;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .fp-card.is-champ .fp-card-type-bar {
    background: linear-gradient(180deg, #3c2a14 0%, #1a1107 100%);
    border-top-color: rgba(255,220,140,0.55);
    border-bottom-color: rgba(255,220,140,0.55);
    color: rgba(255,240,180,0.95);
  }
  .fp-card-desc {
    position: relative;
    z-index: 2;
    background: linear-gradient(180deg, rgba(185,28,28,0.12), rgba(0,0,0,0.22));
    border: 1px solid rgba(185,28,28,0.32);
    border-radius: 0.2rem;
    padding: 0.26rem 0.3rem 0.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
  }
  .fp-card.is-champ .fp-card-desc { background: linear-gradient(180deg, rgba(255,240,170,0.14), rgba(40,24,4,0.32)); border-color: rgba(255,240,170,0.36); }
  .fp-card-stat-row { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 0.12rem 0.42rem; font-size: 0.7rem; }
  .fp-card-stat { display: flex; align-items: center; justify-content: space-between; gap: 0.24rem; line-height: 1; }
  .fp-card-stat em { font-style: normal; font-weight: 800; letter-spacing: 0.08em; color: rgba(252,165,165,0.92); }
  .fp-card-stat b { font-weight: 900; color: #fef2f2; font-size: 0.82rem; }
  .fp-card.is-champ .fp-card-stat em { color: rgba(255,240,180,0.92); }
  .fp-card.is-champ .fp-card-stat b { color: #fff5d6; }
