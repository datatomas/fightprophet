---
import BaseLayout from '../layouts/BaseLayout.astro';
import { runtimeEnvFromLocals } from '../lib/country-master';
import { getFighterCardsData } from '../lib/dashboard-data';

const runtimeEnv = runtimeEnvFromLocals(Astro.locals);
const fighterData = await getFighterCardsData(runtimeEnv);
const pageJson = JSON.stringify(fighterData).replace(/</g, '\\u003c');

const totalProfiles = fighterData.profiles.length;
const activeProfiles = fighterData.profiles.filter((profile) => profile.fighter_status === 'active').length;
const championProfiles = fighterData.profiles.filter((profile) => profile.is_current_champion).length;
const historyRows = fighterData.debug.historyCount;
---

<BaseLayout
  title="MMA Fighter Stats — Records, Striking & Grappling Metrics | Fight Prophet"
  description="Search public MMA fighter stats with records, country, status, method breakdowns, striking and grappling stats, belt context, and recent fight history."
>
  <article class="fp-fighters-page">
    <header class="fp-tool-hero">
      <a class="fp-tool-breadcrumb" href="/">← Fight Prophet</a>
      <p class="fp-section-label" data-i18n="fighters.eyebrow">Fighter Stats</p>
      <h1 data-i18n="fighters.title">MMA Fighter Stats</h1>
      <p data-i18n="fighters.intro">
        Search tracked UFC fighters and inspect career snapshots, method mix, activity status, belt context, striking and grappling metrics, and recent fight history.
      </p>
      <ul class="fp-kpi-chips fp-kpi-chips--hero" aria-label="Fighter archive summary">
        <li class="fp-kpi-chip fp-kpi-chip--hero">
          <img src="/branding/b91c1c-fighterscard-emoji.png" alt="" width="36" height="36" />
          <span data-i18n="fighters.kpi.fighters">Fighters</span><strong data-kpi-total>{totalProfiles.toLocaleString()}</strong>
        </li>
        <li class="fp-kpi-chip fp-kpi-chip--hero">
          <img src="/branding/b91c1c-correct-emoji.png" alt="" width="36" height="36" />
          <span data-i18n="fighters.kpi.active">Active</span><strong data-kpi-active>{activeProfiles.toLocaleString()}</strong>
        </li>
        <li class="fp-kpi-chip fp-kpi-chip--hero">
          <img src="/branding/b91c1c-champion-emoji.png" alt="" width="36" height="36" />
          <span data-i18n="fighters.kpi.champions">Champions</span><strong data-kpi-champs>{championProfiles.toLocaleString()}</strong>
        </li>
        <li class="fp-kpi-chip fp-kpi-chip--hero">
          <img src="/branding/b91c1c-fights-emoji.png" alt="" width="36" height="36" />
          <span data-i18n="fighters.kpi.fightRows">Fight Rows</span><strong data-kpi-rows>{historyRows.toLocaleString()}</strong>
        </li>
      </ul>
    </header>

    {totalProfiles > 0 ? (
      <>
        <section class="fp-tool-controls" aria-label="Fighter filters">
          <label>
            <span data-i18n="fighters.controls.search">Search</span>
            <input type="search" data-fighter-search placeholder="Fighter, country, status" data-i18n-placeholder="fighters.controls.searchPlaceholder" autocomplete="off" />
          </label>
          <label>
            <span data-i18n="fighters.controls.status">Status</span>
            <select data-fighter-status>
              <option value="All" data-i18n="fighters.controls.all">All</option>
              <option value="active" data-i18n="fighters.controls.active">Active</option>
              <option value="inactive" data-i18n="fighters.controls.inactive">Inactive</option>
              <option value="champion" data-i18n="fighters.controls.currentChampions">Current champions</option>
            </select>
          </label>
        </section>

        <div class="fp-fighters-layout">
          <section class="fp-fighter-picker" aria-label="Matching fighters">
            <div class="fp-panel-head">
              <h2 data-i18n="fighters.index.title">Fighter Index</h2>
              <span data-fighter-match-count>{totalProfiles.toLocaleString()} fighters</span>
            </div>
            <label class="fp-fighter-select-label">
              <span data-i18n="fighters.index.choose">Choose fighter</span>
              <select data-fighter-select aria-label="Choose fighter"></select>
            </label>
            <p class="fp-list-empty" data-fighter-empty data-i18n="fighters.index.empty" hidden>No fighters match these filters.</p>
          </section>

          <section class="fp-fighter-detail" aria-live="polite">
            <!-- ── Hero: visual fighter card (left) + identity / KPIs (right) ── -->
            <div class="fp-fighter-hero">
              <div class="fp-fighter-hero-card" data-visual-card></div>

              <div class="fp-fighter-hero-info">
                <header class="fp-fighter-header">
                  <div>
                    <span class="fp-fighter-status" data-profile-status></span>
                    <h2 data-profile-name>Fighter</h2>
                    <p data-profile-meta></p>
                  </div>
                  <div class="fp-record-mark" data-profile-record>—</div>
                </header>

                <div class="fp-hero-stats">
                  <section class="fp-chip-section" aria-labelledby="fp-stats-overview">
                    <h3 class="fp-chip-section-label" id="fp-stats-overview" data-i18n="fighters.overview.title">Overview</h3>
                    <ul class="fp-kpi-chips">
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-correct-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.winRate">Win Rate</span><strong data-kpi-win-rate>—</strong>
                      </li>
                      <li class="fp-kpi-chip">
                        <img src="/branding/finish_rate_icon_b91c1c_transparent.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.finishRate">Finish Rate</span><strong data-kpi-finish-rate>—</strong>
                      </li>
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-winstreak-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.winStreak">Win Streak</span><strong data-kpi-win-streak>—</strong>
                      </li>
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-events-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.lastFight">Last Fight</span><strong data-kpi-last-fight>—</strong>
                      </li>
                    </ul>
                  </section>

                  <section class="fp-chip-section" aria-labelledby="fp-stats-defense">
                    <h3 class="fp-chip-section-label" id="fp-stats-defense" data-i18n="fighters.defense.title">Defense &amp; Streaks</h3>
                    <ul class="fp-kpi-chips">
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-strikingdefence-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.strDef">Str Def</span><strong data-meta-str-def>—</strong>
                      </li>
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-takedowndefence-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.tdDef">TD Def</span><strong data-meta-td-def>—</strong>
                      </li>
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-strikingaccuracy-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.sapm">SApM</span><strong data-meta-sapm>—</strong>
                      </li>
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-bonus-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.bonuses">Bonuses</span><strong data-meta-bonuses>—</strong>
                      </li>
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-winstreak-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.bestWinStreak">Best W Streak</span><strong data-meta-win-streak>—</strong>
                      </li>
                      <li class="fp-kpi-chip">
                        <img src="/branding/b91c1c-incorrect-emoji.png" alt="" width="30" height="30" />
                        <span data-i18n="fighters.stat.worstLossStreak">Worst L Streak</span><strong data-meta-loss-streak>—</strong>
                      </li>
                    </ul>
                  </section>
                </div>
              </div>
            </div>

            <section class="fp-career-snapshot">
              <h3 data-i18n="fighters.section.career">Career Snapshot</h3>
              <div class="fp-kpi-grid" data-career-list></div>
            </section>
            <div class="fp-profile-grid">
              <section>
                <h3 data-i18n="fighters.section.skills">Striking &amp; Grappling</h3>
                <div class="fp-kpi-grid" data-skills-list></div>
              </section>
              <section>
                <h3 data-i18n="fighters.section.methodMix">Method Mix</h3>
                <div class="fp-kpi-grid" data-method-list></div>
              </section>
            </div>

            <section class="fp-history-panel">
              <div class="fp-panel-head">
                <div>
                  <h3 data-i18n="fighters.section.recentHistory">Recent Fight History</h3>
                  <span data-history-count></span>
                </div>
                <button type="button" class="fp-csv-btn" data-csv-download aria-label="Download fight history as CSV" data-i18n-aria-label="fighters.csv.aria">
                  ↓ CSV
                </button>
              </div>
              <div class="fp-history-scroll">
                <table class="fp-history-table" data-history-table>
                  <thead>
                    <tr>
                      <th scope="col" data-i18n="fighters.history.date">Date</th>
                      <th scope="col" data-i18n="fighters.history.result">Result</th>
                      <th scope="col" data-i18n="fighters.history.opponent">Opponent</th>
                      <th scope="col" data-i18n="fighters.history.method">Method</th>
                      <th scope="col" class="fp-col-center">Rd</th>
                      <th scope="col" class="fp-col-center">Time</th>
                      <th scope="col" class="fp-col-center">KD</th>
                      <th scope="col" class="fp-col-center">STR</th>
                      <th scope="col" class="fp-col-center">TD</th>
                      <th scope="col" class="fp-col-center">SUB</th>
                      <th scope="col" data-i18n="fighters.history.event">Event</th>
                    </tr>
                  </thead>
                  <tbody data-history-body></tbody>
                </table>
              </div>
            </section>
          </section>
        </div>
      </>
    ) : (
      <section class="fp-empty-state">
        <strong data-i18n="fighters.empty.title">Fighter stats are temporarily unavailable.</strong>
        <span data-i18n="fighters.empty.copy">The public cards read from the exported dashboard parquet feed. If this is empty, the latest export has not landed yet.</span>
      </section>
    )}
  </article>

  <script type="application/json" id="fp-fighter-data" set:html={pageJson}></script>
</BaseLayout>

<script is:inline>
  (() => {
    const dataNode = document.getElementById('fp-fighter-data');
    if (!dataNode) return;
    const payload = JSON.parse(dataNode.textContent || '{"profiles":[],"history":{}}');
    const profiles = Array.isArray(payload.profiles) ? payload.profiles : [];
    const history = payload.history && typeof payload.history === 'object' ? payload.history : {};
    if (!profiles.length) return;

    const search = document.querySelector('[data-fighter-search]');
    const status = document.querySelector('[data-fighter-status]');
    const fighterSelect = document.querySelector('[data-fighter-select]');
    const emptyState = document.querySelector('[data-fighter-empty]');
    const matchCount = document.querySelector('[data-fighter-match-count]');
    const profileName = document.querySelector('[data-profile-name]');
    const profileMeta = document.querySelector('[data-profile-meta]');
    const profileStatus = document.querySelector('[data-profile-status]');
    const profileRecord = document.querySelector('[data-profile-record]');
    const winRate = document.querySelector('[data-kpi-win-rate]');
    const finishRate = document.querySelector('[data-kpi-finish-rate]');
    const winStreak = document.querySelector('[data-kpi-win-streak]');
    const lastFight = document.querySelector('[data-kpi-last-fight]');
    const careerList = document.querySelector('[data-career-list]');
    const skillsList = document.querySelector('[data-skills-list]');
    const methodList = document.querySelector('[data-method-list]');
    const historyCount  = document.querySelector('[data-history-count]');
    const historyBody   = document.querySelector('[data-history-body]');
    const csvBtn        = document.querySelector('[data-csv-download]');
    const metaStrDef = document.querySelector('[data-meta-str-def]');
    const metaTdDef = document.querySelector('[data-meta-td-def]');
    const metaSapm = document.querySelector('[data-meta-sapm]');
    const metaBonuses = document.querySelector('[data-meta-bonuses]');
    const metaWinStreak = document.querySelector('[data-meta-win-streak]');
    const metaLossStreak = document.querySelector('[data-meta-loss-streak]');
    const visualCardSlot = document.querySelector('[data-visual-card]');

    const params = new URLSearchParams(window.location.search);
    const requested = String(params.get('fighter') || '').trim().toLowerCase();
    let selectedProfile = profiles.find((profile) => profile.name.toLowerCase() === requested)
      || profiles.find((profile) => profile.name.toLowerCase().includes(requested) && requested)
      || profiles[0];

    const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g, (ch) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[ch]));
    const tr = (key, fallback) => window.__fpT ? window.__fpT(key, fallback) : fallback;
    const fmtInt = (value) => value == null || Number.isNaN(Number(value)) ? '—' : Number(value).toLocaleString();
    const fmtPct = (value, decimals = 0) => {
      if (value == null || Number.isNaN(Number(value))) return '—';
      const num = Number(value);
      const pct = num <= 1 ? num * 100 : num;
      return `${pct.toFixed(decimals)}%`;
    };
    const fmtNum = (value, decimals = 2) => value == null || Number.isNaN(Number(value)) ? '—' : Number(value).toFixed(decimals);

    // Pct (0..100) for filling a progress bar; accepts 0..1 or 0..100 source values.
    const pctValue = (value) => {
      if (value == null || Number.isNaN(Number(value))) return null;
      const num = Number(value);
      return Math.max(0, Math.min(100, num <= 1 ? num * 100 : num));
    };

    // Senior-UX KPI card. `opts.pct` (0..100) renders a progress bar; `opts.hint` appends a small footnote.
    const kpiCard = (label, value, opts = {}) => {
      const { pct = null, hint = '', tone = 'default' } = opts;
      const bar = pct == null ? '' : `<div class="fp-kpi-bar" aria-hidden="true"><span style="width:${pct.toFixed(1)}%"></span></div>`;
      const hintHtml = hint ? `<span class="fp-kpi-hint">${escapeHtml(hint)}</span>` : '';
      const valueDisplay = value === '' || value == null ? '—' : value;
      return `<article class="fp-kpi-card fp-kpi-card--${tone}">
        <span class="fp-kpi-label">${escapeHtml(label)}</span>
        <strong class="fp-kpi-value">${escapeHtml(valueDisplay)}</strong>
        ${bar}${hintHtml}
      </article>`;
    };
    const record = (profile) => `${fmtInt(profile.wins)}-${fmtInt(profile.losses)}-${fmtInt(profile.draws || 0)}`;
    const profileUrl = (profile) => `/fighter-stats/?fighter=${encodeURIComponent(profile.name)}`;

    // ── Visual fighter card ─────────────────────────────────────────────────
    // Mirrors the markup/classes from src/components/FighterCard.astro so the same
    // shared CSS (.fp-card, .fp-card-banner, …) renders the Yu-Gi-Oh style card.
    const initialsOf = (n) => String(n || '').split(/\s+/).map((p) => p[0]).filter(Boolean).slice(0, 2).join('').toUpperCase();
    const wcAbbrOf = (wc) => {
      if (!wc) return '';
      const map = {
        'flyweight': 'FLW', 'bantamweight': 'BW', 'featherweight': 'FW',
        'lightweight': 'LW', 'welterweight': 'WW', 'middleweight': 'MW',
        'light heavyweight': 'LHW', 'heavyweight': 'HW', 'strawweight': 'SW',
        "women's strawweight": 'WSW', "women's flyweight": 'WFLW',
        "women's bantamweight": 'WBW', "women's featherweight": 'WFW',
      };
      const key = wc.toLowerCase().trim();
      return map[key] || wc.split(/\s+/).map((p) => p[0]).join('').toUpperCase().slice(0, 4);
    };

    function buildVisualCardHtml(profile) {
      const isChamp = !!profile.is_current_champion;
      const init = initialsOf(profile.name);
      const wc = profile.current_belt_weight_classes || '';
      const abbr = wcAbbrOf(wc);
      const wins = fmtInt(profile.wins);
      const losses = fmtInt(profile.losses);
      const rec = wins !== '—' && losses !== '—' ? `${wins}-${losses}` : (wins !== '—' ? wins : '—');
      const typeLine = [wc || tr('fighters.dynamic.mmaFighter', 'MMA Fighter'), profile.country].filter(Boolean).join(' / ');
      const flag = profile.country_flag || '';
      const ratingNum = isChamp ? 'C' : rec;
      const ratingPos = abbr ? `<span class="fp-card-rating-pos">${escapeHtml(abbr)}</span>` : '';
      const finRate = fmtPct(profile.finish_rate);
      const subRate = fmtPct(profile.sub_rate_win_shrunk);
      const wStreak = fmtInt(profile.longest_win_streak);
      const lStreak = fmtInt(profile.longest_loss_streak);
      const ptsLabel = fmtInt(profile.bonuses_won_count);

      return `<a class="fp-card ${isChamp ? 'is-champ' : 'is-default'} is-compact" href="${escapeHtml(profileUrl(profile))}">
        <div class="fp-card-frame" aria-hidden="true"></div>
        <div class="fp-card-top">
          <div class="fp-card-rating">
            <span class="fp-card-rating-num">${escapeHtml(ratingNum)}</span>
            ${ratingPos}
          </div>
          ${flag ? `<span class="fp-card-flag" title="${escapeHtml(profile.country)}">${escapeHtml(flag)}</span>` : ''}
        </div>
        <header class="fp-card-banner"><span class="fp-card-name">${escapeHtml(profile.name)}</span></header>
        <div class="fp-card-portrait">
          <span class="fp-card-portrait-silhouette" aria-hidden="true">👤</span>
          <span class="fp-card-initials" aria-hidden="true">${escapeHtml(init)}</span>
          ${isChamp ? `<span class="fp-card-crown" aria-label="${escapeHtml(tr('fighters.controls.currentChampions', 'Current champion'))}">👑</span>` : ''}
        </div>
        <div class="fp-card-type-bar">[ ${escapeHtml(typeLine)} ]</div>
        <div class="fp-card-desc">
          <div class="fp-card-stat-row">
            <span class="fp-card-stat"><em>FIN</em><b>${escapeHtml(finRate)}</b></span>
            <span class="fp-card-stat"><em>SUB</em><b>${escapeHtml(subRate)}</b></span>
            <span class="fp-card-stat"><em>W★</em><b>${escapeHtml(wStreak)}</b></span>
            <span class="fp-card-stat"><em>L✗</em><b>${escapeHtml(lStreak)}</b></span>
          </div>
          <div class="fp-card-atkdef">
            <span class="fp-card-atk">PTS/${escapeHtml(ptsLabel)}</span>
            <span class="fp-card-sep">·</span>
            <span class="fp-card-def">REC/${escapeHtml(rec)}</span>
          </div>
        </div>
      </a>`;
    }

    function filteredProfiles() {
      const query = String(search?.value || '').trim().toLowerCase();
      const statusValue = String(status?.value || 'All');
      return profiles.filter((profile) => {
        const statusMatch = statusValue === 'All'
          || profile.fighter_status === statusValue
          || (statusValue === 'champion' && profile.is_current_champion);
        return statusMatch && (!query || String(profile.search_text || profile.name).includes(query));
      });
    }

    function selectProfile(profile, pushState = true) {
      selectedProfile = profile;
      if (pushState) window.history.replaceState({}, '', profileUrl(profile));

      if (visualCardSlot) visualCardSlot.innerHTML = buildVisualCardHtml(profile);

      profileName.textContent = profile.name;
      profileMeta.textContent = [
        profile.country,
        profile.current_belt_weight_classes,
        profile.stance,
      ].filter(Boolean).join(' / ');
      profileStatus.textContent = profile.is_current_champion
        ? tr('fighters.dynamic.currentChampion', 'Current Champion')
        : (profile.fighter_status ? tr(`fighters.status.${String(profile.fighter_status).toLowerCase()}`, String(profile.fighter_status).replace(/^./, (c) => c.toUpperCase())) : tr('fighters.dynamic.fighter', 'Fighter'));
      profileStatus.classList.toggle('is-champion', !!profile.is_current_champion);
      profileRecord.textContent = record(profile);
      winRate.textContent = fmtPct(profile.win_rate, 1);
      finishRate.textContent = fmtPct(profile.finish_rate, 1);
      winStreak.textContent = fmtInt(profile.win_streak);
      lastFight.textContent = profile.last_fight_date || '—';
      if (metaStrDef) metaStrDef.textContent = fmtPct(profile.str_def);
      if (metaTdDef) metaTdDef.textContent = fmtPct(profile.td_def);
      if (metaSapm) metaSapm.textContent = fmtNum(profile.sapm, 2);
      if (metaBonuses) metaBonuses.textContent = fmtInt(profile.bonuses_won_count);
      if (metaWinStreak) metaWinStreak.textContent = fmtInt(profile.longest_win_streak);
      if (metaLossStreak) metaLossStreak.textContent = fmtInt(profile.longest_loss_streak);

      careerList.innerHTML = [
        kpiCard(tr('fighters.kpiCard.country', 'Country'), profile.country || '—'),
        kpiCard(tr('fighters.kpiCard.status', 'Status'), (profile.fighter_status ? tr(`fighters.status.${String(profile.fighter_status).toLowerCase()}`, String(profile.fighter_status).replace(/^./, (c) => c.toUpperCase())) : '—'), { tone: profile.fighter_status === 'active' ? 'good' : 'muted' }),
        kpiCard(tr('fighters.kpiCard.age', 'Age'), fmtInt(profile.age), { hint: profile.age ? tr('fighters.hint.years', 'years') : '' }),
        kpiCard(tr('fighters.kpiCard.height', 'Height'), profile.height || '—'),
        kpiCard(tr('fighters.kpiCard.weight', 'Weight'), profile.weight || '—'),
        kpiCard(tr('fighters.kpiCard.reach', 'Reach'), profile.reach || '—'),
        kpiCard(tr('fighters.kpiCard.firstFight', 'First Fight'), profile.first_fight_date || '—'),
        kpiCard(tr('fighters.kpiCard.titleFights', 'Title Fights'), fmtInt(profile.title_fights), { tone: Number(profile.title_fights) > 0 ? 'accent' : 'default' }),
      ].join('');

      skillsList.innerHTML = [
        kpiCard(tr('fighters.kpiCard.slpm', 'SLpM'), fmtNum(profile.slpm, 2), { hint: tr('fighters.hint.perMinute', 'per minute') }),
        kpiCard(tr('fighters.kpiCard.sapm', 'SApM'), fmtNum(profile.sapm, 2), { hint: tr('fighters.hint.perMinute', 'per minute') }),
        kpiCard(tr('fighters.kpiCard.strAcc', 'Str Acc'), fmtPct(profile.str_acc), { pct: pctValue(profile.str_acc), tone: 'pct' }),
        kpiCard(tr('fighters.kpiCard.strDef', 'Str Def'), fmtPct(profile.str_def), { pct: pctValue(profile.str_def), tone: 'pct' }),
        kpiCard(tr('fighters.kpiCard.tdAvg', 'TD Avg'), fmtNum(profile.td_avg, 2), { hint: tr('fighters.hint.per15', 'per 15 min') }),
        kpiCard(tr('fighters.kpiCard.tdAcc', 'TD Acc'), fmtPct(profile.td_acc), { pct: pctValue(profile.td_acc), tone: 'pct' }),
        kpiCard(tr('fighters.kpiCard.tdDef', 'TD Def'), fmtPct(profile.td_def), { pct: pctValue(profile.td_def), tone: 'pct' }),
        kpiCard(tr('fighters.kpiCard.subAvg', 'Sub Avg'), fmtNum(profile.sub_avg, 2), { hint: tr('fighters.hint.per15', 'per 15 min') }),
      ].join('');

      methodList.innerHTML = [
        kpiCard(tr('fighters.kpiCard.koTkoWins', 'KO/TKO Wins'), fmtInt(profile.ko_wins), { tone: 'count' }),
        kpiCard(tr('fighters.kpiCard.submissionWins', 'Submission Wins'), fmtInt(profile.sub_wins), { tone: 'count' }),
        kpiCard(tr('fighters.kpiCard.decisionWins', 'Decision Wins'), fmtInt(profile.dec_wins), { tone: 'count' }),
        kpiCard(tr('fighters.kpiCard.bonuses', 'Bonuses'), fmtInt(profile.bonuses_won_count), { tone: 'accent' }),
        kpiCard(tr('fighters.kpiCard.bayesKoTko', 'Bayes KO/TKO'), fmtPct(profile.ko_rate_win_shrunk), { pct: pctValue(profile.ko_rate_win_shrunk), tone: 'pct' }),
        kpiCard(tr('fighters.kpiCard.bayesSub', 'Bayes Sub'), fmtPct(profile.sub_rate_win_shrunk), { pct: pctValue(profile.sub_rate_win_shrunk), tone: 'pct' }),
        kpiCard(tr('fighters.kpiCard.bayesFinish', 'Bayes Finish'), fmtPct(profile.finish_rate_win_shrunk), { pct: pctValue(profile.finish_rate_win_shrunk), tone: 'pct' }),
        kpiCard(tr('fighters.kpiCard.methodSample', 'Method Sample'), fmtInt(profile.wins_method_known_count), { hint: tr('fighters.hint.fights', 'fights') }),
      ].join('');

      const rows = history[profile.fighter_id] || [];
      historyCount.textContent = `${rows.length.toLocaleString()} ${rows.length === 1 ? tr('fighters.count.fight', 'fight') : tr('fighters.count.fights', 'fights')}`;

      // Wire CSV download for this fighter
      if (csvBtn) {
        csvBtn.onclick = () => downloadCSV(profile.name, rows);
      }

      if (!rows.length) {
        historyBody.innerHTML = `<tr><td colspan="11" class="fp-history-empty">${escapeHtml(tr('fighters.history.empty', 'No fight history available yet.'))}</td></tr>`;
        return;
      }

      const statCell = (a, b) => {
        const av = fmtInt(a);
        const bv = fmtInt(b);
        if (av === '—' && bv === '—') return '<td class="fp-col-center fp-stat-cell">—</td>';
        return `<td class="fp-col-center fp-stat-cell"><span class="fp-stat-for">${escapeHtml(av)}</span><span class="fp-stat-sep">–</span><span class="fp-stat-against">${escapeHtml(bv)}</span></td>`;
      };

      historyBody.innerHTML = rows.map((row) => {
        const res = String(row.result || '').toLowerCase();
        const resCls = res === 'win' ? 'win' : res === 'loss' ? 'loss' : 'neutral';
        const resLabel = row.result || '—';
        const method = escapeHtml(row.method || row.method_category || '—');
        const titleBadge = row.is_title_fight ? '<span class="fp-title-badge" aria-label="Title fight">★</span>' : '';
        const oppHref = `/fighter-stats/?fighter=${encodeURIComponent(row.opponent_name_display || '')}`;
        const weightTag = row.weight_class ? `<span class="fp-wc-tag">${escapeHtml(row.weight_class)}</span>` : '';

        return `<tr class="fp-fight-tr fp-fight-tr--${resCls}">
          <td class="fp-cell-date">${escapeHtml(row.event_date || '—')}</td>
          <td><span class="fp-result-badge fp-result-badge--${resCls}">${escapeHtml(resLabel)}</span></td>
          <td class="fp-cell-opp">
            <a class="fp-opp-link" href="${oppHref}">${escapeHtml(row.opponent_name_display || '—')}</a>
            ${titleBadge}
          </td>
          <td class="fp-cell-method">
            <span class="fp-method-name">${method}</span>
            ${weightTag}
          </td>
          <td class="fp-col-center">${escapeHtml(String(row.round ?? '—'))}</td>
          <td class="fp-col-center fp-cell-time">${escapeHtml(row.time || '—')}</td>
          ${statCell(row.kd_for, row.kd_against)}
          ${statCell(row.str_for, row.str_against)}
          ${statCell(row.td_for, row.td_against)}
          ${statCell(row.sub_for, row.sub_against)}
          <td class="fp-cell-event">${escapeHtml(row.event_name || '—')}</td>
        </tr>`;
      }).join('');
    }

    function downloadCSV(fighterName, rows) {
      const headers = ['Date','Event','Opponent','Weight Class','Title Fight','Result','Winner','Method','Round','Time','KD For','KD Against','STR For','STR Against','TD For','TD Against','Sub For','Sub Against'];
      const csvRow = (r) => [
        r.event_date, r.event_name, r.opponent_name_display, r.weight_class,
        r.is_title_fight ? 'Yes' : 'No', r.result, r.winner_name_display,
        r.method || r.method_category, r.round ?? '', r.time,
        r.kd_for ?? '', r.kd_against ?? '', r.str_for ?? '', r.str_against ?? '',
        r.td_for ?? '', r.td_against ?? '', r.sub_for ?? '', r.sub_against ?? '',
      ].map((v) => `"${String(v ?? '').replace(/"/g, '""')}"`).join(',');

      const csv = [headers.join(','), ...rows.map(csvRow)].join('\r\n');
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href     = url;
      a.download = `${fighterName.replace(/[^a-z0-9]/gi, '_')}_fight_history.csv`;
      a.click();
      URL.revokeObjectURL(url);
    }

    function renderList() {
      const rows = filteredProfiles();
      matchCount.textContent = `${rows.length.toLocaleString()} fighters`;
      if (!rows.some((profile) => profile.fighter_id === selectedProfile.fighter_id)) {
        selectedProfile = rows[0] || profiles[0];
      }
      if (fighterSelect) {
        fighterSelect.disabled = rows.length === 0;
        fighterSelect.innerHTML = rows.slice(0, 500).map((profile) => {
          const meta = [profile.country, profile.fighter_status, record(profile)].filter(Boolean).join(' / ');
          return `<option value="${escapeHtml(profile.fighter_id)}">${escapeHtml(profile.name)}${meta ? ` — ${escapeHtml(meta)}` : ''}</option>`;
        }).join('');
        fighterSelect.value = selectedProfile?.fighter_id || '';
      }
      if (emptyState) emptyState.hidden = rows.length > 0;
      if (selectedProfile) selectProfile(selectedProfile, false);
    }

    search?.addEventListener('input', renderList);
    status?.addEventListener('change', renderList);
    window.addEventListener('fp-lang-change', renderList);
    fighterSelect?.addEventListener('change', () => {
      const profile = filteredProfiles().find((candidate) => candidate.fighter_id === fighterSelect.value);
      if (profile) {
        selectProfile(profile);
        renderList();
      }
    });
    if (requested) search.value = params.get('fighter') || '';
    renderList();
  })();
</script>

