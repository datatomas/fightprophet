      padding: 0.3rem 0;
    }
    .fp-rank-section-link:hover {
      color: #fef2f2;
    }
    .fp-rank-wall {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .fp-rank-note {
      margin: 0;
      color: #d4d4d8;
      font-size: 0.92rem;
      line-height: 1.55;
      max-width: 72ch;
    }

    .fp-ranking-scoreboard {
      display: grid;
      grid-template-columns: minmax(260px, 0.95fr) minmax(320px, 1.25fr);
      gap: 0.72rem;
      padding: 0.78rem;
      box-sizing: border-box;
      max-width: 100%;
      background:
        linear-gradient(90deg, rgba(127, 29, 29, 0.34), rgba(9, 9, 11, 0.72)),
        repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 10px);
      border: 1px solid rgba(248, 113, 113, 0.28);
      border-radius: 0.5rem;
      box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.32), 0 10px 24px rgba(0, 0, 0, 0.18);
    }
    .fp-ranking-scoreboard-lead {
      display: flex;
      flex-direction: column;
      gap: 0.34rem;
      min-width: 0;
    }
    .fp-score-stamp {
      align-self: flex-start;
      padding: 0.24rem 0.48rem;
      color: #071014;
      background: linear-gradient(160deg, #67e8f9, #22d3ee);
      border: 1px solid rgba(103, 232, 249, 0.75);
      border-radius: 0.32rem;
      font-size: 0.62rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .fp-ranking-scoreboard h3 {
      margin: 0;
      color: #fef2f2;
      font-size: clamp(1.02rem, 1.8vw, 1.28rem);
      line-height: 1.2;
      letter-spacing: 0;
    }
    .fp-ranking-scoreboard p {
      margin: 0;
      color: #d4d4d8;
      font-size: 0.88rem;
      line-height: 1.5;
    }
    .fp-score-rules {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.44rem;
    }
    .fp-score-rule {
      display: grid;
      gap: 0.2rem;
      min-width: 0;
      max-width: 100%;
      padding: 0.54rem 0.6rem;
      background: rgba(9, 9, 11, 0.58);
      border: 1px solid rgba(113, 113, 122, 0.34);
      border-left-color: rgba(248, 113, 113, 0.7);
      border-radius: 0.5rem;
    }
    .fp-score-rule strong {
      color: #fef2f2;
      font-size: 0.82rem;
      line-height: 1.15;
    }
    .fp-score-rule span {
      color: #a1a1aa;
      font-size: 0.72rem;
      line-height: 1.35;
    }
    @media (max-width: 900px) {
      .fp-ranking-scoreboard {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 560px) {
      .fp-ranking-scoreboard {
        padding: 0.62rem;
      }
      .fp-score-rules {
        grid-template-columns: 1fr;
      }
    }

    .fp-rank-control-row {
      display: flex;
      align-items: stretch;
      justify-content: space-between;
      gap: 0.62rem;
      flex-wrap: wrap;
    }
    .fp-rank-search {
      display: inline-flex;
      align-items: center;
      gap: 0.42rem;
      min-width: min(100%, 340px);
      padding: 0.3rem 0.44rem;
      box-sizing: border-box;
      background: rgba(22, 22, 26, 0.72);
      border: 1px solid rgba(113, 113, 122, 0.36);
      border-radius: 999px;
    }
    .fp-rank-search span {
      color: #67e8f9;
      font-size: 0.68rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .fp-rank-search input {
      min-width: 0;
      width: 100%;
      color: #fef2f2;
      background: transparent;
      border: 0;
      outline: 0;
      font: inherit;
      font-size: 0.86rem;
    }
    .fp-rank-search input::placeholder {
      color: #71717a;
    }
    @media (max-width: 560px) {
      .fp-rank-control-row,
      .fp-rank-search,
      .fp-status-toggle {
        width: 100%;
      }
      .fp-status-toggle {
        justify-content: space-between;
      }
      .fp-status-btn {
        flex: 1;
        padding-inline: 0.46rem;
      }
    }

    /* STATUS TOGGLE (active / inactive / all) */
    .fp-status-toggle {
      display: inline-flex;
      gap: 0.32rem;
      padding: 0.3rem;
      box-sizing: border-box;
      background: rgba(22, 22, 26, 0.6);
      border: 1px solid rgba(113, 113, 122, 0.32);
      border-radius: 999px;
      align-self: stretch;
    }
    .fp-status-btn {
      padding: 0.34rem 0.78rem;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #d4d4d8;
      background: transparent;
      border: 1px solid transparent;
      border-radius: 999px;
      cursor: pointer;
      transition: color 140ms ease, background 140ms ease, border-color 140ms ease;
    }
    .fp-status-btn:hover {
      color: #fef2f2;
      border-color: rgba(248, 113, 113, 0.4);
    }
    .fp-status-btn.is-active {
      color: #fef2f2;
      background: linear-gradient(160deg, rgba(127, 29, 29, 0.85), rgba(35, 20, 20, 0.95));
      border-color: rgba(248, 113, 113, 0.6);
      box-shadow: 0 0 12px rgba(220, 38, 38, 0.22);
    }
    @media (max-width: 560px) {
      .fp-status-btn {
        padding: 0.34rem 0.46rem;
      }
    }
    .fp-division-empty {
      margin: 0.6rem 0 0;
      font-size: 0.86rem;
      color: #a1a1aa;
    }

    /* DIVISION PILLS */
    .fp-division-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.36rem;
      padding: 0.42rem;
      box-sizing: border-box;
      max-width: 100%;
      background: rgba(22, 22, 26, 0.6);
      border: 1px solid rgba(113, 113, 122, 0.32);
      border-radius: 0.7rem;
    }
    .fp-division-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.32rem;
      padding: 0.36rem 0.7rem;
      font-size: 0.78rem;
      font-weight: 700;
      color: #d4d4d8;
      background: rgba(35, 35, 40, 0.7);
      border: 1px solid rgba(113, 113, 122, 0.32);
      border-radius: 999px;
      cursor: pointer;
      letter-spacing: 0.01em;
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease, transform 140ms ease;
    }
    .fp-division-pill:hover {
      color: #fef2f2;
      border-color: rgba(248, 113, 113, 0.45);
      transform: translateY(-1px);
    }
    .fp-division-pill.is-active {
      background: linear-gradient(160deg, rgba(127, 29, 29, 0.85), rgba(35, 20, 20, 0.95));
      color: #fef2f2;
      border-color: rgba(248, 113, 113, 0.6);
      box-shadow: 0 0 12px rgba(220, 38, 38, 0.22);
    }
    .fp-division-pill-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.3rem;
      padding: 0.04rem 0.34rem;
      font-size: 0.62rem;
      font-weight: 800;
      background: rgba(220, 38, 38, 0.2);
      color: #fee2e2;
      border-radius: 999px;
    }
    .fp-division-panels {
      position: relative;
      transition: min-height 140ms ease;
    }

    /* DIVISION BLOCK */
    .fp-division-block {
      display: none;
      opacity: 0;
    }
    .fp-division-block.is-active,
    .fp-division-block.is-entering,
    .fp-division-block.is-leaving {
      display: flex;
      flex-direction: column;
      gap: 0.62rem;
    }
    .fp-division-block.is-active,
    .fp-division-block.is-entering {
      opacity: 1;
    }
    .fp-division-block.is-entering {
      animation: fpDeckIn 180ms ease-out;
    }
    .fp-division-block.is-leaving {
      position: absolute;
      inset: 0;
      pointer-events: none;
      animation: fpDeckOut 140ms ease both;
    }
    .fp-division-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.6rem;
      padding: 0.35rem 0.62rem;
      border-left: 3px solid rgba(220, 38, 38, 0.6);
      background: linear-gradient(90deg, rgba(127, 29, 29, 0.22), transparent);
      border-radius: 0.4rem;
    }
    .fp-division-title {
      margin: 0;
      font-size: 0.96rem;
      font-weight: 800;
      color: #fef2f2;
      letter-spacing: 0.01em;
    }
    .fp-division-count {
      font-size: 0.66rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
      color: #a1a1aa;
    }
    .fp-division-description {
      margin: 0;
      color: #bfbfc8;
      font-size: 0.86rem;
      line-height: 1.55;
      max-width: 68ch;
    }

    /* CARD GRID — centered card-game hierarchy: one GOAT boss card, ranked GOATs below. */
    .fp-card-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: start;
      gap: 0.92rem 0.78rem;
      max-width: 1120px;
      margin-inline: auto;
      padding-inline: 0.1rem;
    }
    .fp-card-shell {
      contain: layout;
      will-change: transform, opacity;
      width: 100%;
      flex: 0 1 168px;
      max-width: 168px;
      position: relative;
      --fp-card-scale: 1;
      --fp-card-font-scale: 1;
      transform-origin: center top;
    }
    .fp-card-holder {
      width: 100%;
    }
    .fp-rank-tier-label {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 1.15rem;
      margin: 0 auto 0.22rem;
      padding: 0.12rem 0.44rem;
      color: #fef2f2;
      background: linear-gradient(160deg, rgba(127, 29, 29, 0.92), rgba(24, 24, 27, 0.9));
      border: 1px solid rgba(248, 113, 113, 0.55);
      border-radius: 999px;
      box-shadow: 0 0 12px rgba(220, 38, 38, 0.2);
      font-size: 0.58rem;
      font-weight: 900;
      line-height: 1;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .fp-rank-tier-label[hidden] {
      display: none;
    }
    .fp-card-shell.is-rank-king {
      flex-basis: 100%;
      max-width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      --fp-card-scale: 1.24;
      --fp-card-font-scale: 1.14;
      z-index: 4;
    }
    .fp-card-shell.is-rank-king .fp-card-holder {
      width: min(270px, 100%);
      max-width: 270px;
    }
    .fp-card-shell.is-rank-king .fp-rank-tier-label {
      color: #140900;
      background: linear-gradient(160deg, #ffe27a, #f59e0b);
      border-color: rgba(255, 240, 170, 0.78);
      box-shadow: 0 0 20px rgba(245, 158, 11, 0.28);
      font-size: 0.66rem;
    }
    .fp-card-shell.is-rank-goat {
      --fp-card-scale: 1.02;
      --fp-card-font-scale: 1.02;
      z-index: 1;
    }
    .fp-card-shell[hidden] {
      display: none;
    }
    .fp-card-shell.is-filter-entering {
      animation: fpCardFilterIn 260ms cubic-bezier(0.2, 0.85, 0.25, 1) both;
      animation-delay: calc(var(--card-index, 0) * 12ms);
    }
    @media (max-width: 900px) {
      .fp-card-grid {
        gap: 0.78rem 0.64rem;
      }
      .fp-card-shell.is-rank-king .fp-card-holder {
        width: min(220px, 100%);
        max-width: 220px;
      }
    }
    @media (max-width: 560px) {
      .fp-card-grid {
        gap: 0.78rem 0.54rem;
      }
      .fp-card-shell.is-rank-goat {
        flex-basis: calc(50% - 0.32rem);
        max-width: 170px;
      }
      .fp-card-shell.is-rank-king .fp-card-holder {
        width: min(224px, 100%);
        max-width: 224px;
      }
    }
    .fp-division-block.is-entering .fp-card-shell {
      animation: fpCardDeal 360ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
      animation-delay: calc(var(--card-index, 0) * 28ms);
    }
    .fp-division-block.is-leaving .fp-card-shell {
      animation: none;
    }
    .fp-division-footer {
      display: flex;
      justify-content: flex-end;
      padding-top: 0.2rem;
    }
    .fp-division-link {
      font-size: 0.82rem;
      font-weight: 700;
      color: #fca5a5;
      text-decoration: none;
    }
    .fp-division-link:hover {
      color: #fef2f2;
    }
    @keyframes fpDeckIn {
      0% {
        opacity: 0;
        transform: translateY(6px) scale(0.995);
      }
      100% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    @keyframes fpDeckOut {
      0% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
      100% {
        opacity: 0;
        transform: translateY(-4px) scale(0.995);
      }
    }
    @keyframes fpCardDeal {
      0% {
        opacity: 0;
        transform: translate3d(0, -18px, 0) rotate(-2deg) scale(0.9);
        filter: saturate(0.85) brightness(0.82);
      }
      62% {
        opacity: 1;
        transform: translate3d(0, 4px, 0) rotate(0.8deg) scale(1.015);
      }
      100% {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
        filter: none;
      }
    }
    @keyframes fpCardFilterIn {
      0% {
        opacity: 0;
        transform: translate3d(0, 10px, 0) rotate(1deg) scale(0.96);
      }
      100% {
        opacity: 1;
        transform: translate3d(0, 0, 0) rotate(0) scale(1);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .fp-division-block.is-entering .fp-card-shell,
      .fp-card-shell.is-filter-entering {
        animation: none;
      }
    }

    /* SECTIONS GRID */
    .fp-sections-head {
      display: flex;
      flex-direction: column;
      gap: 0.18rem;
      margin-bottom: 0.5rem;
    }
    .fp-sections-title {
      margin: 0;
      font-size: clamp(1.05rem, 2.2vw, 1.32rem);
      font-weight: 800;
      color: #fef2f2;
      letter-spacing: 0;
    }
    .fp-cta-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.6rem;
    }
    .fp-section-card {
      display: flex;
      flex-direction: column;
      gap: 0.22rem;
      padding: 0.78rem 0.85rem;
      text-decoration: none;
      color: #fef2f2;
      background: linear-gradient(155deg, rgba(35, 20, 20, 0.55), rgba(22, 22, 26, 0.85));
      border: 1px solid rgba(220, 38, 38, 0.22);
      border-radius: 0.75rem;
      transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
    }
    .fp-section-card:hover {
      transform: translateY(-2px);
      border-color: rgba(248, 113, 113, 0.45);
      box-shadow: 0 0 14px rgba(220, 38, 38, 0.18);
    }
    .fp-section-card strong {
      font-size: 0.96rem;
      font-weight: 800;
    }
    .fp-section-card span {
      font-size: 0.78rem;
      color: #a1a1aa;
      line-height: 1.4;
    }
    @media (max-width: 760px) {
      .fp-cta-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 460px) {
      .fp-cta-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 560px) {
      .fp-home-main {
        gap: 1rem;
        overflow-x: hidden;
      }
      .fp-hero {
        padding: 1.18rem 0.88rem 1rem;
        border-radius: 0.7rem;
      }
      .fp-hero-logo {
        width: min(168px, 72vw);
      }
      .fp-hero-title {
        max-width: 19ch;
        font-size: clamp(1.28rem, 6.2vw, 1.58rem);
      }
      .fp-hero-sub {
        max-width: 100%;
        font-size: 0.92rem;
      }
      .fp-hero-ctas {
        width: 100%;
        flex-direction: column;
        align-items: stretch;
      }
      .fp-cta-primary,
      .fp-cta-ghost {
        width: 100%;
        justify-content: center;
        box-sizing: border-box;
      }
      .fp-rank-section-title {
        font-size: 1.22rem;
      }
      .fp-rank-section-copy {
        font-size: 0.9rem;
      }
    }

    /* NEWS */
    .fp-news-section {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .fp-news-shell {
      display: grid;
      grid-template-columns: minmax(220px, 300px) 1fr;
      gap: 0.7rem;
      align-items: stretch;
      min-height: 360px;
    }
    .fp-news-menu {
      display: grid;
      grid-auto-rows: minmax(78px, 1fr);
      gap: 0.42rem;
      max-height: 360px;
      overflow-y: auto;
      padding-right: 0.18rem;
    }
    .fp-news-menu-item {
      display: flex;
      flex-direction: column;
      gap: 0.18rem;
      text-align: left;
      padding: 0.55rem 0.62rem;
      cursor: pointer;
      border: 1px solid rgba(220, 38, 38, 0.2);
      border-radius: 0.7rem;
      background: linear-gradient(160deg, rgba(35, 20, 20, 0.45), rgba(22, 22, 26, 0.85));
      color: #f4f4f5;
      transition: border-color 140ms ease;
    }
    .fp-news-menu-item:hover {
      border-color: rgba(248, 113, 113, 0.45);
    }
    .fp-news-menu-item.is-active {
      border-color: rgba(248, 113, 113, 0.6);
      background: linear-gradient(160deg, rgba(75, 20, 20, 0.55), rgba(22, 22, 26, 0.9));
      box-shadow: 0 0 14px rgba(239, 68, 68, 0.2);
    }
    .fp-news-menu-date {
      font-size: 0.66rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fca5a5;
      font-weight: 700;
    }
    .fp-news-menu-title {
      font-size: 0.82rem;
      line-height: 1.35;
      color: #fef2f2;
      font-weight: 700;
    }
    .fp-news-menu-source {
      font-size: 0.62rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #a1a1aa;
      font-weight: 700;
    }
    .fp-news-detail {
      display: flex;
      flex-direction: column;
      padding: 0.95rem 1.05rem;
      background: linear-gradient(160deg, rgba(35, 20, 20, 0.45), rgba(22, 22, 26, 0.88));
      border: 1px solid rgba(220, 38, 38, 0.24);
      border-radius: 0.85rem;
    }
    .fp-news-date {
      margin: 0 0 0.3rem;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fca5a5;
      font-weight: 700;
    }
    .fp-news-detail h3 {
      margin: 0 0 0.4rem;
      font-size: 1.04rem;
      line-height: 1.3;
      color: #fef2f2;
      font-weight: 800;
    }
    .fp-news-detail p {
      margin: 0;
      color: #d4d4d8;
      line-height: 1.55;
      font-size: 0.9rem;
    }
    .fp-news-detail-link {
      margin-top: auto;
      align-self: flex-start;
      display: inline-flex;
      padding: 0.42rem 0.78rem;
      font-size: 0.82rem;
      font-weight: 700;
      color: #fef2f2;
      text-decoration: none;
      border: 1px solid rgba(248, 113, 113, 0.45);
      border-radius: 999px;
      background: linear-gradient(160deg, rgba(127, 29, 29, 0.7), rgba(24, 24, 27, 0.6));
    }
    @media (max-width: 760px) {
      .fp-news-shell { grid-template-columns: 1fr; }
      .fp-news-menu { max-height: 240px; }
    }

    /* FINAL CTA BANNER */
    .fp-final-cta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.2rem;
      background:
        radial-gradient(80% 130% at 100% 0%, rgba(220, 38, 38, 0.22), transparent 70%),
        linear-gradient(160deg, rgba(20, 20, 22, 0.95), rgba(40, 18, 18, 0.85));
      border: 1px solid rgba(220, 38, 38, 0.32);
      border-radius: 1rem;
      box-shadow: 0 0 18px rgba(220, 38, 38, 0.14);
    }
    .fp-final-cta-eyebrow {
      margin: 0;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 800;
      color: #fca5a5;
    }
    .fp-final-cta-title {
      margin: 0.18rem 0 0;
      font-size: clamp(0.98rem, 2vw, 1.18rem);
      font-weight: 800;
      color: #fef2f2;
      max-width: 48ch;
      line-height: 1.35;
    }
    @media (max-width: 760px) {
      .fp-final-cta {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.7rem;
      }
    }

    /* EMPTY STATE */
    .fp-empty-state {
      display: grid;
      gap: 0.55rem;
      padding: 1.1rem 1.2rem;
      background: linear-gradient(150deg, rgba(22, 22, 26, 0.92), rgba(36, 36, 42, 0.78));
      border: 1px solid rgba(113, 113, 122, 0.42);
      border-radius: 0.9rem;
      color: #d4d4d8;
      line-height: 1.55;
    }
    .fp-empty-state strong {
      color: #fef2f2;
      font-size: 1rem;
    }
    .fp-empty-debug {
      display: block;
      max-width: 100%;
      overflow-wrap: anywhere;
      font-size: 0.8rem;
      color: #fca5a5;
      background: rgba(20, 20, 22, 0.72);
      border: 1px solid rgba(220, 38, 38, 0.22);
