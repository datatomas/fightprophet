  <script define:vars={{ newsItems }}>
    const newsList = Array.isArray(newsItems) ? newsItems : [];
    const byId = Object.fromEntries(newsList.map((item) => [item.id, item]));
    const menu = document.getElementById('fp-news-menu');
    const dateEl = document.getElementById('fp-news-detail-date');
    const titleEl = document.getElementById('fp-news-detail-title');
    const descEl = document.getElementById('fp-news-detail-desc');
    const linkEl = document.getElementById('fp-news-detail-link');

    function renderNews(newsId) {
      const item = byId[newsId];
      if (!item || !dateEl || !titleEl || !descEl || !linkEl) return;
      dateEl.textContent = item.datePublished || '';
      titleEl.textContent = item.title || '';
      descEl.textContent = item.description || '';
      linkEl.href = item.url || '#';
      linkEl.style.display = item.url ? 'inline-flex' : 'none';

      menu?.querySelectorAll('.fp-news-menu-item').forEach((btn) => {
        btn.classList.toggle('is-active', btn.getAttribute('data-news-id') === newsId);
      });
    }

    menu?.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const button = target.closest('.fp-news-menu-item');
      if (!button) return;
      renderNews(button.getAttribute('data-news-id') || '');
    });
  </script>

