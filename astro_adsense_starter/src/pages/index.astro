    // Read priority: ?lang query → fp_lang cookie (parent-domain shared with the app) → localStorage → en
    function readLangCookie() {
      const prefix = FP_LANG_KEY + '=';
      const parts = (document.cookie || '').split(';');
      for (const raw of parts) {
        const c = raw.trim();
        if (c.startsWith(prefix)) {
          try { return decodeURIComponent(c.slice(prefix.length)); } catch { return c.slice(prefix.length); }
        }
      }
      return '';
    }

    function applyLanguage(lang, opts) {
      const selected = translations[lang] ? lang : 'en';
      const pack = translations[selected];
      Object.entries(keyToId).forEach(([key, id]) => {
        const el = document.getElementById(id);
        if (el && typeof pack[key] === 'string') el.textContent = pack[key];
      });
      const rankSearch = document.getElementById('i18n-rank-search');
      if (rankSearch && typeof pack.rankSearchPlaceholder === 'string') {
        rankSearch.setAttribute('placeholder', pack.rankSearchPlaceholder);
      }
      document.documentElement.lang = selected;
      // Persistence + button active state are owned by BaseLayout — only re-broadcast
      // when this script is the one driving the change (a click on the home page).
      if (opts && opts.broadcast) {
        window.dispatchEvent(new CustomEvent('fp-lang-change', { detail: { lang: selected } }));
      }
    }

    const queryLang = (new URLSearchParams(window.location.search).get('lang') || '').toLowerCase();
    const cookieLang = (readLangCookie() || '').toLowerCase();
    const localLang = (localStorage.getItem(FP_LANG_KEY) || '').toLowerCase();
    const initialLang = translations[queryLang] ? queryLang
      : translations[cookieLang] ? cookieLang
      : translations[localLang] ? localLang
      : 'en';
    applyLanguage(initialLang);

    // The rail buttons are also bound by BaseLayout (which persists). We just need
    // to re-render the home content whenever language changes anywhere on the page.
    window.addEventListener('fp-lang-change', (event) => {
      const detail = event && event.detail ? event.detail : null;
      const lang = detail && detail.lang ? detail.lang : 'en';
      applyLanguage(lang);
    });
  </script>

