---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import FighterCard from '../components/FighterCard.astro';
import { runtimeEnvFromLocals } from '../lib/country-master';
import { getAllRankedFighterCards, groupRankedFightersByDivision } from '../lib/champions';

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.fightprophet.com';
const subscribeEndpoint = import.meta.env.PUBLIC_SUBSCRIBE_ENDPOINT || '';
const withPage = (slug: string) => `${appUrl}${appUrl.includes('?') ? '&' : '?'}page=${encodeURIComponent(slug)}`;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://fightprophet.com').replace(/\/$/, '');
const rankingsAppUrl = withPage('rankings');

const allRankedFighters = await getAllRankedFighterCards(runtimeEnvFromLocals(Astro.locals));
const rankedDivisions = groupRankedFightersByDivision(allRankedFighters);
const totalRankedFighters = allRankedFighters.length;
interface NewsItem {
  id: string;
  title: string;
  description: string;
  datePublished: string;
  url: string;
  source: string;
}

const MMA_FEEDS = [
  { name: 'MMA Fighting', url: 'https://www.mmafighting.com/rss/index.xml' },
  { name: 'ESPN MMA', url: 'https://www.espn.com/espn/rss/mma/news' },
];

function stripHtml(input: string): string {
  return input
    .replace(/<!\[CDATA\[|\]\]>/g, '')
    .replace(/<[^>]*>/g, ' ')
    .replace(/&nbsp;/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function toIsoDate(input: string): string {
  const parsed = new Date(input);
  if (Number.isNaN(parsed.getTime())) return new Date().toISOString().slice(0, 10);
  return parsed.toISOString().slice(0, 10);
}

function slugify(input: string): string {
  return input
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 72) || 'mma-news';
}

function parseRssItems(xml: string, source: string, limit = 12): NewsItem[] {
  const itemMatches = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)].slice(0, limit);

  return itemMatches
    .map((match, idx) => {
      const itemXml = match[1] || '';
      const titleRaw = itemXml.match(/<title>([\s\S]*?)<\/title>/i)?.[1] || '';
      const descRaw = itemXml.match(/<description>([\s\S]*?)<\/description>/i)?.[1] || '';
      const linkRaw = itemXml.match(/<link>([\s\S]*?)<\/link>/i)?.[1] || '';
      const dateRaw = itemXml.match(/<pubDate>([\s\S]*?)<\/pubDate>/i)?.[1] || '';

      const title = stripHtml(titleRaw) || 'MMA News Update';
      const description = stripHtml(descRaw) || 'Latest MMA world update.';
      const url = stripHtml(linkRaw) || siteUrl;
      const datePublished = toIsoDate(stripHtml(dateRaw));

      return {
        id: `${slugify(title)}-${idx}`,
        title,
        description,
        datePublished,
        url,
        source,
      };
    })
    .filter((item) => !!item.title && !!item.url);
}

async function getMmaNewsItems(): Promise<NewsItem[]> {
  const allItems: NewsItem[] = [];
  const perFeed = 6;

  for (const feed of MMA_FEEDS) {
    try {
      const response = await fetch(feed.url, {
        headers: {
          'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36',
        },
      });
      if (!response.ok) continue;
      const xml = await response.text();
      allItems.push(...parseRssItems(xml, feed.name, perFeed));
    } catch {
      continue;
    }
  }

  const deduped = allItems
    .filter((item, index, arr) => arr.findIndex((other) => other.url === item.url) === index)
    .sort((a, b) => b.datePublished.localeCompare(a.datePublished))
    .slice(0, 12);

  if (deduped.length > 0) {
    return deduped;
  }

  return [
    {
      id: 'mma-fallback-1',
      title: 'MMA headlines are updating — source temporarily unavailable',
      description: 'Latest MMA world feed is temporarily unavailable. Please check back shortly for refreshed fight news.',
      datePublished: new Date().toISOString().slice(0, 10),
      url: 'https://www.mmafighting.com',
      source: 'MMA News',
    },
    {
      id: 'mma-fallback-2',
      title: 'Fight cards, rankings, and roster movement remain in focus',
      description: 'Coverage includes event announcements, divisional developments, and key matchup updates across MMA.',
      datePublished: new Date().toISOString().slice(0, 10),
      url: 'https://www.mmafighting.com/latest-news',
      source: 'MMA News',
    },
  ];
}

const newsItems = await getMmaNewsItems();

const initialNews = newsItems[0];

const newsStructuredData = newsItems.map((item) => ({
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: item.title,
  description: item.description,
  datePublished: item.datePublished,
  dateModified: item.datePublished,
  author: {
    '@type': 'Organization',
    name: 'Fight Prophet',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Fight Prophet',
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/branding/fightprophet_logo_white.png`,
    },
  },
  mainEntityOfPage: `${siteUrl}/#news-${item.id}`,
  url: `${siteUrl}/#news-${item.id}`,
}));
---

<BaseLayout title="Fight Prophet | Home" description="MMA AI and ML-powered fight analytics, predictions, fighter rankings, and model insights to help fight fans bet smarter.">
  <section class="fp-hero">
    <div class="fp-hero-shell">
      <div class="fp-hero-top-controls">
        <div class="fp-lang-switch" aria-label="Language selector">
          <button type="button" class="fp-lang-btn" data-lang="es" title="Español">🇨🇴</button>
          <button type="button" class="fp-lang-btn" data-lang="pt" title="Português">🇧🇷</button>
          <button type="button" class="fp-lang-btn" data-lang="en" title="English">🇺🇸</button>
        </div>
        <img class="fp-hero-mark" src="/branding/fightprophet_ear_white.png" alt="Fight Prophet mark" loading="lazy" />
      </div>
      <div class="fp-hero-content">
        <div class="fp-hero-brand">
          <img src="/branding/fightprophet_logo_white.png" alt="FightProphet.com" class="fp-hero-logo" loading="lazy" />
          <p class="fp-hero-subtitle" id="i18n-topbar-subtitle">The fight data already knows who's getting smashed. We just highlight it.</p>
        </div>
        <div class="fp-hero-main">
          <div class="fp-hero-pills" aria-label="Highlights">
            <span class="fp-hero-pill" id="i18n-pill-1">AI-powered fight previews</span>
            <span class="fp-hero-pill" id="i18n-pill-2">Model confidence</span>
            <span class="fp-hero-pill" id="i18n-pill-3">Risk-aware decision support</span>
          </div>
          <p class="fp-hero-note" id="i18n-hero-note">For information and education only — never financial advice.</p>
          <div class="fp-hero-actions">
            <a class="fp-btn fp-btn-primary" href={appUrl} target="_blank" rel="noopener noreferrer" id="i18n-open-app-main">Open Fight Prophet App</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="fp-section-head">
      <div>
        <p class="fp-section-label">Ranked Fighters Wall</p>
        <p class="fp-section-intro fp-section-intro-tight">
          Live ranking cards for every active fighter across {rankedDivisions.length || 0} divisions{totalRankedFighters ? ` (${totalRankedFighters} cards)` : ''}. Pick any division to jump straight to the cards and open one for the full profile.
        </p>
      </div>
      <a class="fp-btn fp-btn-secondary" href="/rankings/">Full rankings</a>
    </div>
    {rankedDivisions.length > 0 ? (
      <>
        <nav class="fp-division-jump" aria-label="Jump to division">
          {rankedDivisions.map((g) => (
            <a class="fp-division-pill" href={`#division-${g.weight_class.replace(/[^a-zA-Z0-9]+/g, '-').toLowerCase()}`}>
              {g.weight_class}
              <span class="fp-division-pill-count">{g.fighters.length}</span>
            </a>
          ))}
        </nav>
        {rankedDivisions.map((group) => (
          <div class="fp-division-block" id={`division-${group.weight_class.replace(/[^a-zA-Z0-9]+/g, '-').toLowerCase()}`}>
            <div class="fp-division-header">
              <h3 class="fp-division-title">{group.weight_class}</h3>
              <span class="fp-division-count">{group.fighters.length} ranked</span>
            </div>
            <div class="fp-champ-grid">
              {group.fighters.map((c) => (
                <FighterCard
                  name={c.name}
                  fighterId={c.fighter_id}
                  country={c.country}
                  weightClass={c.weight_class}
                  isChampion={c.is_champion ?? false}
                  finishRate={c.finish_rate ?? null}
                  subRate={c.sub_rate ?? null}
                  winStreak={c.win_streak ?? null}
                  lossStreak={c.loss_streak ?? null}
                  wins={c.wins ?? null}
                  losses={c.losses ?? null}
                  appUrl={appUrl}
                />
              ))}
            </div>
          </div>
        ))}
      </>
    ) : (
      <div class="fp-empty-state">
        <strong>Ranked fighter cards are temporarily unavailable on the homepage.</strong>
        <span>
          The live rankings wall refreshes from the Monday ETL feed. If it is empty right now, the site feed has not landed yet or is refreshing.
        </span>
      </div>
    )}
  </section>

  <section>
    <div class="fp-section-head">
      <div>
        <p class="fp-section-label" id="i18n-start-exploring">Sections</p>
        <p class="fp-section-intro fp-section-intro-tight">
          Keep these links on the site for crawling and indexing, then open the app from each section page when you want the live interactive view.
        </p>
      </div>
    </div>
    <div class="fp-cta-grid">
      <a class="fp-cta-card" href="/predictions/"><strong id="i18n-cta-1-title">Predictions</strong><span id="i18n-cta-1-desc">Compare model vs market probability</span></a>
      <a class="fp-cta-card" href="/fight-lab/"><strong id="i18n-cta-2-title">Fight Lab</strong><span id="i18n-cta-2-desc">Historical picks + model metrics</span></a>
      <a class="fp-cta-card" href="/rankings/"><strong id="i18n-cta-3-title">Fighter Rankings</strong><span id="i18n-cta-3-desc">Divisional performance and risers</span></a>
      <a class="fp-cta-card" href="/belt-holders/"><strong id="i18n-cta-4-title">Belt Holders</strong><span id="i18n-cta-4-desc">Champions and title history</span></a>
      <a class="fp-cta-card" href="/fighter-card/"><strong id="i18n-cta-5-title">Fighter Cards</strong><span id="i18n-cta-5-desc">Open a data card for any fighter</span></a>
      <a class="fp-cta-card" href="/events-history/"><strong id="i18n-cta-6-title">Events History</strong><span id="i18n-cta-6-desc">Past UFC cards and results</span></a>
    </div>
  </section>

  <section>
    <p class="fp-section-label" id="i18n-latest-news">Latest news</p>
    <div class="fp-news-shell">
      <nav class="fp-news-menu" id="fp-news-menu" aria-label="News menu">
        {newsItems.map((item, idx) => (
          <button
            type="button"
            class={`fp-news-menu-item${idx === 0 ? ' is-active' : ''}`}
            data-news-id={item.id}
            id={`news-${item.id}`}
          >
            <span class="fp-news-menu-date">{item.datePublished}</span>
            <span class="fp-news-menu-title">{item.title}</span>
            <span class="fp-news-menu-source">{item.source}</span>
          </button>
        ))}
      </nav>
      <article class="fp-news-detail" id="fp-news-detail">
        <p class="fp-news-date" id="fp-news-detail-date">{initialNews.datePublished}</p>
        <h2 id="fp-news-detail-title">{initialNews.title}</h2>
        <p id="fp-news-detail-desc">{initialNews.description}</p>
        <a id="fp-news-detail-link" class="fp-news-detail-link" href={initialNews.url || appUrl} target="_blank" rel="noopener noreferrer">
          Open related page
        </a>
      </article>
    </div>
  </section>

  <AdSlot slot="1234567890" />

  <section>
    <p class="fp-section-label" id="i18n-why-open-source">Why open source</p>
    <div class="fp-story">
      <h2 class="fp-story-title" id="i18n-story-title">Built by fans, improved by community</h2>
      <p id="i18n-story-text">Fight Prophet is open source. Community members can contribute by reporting data issues, suggesting features, improving model diagnostics, and helping maintain manual override datasets (like title vacates and fighter countries).</p>
    </div>
  </section>

  <section class="fp-subscribe-wrap">
    <div class="fp-subscribe-logo-wrap">
      <img src="/branding/fightprophet_logo_white.png" alt="Fight Prophet" class="fp-subscribe-logo" loading="lazy" />
    </div>
    <div>
      <h2 id="i18n-subscribe-title">Subscribe for updates</h2>
      <p id="i18n-subscribe-copy">Get release notes, feature updates, and major model changes.</p>
      <form id="subscribe-form" class="fp-subscribe-form">
        <label for="subscribe-email" id="i18n-email-label">Email</label>
        <div class="fp-subscribe-row">
          <input id="subscribe-email" name="email" type="email" autocomplete="email" required />
          <button type="submit" id="i18n-subscribe-btn">Subscribe</button>
        </div>
      </form>
      <p id="subscribe-status" aria-live="polite"></p>
    </div>
  </section>

  <script define:vars={{ subscribeEndpoint }}>
    const form = document.getElementById('subscribe-form');
    const status = document.getElementById('subscribe-status');

    function getStatusText(key, fallback) {
      const pack = window.__fpLangStatus || {};
      return pack[key] || fallback;
    }

    if (form && status) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const formData = new FormData(form);
        const email = String(formData.get('email') || '').trim();

        if (!email) {
          status.textContent = getStatusText('invalid', 'Please enter a valid email.');
          return;
        }

        if (!subscribeEndpoint) {
          status.textContent = getStatusText('noEndpoint', 'Subscription endpoint is not configured yet.');
          return;
        }

        status.textContent = getStatusText('submitting', 'Submitting...');

        try {
          const response = await fetch(subscribeEndpoint, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ email, source: 'fightprophet-astro' }),
          });

          if (!response.ok) {
            throw new Error('Request failed');
          }

          form.reset();
          status.textContent = getStatusText('success', 'Thanks. You are subscribed.');
        } catch {
          status.textContent = getStatusText('failed', 'Subscription failed. Please try again.');
        }
      });
    }
  </script>

