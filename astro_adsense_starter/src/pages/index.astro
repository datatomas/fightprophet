---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import FighterCard from '../components/FighterCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { runtimeEnvFromLocals, getCountryMasterIndex } from '../lib/country-master';
import { getAllRankedFighterCards, getHomepageGoatCards, getHomepageRankingsDebug, groupRankedFightersByDivision } from '../lib/champions';

const rankingsAnchorUrl = '/#fp-rankings';
const predictionsPageUrl = '/predictions/';

const runtimeEnv = runtimeEnvFromLocals(Astro.locals);
Astro.locals.countryMaster = await getCountryMasterIndex(runtimeEnv);
const allRankedFighters = await getAllRankedFighterCards(runtimeEnv);
const homepageGoats = await getHomepageGoatCards(runtimeEnv);
const homepageRankingsDebug = getHomepageRankingsDebug(runtimeEnv);
const rankedDivisions = groupRankedFightersByDivision(allRankedFighters);
const totalRankedFighters = allRankedFighters.length;
const goatPreviewLimit = 10;
const topGoats = homepageGoats.slice(0, goatPreviewLimit);

function slugify(input: string): string {
  return input
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 72) || 'mma-news';
}

function rankTierFor(index: number): string {
  if (index === 0) return 'king';
  return 'goat';
}

interface RankingDeck {
  slug: string;
  label: string;
  title: string;
  note: string;
  countLabel: string;
  fighters: typeof topGoats;
}

interface RankingDeckExt extends RankingDeck {
  rerank: boolean;
}

const rankingDecks: RankingDeckExt[] = [
  ...(topGoats.length > 0
      ? [{
        slug: 'goat-list',
        label: 'GOAT List',
        title: 'GOAT List',
        note: 'All-time global ladder: every UFC weight class feeds one GOAT score, sorted by global rank and global points.',
        countLabel: `${topGoats.length} featured fighters`,
        fighters: topGoats,
        rerank: false,
      }]
    : []),
  ...rankedDivisions
    .filter((group) => group.fighters.length > 0)
    .map((group) => ({
      slug: `division-${slugify(group.weight_class || 'division')}`,
      label: group.weight_class,
      title: group.weight_class,
      note: `${group.weight_class} ladder: the same scoring engine, scoped to one weight class so the division king is obvious.`,
      countLabel: `${group.fighters.length} ranked fighters`,
      fighters: group.fighters,
      rerank: true,
    })),
];

const initialDeckSlug = rankingDecks[0]?.slug || '';
const hasRankingDecks = rankingDecks.length > 0;

const analysisNotes = [
  {
    title: 'Ranking signal, not nostalgia',
    copy: `${totalRankedFighters.toLocaleString()} ranked fighter records feed the public board. The score weights result quality, opponent strength, title stakes, finishes, streaks, inactivity, and loss penalties so readers can inspect the same logic across divisions.`,
  },
  {
    title: 'Prediction signal, not betting advice',
    copy: 'Upcoming-fight probabilities are treated as model estimates. A useful pick needs both probability and context: missing opponent history, short-notice changes, stale lines, and low model agreement all reduce confidence.',
  },
  {
    title: 'Audit trail for every model claim',
    copy: 'Fight Lab keeps historical predictions next to actual outcomes, closing-market context, and calibration metrics. That makes the model falsifiable instead of just promotional.',
  },
  {
    title: 'Data needs human cleanup',
    copy: 'Country normalization, activity status, title vacancies, and unusual fight records can require manual review. Those overrides keep the public cards readable when source data is incomplete.',
  },
];
---

<BaseLayout title="Fight Prophet | MMA Predictions, Rankings & Analytics" description="MMA AI and ML-powered fight predictions, fighter rankings, and model insights. Built for fans who want clear data without the noise.">
  <div class="fp-home-main">

    <!-- HERO -->
    <header class="fp-hero">
      <div class="fp-hero-brand">
        <img src="/branding/fightprophet_logo_white.png" alt="Fight Prophet" class="fp-hero-logo" loading="eager" />
      </div>
      <p class="fp-hero-eyebrow" id="i18n-hero-eyebrow">The Home of MMA Intelligence</p>
      <h1 class="fp-hero-title" id="i18n-hero-title">Who is the greatest fighter of all time?</h1>
      <p class="fp-hero-sub" id="i18n-hero-sub">Fight Prophet runs an AI &amp; ML-powered fight-by-fight ranking engine: every UFC result earns or burns points, then the board splits into all-time, active, and weight-class GOAT lists. Predictions and rankings, built from data.</p>
      <div class="fp-hero-ctas">
        <a class="fp-cta-primary" href={predictionsPageUrl}>
          <span id="i18n-cta-open-app">See predictions</span>
          <span class="fp-cta-arrow" aria-hidden="true">→</span>
        </a>
        <a class="fp-cta-ghost" href={rankingsAnchorUrl} id="i18n-cta-browse">Browse rankings ↓</a>
      </div>
      <p class="fp-hero-note" id="i18n-hero-note">For information and education only — not financial advice. Our predictions and estimates can be wrong.</p>
    </header>

    <!-- RANKINGS CENTERPIECE -->
    <section id="fp-rankings" class="fp-rank-section">
      <div class="fp-rank-section-head">
        <div>
          <p class="fp-section-label" id="i18n-rank-label">GOAT Board</p>
          <h2 class="fp-rank-section-title" id="i18n-rank-title">All-time, active, and division GOAT rankings</h2>
          <p class="fp-rank-section-copy" id="i18n-rank-copy">No nostalgia ballot. No barbershop argument. The board is rebuilt from fight results, opponent quality, finishes, titles, streaks, inactivity, and losses.</p>
        </div>
      </div>

      {hasRankingDecks ? (
        <div class="fp-rank-wall" data-initial-division={initialDeckSlug} data-status-filter="all">
          <div class="fp-ranking-scoreboard" aria-label="How Fight Prophet rankings work">
            <div class="fp-ranking-scoreboard-lead">
              <span class="fp-score-stamp" id="i18n-score-stamp">Ranking Engine</span>
              <h3 id="i18n-score-title">Points are won in the cage, then boosted for legacy.</h3>
            </div>
            <div class="fp-score-rules">
              <div class="fp-score-rule">
                <strong id="i18n-score-rule-1-title">All-time GOAT</strong>
                <span id="i18n-score-rule-1-copy">Global points compare every UFC fighter across every weight class.</span>
              </div>
              <div class="fp-score-rule">
                <strong id="i18n-score-rule-2-title">Active GOAT</strong>
                <span id="i18n-score-rule-2-copy">The live race without retired or long-inactive names.</span>
              </div>
              <div class="fp-score-rule">
                <strong id="i18n-score-rule-3-title">By weight</strong>
                <span id="i18n-score-rule-3-copy">Division tabs reveal the king of each class using the same point logic.</span>
              </div>
              <div class="fp-score-rule">
                <strong id="i18n-score-rule-4-title">How points move</strong>
                <span id="i18n-score-rule-4-copy">Elite wins, finishes, title stakes, bonuses, streaks, and defenses matter. Losses hurt.</span>
              </div>
            </div>
          </div>

          <div class="fp-rank-control-row">
            <label class="fp-rank-search">
              <span id="i18n-rank-search-label">Search</span>
              <input id="i18n-rank-search" type="search" data-rank-search placeholder="Search fighter, country, division" autocomplete="off" />
            </label>

            <label class="fp-rank-select-label">
              <span>Board</span>
              <select data-division-select aria-label="Ranking category">
                {rankingDecks.map((deck, idx) => (
                  <option value={deck.slug} selected={idx === 0}>
                    {deck.label} · {deck.fighters.length}
                  </option>
                ))}
              </select>
            </label>

            <label class="fp-rank-select-label">
              <span>Status</span>
              <select data-status-select aria-label="Fighter status filter">
                <option value="all" selected id="i18n-status-all">All-time</option>
                <option value="active" id="i18n-status-active">Active</option>
                <option value="inactive" id="i18n-status-inactive">Inactive</option>
              </select>
            </label>
          </div>

          <div class="fp-division-panels">
            {rankingDecks.map((deck, idx) => (
              <section
                class={`fp-division-block${idx === 0 ? ' is-active' : ''}`}
                data-division-panel={deck.slug}
                data-rerank={deck.rerank ? 'true' : 'false'}
                data-deck-kind={deck.slug === 'goat-list' ? 'goat' : 'division'}
                hidden={idx !== 0}
              >
                <div class="fp-division-header">
                  <h3 class="fp-division-title">{deck.title}</h3>
                  <span class="fp-division-count" data-deck-count data-original-count={deck.countLabel}>{deck.countLabel}</span>
                </div>
                <p class="fp-division-description">{deck.note}</p>
                <div class="fp-card-grid">
                  {deck.fighters.map((c, cardIdx) => (
                    <div
                      class={`fp-card-shell is-rank-${rankTierFor(cardIdx)}`}
                      style={`--card-index:${Math.min(cardIdx, 10)};`}
                      data-rank-tier={rankTierFor(cardIdx)}
                      data-fighter-status={c.fighter_status || 'active'}
                      data-global-rank={c.global_rank ?? ''}
                      data-division-rank={c.rank ?? ''}
                      data-search-text={`${c.name || ''} ${c.country || ''} ${c.weight_class || ''}`.toLowerCase()}
                    >
                      <span class="fp-rank-tier-label" aria-hidden="true" hidden={cardIdx !== 0}>THE GOAT</span>
                      <div class="fp-card-holder">
                        <FighterCard
                          name={c.name}
                          fighterId={c.fighter_id}
                          country={c.country}
                          weightClass={c.weight_class}
                          isChampion={c.is_champion ?? false}
                          finishRate={c.finish_rate ?? null}
                          subRate={c.sub_rate ?? null}
                          winStreak={c.win_streak ?? null}
                          lossStreak={c.loss_streak ?? null}
                          wins={c.wins ?? null}
                          losses={c.losses ?? null}
                          points={deck.slug === 'goat-list' ? c.global_points ?? c.points ?? null : c.points ?? c.global_points ?? null}
                          globalRank={c.global_rank ?? null}
                          divisionRank={c.rank ?? null}
                          compact={true}
                        />
                      </div>
                    </div>
                  ))}
                </div>
                <p class="fp-division-empty" hidden>No fighters match this filter.</p>
              </section>
            ))}
          </div>

        </div>
      ) : (
        <div class="fp-empty-state">
          <strong>Rankings are temporarily unavailable.</strong>
          <span>The live rankings refresh from the Monday ETL feed. If this is empty right now, the site feed has not landed yet.</span>
          <code class="fp-empty-debug">
            Azure account: {homepageRankingsDebug.hasAzureAccount ? 'yes' : 'no'} · key: {homepageRankingsDebug.hasAzureKey ? 'yes' : 'no'} · blob: {homepageRankingsDebug.blobPath}
          </code>
          <a class="fp-cta-primary" href={rankingsAnchorUrl}>Try rankings again →</a>
        </div>
      )}
    </section>

    <!-- SECTIONS GRID -->
    <section class="fp-sections">
      <div class="fp-sections-head">
        <p class="fp-section-label" id="i18n-explore-label">Explore</p>
        <h2 class="fp-sections-title" id="i18n-explore-title">Everything Fight Prophet has</h2>
      </div>
      <div class="fp-cta-grid">
        <a class="fp-section-card" href="/predictions/">
          <strong id="i18n-cta-1-title">Predictions</strong>
          <span id="i18n-cta-1-desc">Compare model vs market probability</span>
        </a>
        <a class="fp-section-card" href="/fight-lab/">
          <strong id="i18n-cta-2-title">Fight Lab</strong>
          <span id="i18n-cta-2-desc">Historical picks + model metrics</span>
        </a>
        <a class="fp-section-card" href="/rankings/">
          <strong id="i18n-cta-3-title">Fighter Rankings</strong>
          <span id="i18n-cta-3-desc">Every division in one place</span>
        </a>
        <a class="fp-section-card" href="/belt-holders/">
          <strong id="i18n-cta-4-title">Belt Holders</strong>
          <span id="i18n-cta-4-desc">Champions and title history</span>
        </a>
        <a class="fp-section-card" href="/fighter-card/">
          <strong id="i18n-cta-5-title">Fighter Cards</strong>
          <span id="i18n-cta-5-desc">Open a data card for any fighter</span>
        </a>
        <a class="fp-section-card" href="/events-history/">
          <strong id="i18n-cta-6-title">Events History</strong>
          <span id="i18n-cta-6-desc">Past UFC cards and results</span>
        </a>
      </div>
    </section>

    <NewsletterSignup />

    <!-- ORIGINAL ANALYSIS NOTES -->
    <section class="fp-insight-section" aria-labelledby="fp-insight-title">
      <div class="fp-insight-head">
        <p class="fp-section-label" id="i18n-news-label">Model notes</p>
        <h2 id="fp-insight-title">How to read Fight Prophet without overreading it</h2>
        <p>
          These notes are original guidance for using the rankings and model outputs. They are
          written to make the data understandable, not to recycle fight news from other publishers.
        </p>
      </div>
      <div class="fp-insight-grid">
        {analysisNotes.map((note) => (
          <article class="fp-insight-card">
            <h3>{note.title}</h3>
            <p>{note.copy}</p>
          </article>
        ))}
      </div>
      <div class="fp-insight-links">
        <a href="/about/">How Fight Prophet works</a>
        <a href="/editorial-policy/">Editorial policy</a>
        <a href="/responsible-use/">Responsible use</a>
      </div>
    </section>

    <!-- FINAL CTA BANNER -->
    <section class="fp-final-cta">
      <div>
        <p class="fp-final-cta-eyebrow" id="i18n-final-eyebrow">Up next</p>
        <h2 class="fp-final-cta-title" id="i18n-final-title">Compare model picks vs. market for the upcoming fights.</h2>
      </div>
      <a class="fp-cta-primary" href={predictionsPageUrl}>
        <span id="i18n-final-cta">Predictions</span>
        <span class="fp-cta-arrow" aria-hidden="true">→</span>
      </a>
    </section>

    <AdSlot slot="1234567890" />
  </div>

  <script>
    const wall = document.querySelector('.fp-rank-wall');
    if (wall) {
      const divisionPills = Array.from(wall.querySelectorAll('.fp-division-pill'));
      const divisionPanels = Array.from(wall.querySelectorAll('.fp-division-block'));
      const panelHost = wall.querySelector('.fp-division-panels');
      const statusButtons = Array.from(wall.querySelectorAll('.fp-status-btn'));
      const divisionSelect = wall.querySelector('[data-division-select]');
      const statusSelect = wall.querySelector('[data-status-select]');
      const searchInput = wall.querySelector('[data-rank-search]');
      let activeSlug = wall.getAttribute('data-initial-division') || divisionPanels[0]?.getAttribute('data-division-panel') || '';
      let activeStatus = wall.getAttribute('data-status-filter') || 'all';
      let activeSearch = searchInput?.value?.trim().toLowerCase() || '';
      let cleanupTimer = 0;
      let filterFrame = 0;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      function activePanel() {
        return divisionPanels.find((panel) => panel.getAttribute('data-division-panel') === activeSlug) || null;
      }

      function visibleShells(panel) {
        if (!panel) return [];
        return Array.from(panel.querySelectorAll('.fp-card-shell')).filter((shell) => !shell.hidden);
      }

      function snapshotPanel(panel) {
        if (!panel || prefersReducedMotion.matches) return new Map();
        return new Map(visibleShells(panel).map((shell) => [shell, shell.getBoundingClientRect()]));
      }

      function animateReflow(panel, firstRects) {
        if (!panel || prefersReducedMotion.matches) return;
        visibleShells(panel).forEach((shell) => {
          const first = firstRects.get(shell);
          const last = shell.getBoundingClientRect();
          const dx = first ? first.left - last.left : 0;
          const dy = first ? first.top - last.top : 0;

          shell.classList.remove('is-filter-entering');
          if (!first) {
            shell.classList.add('is-filter-entering');
            window.setTimeout(() => shell.classList.remove('is-filter-entering'), 340);
            return;
          }
          if (Math.abs(dx) < 1 && Math.abs(dy) < 1) return;
          shell.animate(
            [
              { transform: `translate3d(${dx}px, ${dy}px, 0) rotate(-0.8deg)`, opacity: 0.82 },
              { transform: 'translate3d(0, 0, 0) rotate(0)', opacity: 1 },
            ],
            {
              duration: 340,
              easing: 'cubic-bezier(0.2, 0.85, 0.25, 1)',
            },
          );
        });
      }

      function applyHierarchy(shell, visibleRank) {
        const isKing = visibleRank === 1;
        shell.classList.toggle('is-rank-king', isKing);
        shell.classList.toggle('is-rank-goat', !isKing);
        shell.setAttribute('data-rank-tier', isKing ? 'king' : 'goat');
        shell.setAttribute('data-board-slot', String(visibleRank));
        const label = shell.querySelector('.fp-rank-tier-label');
        if (label) {
          label.hidden = !isKing;
          label.textContent = 'THE GOAT';
        }
      }

      function ensureRatingSub(shell) {
        const rating = shell.querySelector('.fp-card-rating');
        if (!rating) return null;
        let sub = rating.querySelector('.fp-card-rating-sub');
        if (!sub) {
          sub = document.createElement('span');
          sub.className = 'fp-card-rating-sub';
          rating.appendChild(sub);
        }
        return sub;
      }

      function applyStatusFilter(status, opts = {}) {
        const panelBefore = opts.animate ? activePanel() : null;
        const firstRects = panelBefore ? snapshotPanel(panelBefore) : null;
        activeStatus = status || 'all';
        activeSearch = searchInput?.value?.trim().toLowerCase() || '';
        wall.setAttribute('data-status-filter', activeStatus);

        statusButtons.forEach((btn) => {
          const isOn = btn.getAttribute('data-status-target') === activeStatus;
          btn.classList.toggle('is-active', isOn);
          btn.setAttribute('aria-pressed', isOn ? 'true' : 'false');
        });
        if (statusSelect) statusSelect.value = activeStatus;

        divisionPanels.forEach((panel) => {
          const shells = Array.from(panel.querySelectorAll('.fp-card-shell'));
          const rerank = panel.getAttribute('data-rerank') === 'true';
          const deckKind = panel.getAttribute('data-deck-kind') || 'division';
          let visibleCount = 0;

          shells.forEach((shell) => {
            const shellStatus = (shell.getAttribute('data-fighter-status') || 'active').toLowerCase();
            const searchable = (shell.getAttribute('data-search-text') || '').toLowerCase();
            const matchesStatus = activeStatus === 'all' || shellStatus === activeStatus;
            const matchesSearch = !activeSearch || searchable.includes(activeSearch);
            const matches = matchesStatus && matchesSearch;
            shell.hidden = !matches;
            if (!matches) {
              const label = shell.querySelector('.fp-rank-tier-label');
              if (label) label.hidden = true;
              return;
            }
            visibleCount += 1;
            applyHierarchy(shell, visibleCount);
            const num = shell.querySelector('.fp-card-rating-num');
            const pos = shell.querySelector('.fp-card-rating-pos');
            const sub = ensureRatingSub(shell);
            if (sub && !shell.dataset.originalSubText && sub.textContent) {
              shell.dataset.originalSubText = sub.textContent.trim();
            }
            const originalSubText = shell.dataset.originalSubText || '';
            const globalRank = Number.parseInt(shell.getAttribute('data-global-rank') || '', 10);
            const divisionRank = Number.parseInt(shell.getAttribute('data-division-rank') || '', 10);
            const subPrefix = originalSubText.replace(/#\d+\s*$/, '').trim();

            if (deckKind === 'goat') {
              if (num && Number.isFinite(globalRank)) {
                num.textContent = activeStatus === 'all' ? `#${globalRank}` : `#${visibleCount}`;
              }
              if (pos) {
                pos.textContent = activeStatus === 'all'
                  ? 'P4P'
                  : activeStatus === 'active'
                    ? 'ACTIVE'
                    : 'INACTIVE';
              }
              if (sub) {
                if (activeStatus === 'all' || !Number.isFinite(globalRank)) {
                  sub.textContent = '';
                  sub.hidden = true;
                } else {
                  sub.textContent = `P4P #${globalRank}`;
                  sub.hidden = false;
                }
              }
              return;
            }

            if (sub && Number.isFinite(divisionRank)) {
              const divisionVisibleRank = activeStatus === 'all' || !rerank ? divisionRank : visibleCount;
              if (num) {
                num.textContent = `#${divisionVisibleRank}`;
              }
              if (pos) {
                pos.textContent = subPrefix || 'DIV';
              }
              if (Number.isFinite(globalRank)) {
                sub.textContent = `P4P #${globalRank}`;
                sub.hidden = false;
              } else {
                sub.textContent = '';
                sub.hidden = true;
              }
            } else {
              if (num && Number.isFinite(globalRank)) {
                num.textContent = `#${globalRank}`;
              }
              if (pos) {
                pos.textContent = 'P4P';
              }
              if (sub) {
                sub.textContent = '';
                sub.hidden = true;
              }
            }
          });

          const deckCountEl = panel.querySelector('[data-deck-count]');
          if (deckCountEl) {
            if (activeSearch) {
              deckCountEl.textContent = `${visibleCount} match${visibleCount === 1 ? '' : 'es'}`;
            } else if (activeStatus === 'all') {
              deckCountEl.textContent = deckCountEl.getAttribute('data-original-count') || `${visibleCount} fighters`;
            } else {
              const label = activeStatus === 'active' ? 'active fighter' : 'inactive fighter';
              deckCountEl.textContent = `${visibleCount} ${label}${visibleCount === 1 ? '' : 's'}`;
            }
          }
          const emptyEl = panel.querySelector('.fp-division-empty');
          if (emptyEl) emptyEl.hidden = visibleCount > 0;

        });

        if (panelBefore && firstRects) {
          requestAnimationFrame(() => animateReflow(panelBefore, firstRects));
        }
      }

      function syncPills(slug) {
        divisionPills.forEach((pill) => {
          const isActive = pill.getAttribute('data-division-target') === slug;
          pill.classList.toggle('is-active', isActive);
          pill.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
        if (divisionSelect) divisionSelect.value = slug;
      }

      function clearPanelState(panel) {
        panel.classList.remove('is-entering', 'is-leaving');
      }

      function setDivision(slug) {
        if (!slug) return;
        if (slug === activeSlug) return;

        const current = divisionPanels.find((panel) => panel.getAttribute('data-division-panel') === activeSlug);
        const next = divisionPanels.find((panel) => panel.getAttribute('data-division-panel') === slug);
        if (!next) return;

        activeSlug = slug;
        syncPills(slug);

        if (cleanupTimer) window.clearTimeout(cleanupTimer);

        const lockedHeight = Math.max(current?.offsetHeight || 0, next.offsetHeight || 0);
        if (panelHost && lockedHeight) panelHost.style.minHeight = `${lockedHeight}px`;

        divisionPanels.forEach((panel) => {
          if (panel !== current && panel !== next) {
            clearPanelState(panel);
            panel.classList.remove('is-active');
            panel.hidden = true;
          }
        });

        next.hidden = false;
        next.classList.add('is-active');
        clearPanelState(next);
        void next.offsetWidth;
        next.classList.add('is-entering');

        if (current && current !== next) {
          current.hidden = false;
          current.classList.add('is-active');
          clearPanelState(current);
          void current.offsetWidth;
          current.classList.add('is-leaving');
        }

        cleanupTimer = window.setTimeout(() => {
          if (current && current !== next) {
            clearPanelState(current);
            current.classList.remove('is-active');
            current.hidden = true;
          }
          clearPanelState(next);
          next.classList.add('is-active');
          panelHost?.style.removeProperty('min-height');
        }, 260);
      }

      syncPills(activeSlug);
      const initialPanel = divisionPanels.find((panel) => panel.getAttribute('data-division-panel') === activeSlug);
      if (initialPanel) {
        initialPanel.hidden = false;
        initialPanel.classList.add('is-active');
      }

      divisionPills.forEach((pill) => {
        pill.addEventListener('click', () => {
          const slug = pill.getAttribute('data-division-target') || '';
          setDivision(slug);
        });
      });

      statusButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-status-target') || 'all';
          if (target === activeStatus) return;
          applyStatusFilter(target, { animate: true });
        });
      });

      divisionSelect?.addEventListener('change', () => {
        setDivision(divisionSelect.value || '');
      });

      statusSelect?.addEventListener('change', () => {
        const target = statusSelect.value || 'all';
        if (target === activeStatus) return;
        applyStatusFilter(target, { animate: true });
      });

      searchInput?.addEventListener('input', () => {
        if (filterFrame) window.cancelAnimationFrame(filterFrame);
        filterFrame = window.requestAnimationFrame(() => {
          filterFrame = 0;
          applyStatusFilter(activeStatus, { animate: true });
        });
      });

      applyStatusFilter(activeStatus);
    }
  </script>

