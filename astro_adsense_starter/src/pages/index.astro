---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import FighterCard from '../components/FighterCard.astro';
import { buildAppPageUrl } from '../lib/app-url';
import { runtimeEnvFromLocals } from '../lib/country-master';
import { getAllRankedFighterCards, getHomepageGoatCards, getHomepageRankingsDebug, groupRankedFightersByDivision } from '../lib/champions';

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.fightprophet.com';
const withPage = (slug: string) => buildAppPageUrl(appUrl, slug);
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://fightprophet.com').replace(/\/$/, '');
const rankingsPageUrl = '/rankings';
const rankingsAnchorUrl = '/#fp-rankings';
const predictionsAppUrl = withPage('predictions');

const runtimeEnv = runtimeEnvFromLocals(Astro.locals);
const allRankedFighters = await getAllRankedFighterCards(runtimeEnv);
const homepageGoats = await getHomepageGoatCards(runtimeEnv);
const homepageRankingsDebug = getHomepageRankingsDebug(runtimeEnv);
const rankedDivisions = groupRankedFightersByDivision(allRankedFighters);
const totalRankedFighters = allRankedFighters.length;
const goatPreviewLimit = 12;
const topGoats = homepageGoats.slice(0, goatPreviewLimit);

interface NewsItem {
  id: string;
  title: string;
  description: string;
  datePublished: string;
  url: string;
  source: string;
}

const MMA_FEEDS = [
  { name: 'MMA Fighting', url: 'https://www.mmafighting.com/rss/index.xml' },
  { name: 'ESPN MMA', url: 'https://www.espn.com/espn/rss/mma/news' },
];

function stripHtml(input: string): string {
  return input
    .replace(/<!\[CDATA\[|\]\]>/g, '')
    .replace(/<[^>]*>/g, ' ')
    .replace(/&nbsp;/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function toIsoDate(input: string): string {
  const parsed = new Date(input);
  if (Number.isNaN(parsed.getTime())) return new Date().toISOString().slice(0, 10);
  return parsed.toISOString().slice(0, 10);
}

function slugify(input: string): string {
  return input
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 72) || 'mma-news';
}

interface RankingDeck {
  slug: string;
  label: string;
  title: string;
  note: string;
  countLabel: string;
  fighters: typeof topGoats;
}

const rankingDecks: RankingDeck[] = [
  ...(topGoats.length > 0
    ? [{
        slug: 'goat-list',
        label: 'GOAT List',
        title: 'GOAT List',
        note: 'A pound-for-pound style snapshot built from the latest model-wide ranking feed. Tap any category below to swap the deck.',
        countLabel: `${topGoats.length} featured fighters`,
        fighters: topGoats,
      }]
    : []),
  ...rankedDivisions
    .filter((group) => group.fighters.length > 0)
    .map((group) => ({
      slug: `division-${slugify(group.weight_class || 'division')}`,
      label: group.weight_class,
      title: group.weight_class,
      note: `Current ranking deck for ${group.weight_class}. Click around and the cards reshuffle into the new division.`,
      countLabel: `${group.fighters.length} ranked fighters`,
      fighters: group.fighters,
    })),
];

const initialDeckSlug = rankingDecks[0]?.slug || '';
const hasRankingDecks = rankingDecks.length > 0;

function parseRssItems(xml: string, source: string, limit = 12): NewsItem[] {
  const itemMatches = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)].slice(0, limit);

  return itemMatches
    .map((match, idx) => {
      const itemXml = match[1] || '';
      const titleRaw = itemXml.match(/<title>([\s\S]*?)<\/title>/i)?.[1] || '';
      const descRaw = itemXml.match(/<description>([\s\S]*?)<\/description>/i)?.[1] || '';
      const linkRaw = itemXml.match(/<link>([\s\S]*?)<\/link>/i)?.[1] || '';
      const dateRaw = itemXml.match(/<pubDate>([\s\S]*?)<\/pubDate>/i)?.[1] || '';

      const title = stripHtml(titleRaw) || 'MMA News Update';
      const description = stripHtml(descRaw) || 'Latest MMA world update.';
      const url = stripHtml(linkRaw) || siteUrl;
      const datePublished = toIsoDate(stripHtml(dateRaw));

      return {
        id: `${slugify(title)}-${idx}`,
        title,
        description,
        datePublished,
        url,
        source,
      };
    })
    .filter((item) => !!item.title && !!item.url);
}

async function getMmaNewsItems(): Promise<NewsItem[]> {
  const allItems: NewsItem[] = [];
  const perFeed = 5;

  for (const feed of MMA_FEEDS) {
    try {
      const response = await fetch(feed.url, {
        headers: {
          'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36',
        },
      });
      if (!response.ok) continue;
      const xml = await response.text();
      allItems.push(...parseRssItems(xml, feed.name, perFeed));
    } catch {
      continue;
    }
  }

  const deduped = allItems
    .filter((item, index, arr) => arr.findIndex((other) => other.url === item.url) === index)
    .sort((a, b) => b.datePublished.localeCompare(a.datePublished))
    .slice(0, 8);

  if (deduped.length > 0) {
    return deduped;
  }

  return [
    {
      id: 'mma-fallback-1',
      title: 'MMA headlines are updating — source temporarily unavailable',
      description: 'Latest MMA world feed is temporarily unavailable. Please check back shortly for refreshed fight news.',
      datePublished: new Date().toISOString().slice(0, 10),
      url: 'https://www.mmafighting.com',
      source: 'MMA News',
    },
  ];
}

const newsItems = await getMmaNewsItems();
const initialNews = newsItems[0];

const newsStructuredData = newsItems.map((item) => ({
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: item.title,
  description: item.description,
  datePublished: item.datePublished,
  dateModified: item.datePublished,
  author: { '@type': 'Organization', name: 'Fight Prophet' },
  publisher: {
    '@type': 'Organization',
    name: 'Fight Prophet',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/branding/fightprophet_logo_white.png` },
  },
  mainEntityOfPage: `${siteUrl}/#news-${item.id}`,
  url: `${siteUrl}/#news-${item.id}`,
}));
---

<BaseLayout title="Fight Prophet | MMA Predictions, Rankings & Analytics" description="MMA AI and ML-powered fight predictions, fighter rankings, and model insights. Built for fans who want clear data without the noise.">
  <div class="fp-home-main">

    <!-- HERO -->
    <header class="fp-hero">
      <div class="fp-hero-brand">
        <img src="/branding/fightprophet_logo_white.png" alt="Fight Prophet" class="fp-hero-logo" loading="eager" />
      </div>
      <h1 class="fp-hero-title" id="i18n-hero-title">AI-powered MMA rankings, stats, and fight predictions.</h1>
      <p class="fp-hero-sub" id="i18n-hero-sub">Built for fans by fans. Machine-learning models help turn fight data into simple picks and rankings.</p>
      <div class="fp-hero-ctas">
        <a class="fp-cta-primary" href={predictionsAppUrl}>
          <span id="i18n-cta-open-app">See predictions</span>
          <span class="fp-cta-arrow" aria-hidden="true">→</span>
        </a>
        <a class="fp-cta-ghost" href={rankingsAnchorUrl} id="i18n-cta-browse">Browse rankings ↓</a>
      </div>
      <p class="fp-hero-note" id="i18n-hero-note">For information and education only — not financial advice. Our predictions and estimates can be wrong.</p>
    </header>

    <!-- RANKINGS CENTERPIECE -->
    <section id="fp-rankings" class="fp-rank-section">
      <div class="fp-rank-section-head">
        <div>
          <p class="fp-section-label" id="i18n-rank-label">GOAT Board</p>
          <h2 class="fp-rank-section-title" id="i18n-rank-title">GOAT List</h2>
        </div>
        <a class="fp-rank-section-link" href={rankingsPageUrl}>GOAT list →</a>
      </div>

      {hasRankingDecks ? (
        <div class="fp-rank-wall" data-initial-division={initialDeckSlug}>
          <p class="fp-rank-note">Start on the GOAT list, then click any category pill to swap the deck and reveal a different set of fighter cards.</p>

          <div class="fp-division-pills" role="toolbar" aria-label="Ranking categories">
            {rankingDecks.map((deck, idx) => (
              <button
                type="button"
                class={`fp-division-pill${idx === 0 ? ' is-active' : ''}`}
                data-division-target={deck.slug}
                aria-pressed={idx === 0 ? 'true' : 'false'}
              >
                <span>{deck.label}</span>
                <span class="fp-division-pill-count">{deck.fighters.length}</span>
              </button>
            ))}
          </div>

          <div class="fp-division-panels">
            {rankingDecks.map((deck, idx) => (
              <section
                class={`fp-division-block${idx === 0 ? ' is-active' : ''}`}
                data-division-panel={deck.slug}
                hidden={idx !== 0}
              >
                <div class="fp-division-header">
                  <h3 class="fp-division-title">{deck.title}</h3>
                  <span class="fp-division-count">{deck.countLabel}</span>
                </div>
                <p class="fp-division-description">{deck.note}</p>
                <div class="fp-card-grid">
                  {deck.fighters.map((c, cardIdx) => (
                    <div class="fp-card-shell" style={`--card-index:${cardIdx};`}>
                      <FighterCard
                        name={c.name}
                        fighterId={c.fighter_id}
                        country={c.country}
                        weightClass={c.weight_class}
                        isChampion={c.is_champion ?? false}
                        finishRate={c.finish_rate ?? null}
                        subRate={c.sub_rate ?? null}
                        winStreak={c.win_streak ?? null}
                        lossStreak={c.loss_streak ?? null}
                        wins={c.wins ?? null}
                        losses={c.losses ?? null}
                        globalRank={c.global_rank ?? null}
                        divisionRank={c.rank ?? null}
                        compact={true}
                        appUrl={appUrl}
                      />
                    </div>
                  ))}
                </div>
              </section>
            ))}
          </div>

          <div class="fp-division-footer">
            <a class="fp-division-link" href={rankingsPageUrl}>
              See full rankings →
            </a>
          </div>
        </div>
      ) : (
        <div class="fp-empty-state">
          <strong>Rankings are temporarily unavailable.</strong>
          <span>The live rankings refresh from the Monday ETL feed. If this is empty right now, the site feed has not landed yet.</span>
          <code class="fp-empty-debug">
            Azure account: {homepageRankingsDebug.hasAzureAccount ? 'yes' : 'no'} · key: {homepageRankingsDebug.hasAzureKey ? 'yes' : 'no'} · blob: {homepageRankingsDebug.blobPath}
          </code>
          <a class="fp-cta-primary" href={rankingsPageUrl}>See all categories →</a>
        </div>
      )}
    </section>

    <!-- SECTIONS GRID -->
    <section class="fp-sections">
      <div class="fp-sections-head">
        <p class="fp-section-label" id="i18n-explore-label">Explore</p>
        <h2 class="fp-sections-title" id="i18n-explore-title">Everything Fight Prophet has</h2>
      </div>
      <div class="fp-cta-grid">
        <a class="fp-section-card" href={predictionsAppUrl}>
          <strong id="i18n-cta-1-title">Predictions</strong>
          <span id="i18n-cta-1-desc">Compare model vs market probability</span>
        </a>
        <a class="fp-section-card" href={withPage('fight-lab')}>
          <strong id="i18n-cta-2-title">Fight Lab</strong>
          <span id="i18n-cta-2-desc">Historical picks + model metrics</span>
        </a>
        <a class="fp-section-card" href={rankingsPageUrl}>
          <strong id="i18n-cta-3-title">Fighter Rankings</strong>
          <span id="i18n-cta-3-desc">Every division in one place</span>
        </a>
        <a class="fp-section-card" href={withPage('belt-holders')}>
          <strong id="i18n-cta-4-title">Belt Holders</strong>
          <span id="i18n-cta-4-desc">Champions and title history</span>
        </a>
        <a class="fp-section-card" href={withPage('fighter-card')}>
          <strong id="i18n-cta-5-title">Fighter Cards</strong>
          <span id="i18n-cta-5-desc">Open a data card for any fighter</span>
        </a>
        <a class="fp-section-card" href={withPage('events-history')}>
          <strong id="i18n-cta-6-title">Events History</strong>
          <span id="i18n-cta-6-desc">Past UFC cards and results</span>
        </a>
      </div>
    </section>

    <!-- LATEST NEWS -->
    {newsItems.length > 0 && (
      <section class="fp-news-section">
        <p class="fp-section-label" id="i18n-news-label">Latest news</p>
        <div class="fp-news-shell">
          <nav class="fp-news-menu" id="fp-news-menu" aria-label="News menu">
            {newsItems.map((item, idx) => (
              <button
                type="button"
                class={`fp-news-menu-item${idx === 0 ? ' is-active' : ''}`}
                data-news-id={item.id}
                id={`news-${item.id}`}
              >
                <span class="fp-news-menu-date">{item.datePublished}</span>
                <span class="fp-news-menu-title">{item.title}</span>
                <span class="fp-news-menu-source">{item.source}</span>
              </button>
            ))}
          </nav>
          <article class="fp-news-detail" id="fp-news-detail">
            <p class="fp-news-date" id="fp-news-detail-date">{initialNews.datePublished}</p>
            <h3 id="fp-news-detail-title">{initialNews.title}</h3>
            <p id="fp-news-detail-desc">{initialNews.description}</p>
            <a id="fp-news-detail-link" class="fp-news-detail-link" href={initialNews.url || appUrl} target="_blank" rel="noopener noreferrer">
              Read full article →
            </a>
          </article>
        </div>
      </section>
    )}

    <!-- FINAL CTA BANNER -->
    <section class="fp-final-cta">
      <div>
        <p class="fp-final-cta-eyebrow" id="i18n-final-eyebrow">Up next</p>
        <h2 class="fp-final-cta-title" id="i18n-final-title">Compare model picks vs. market for the upcoming fights.</h2>
      </div>
      <a class="fp-cta-primary" href={predictionsAppUrl}>
        <span id="i18n-final-cta">Predictions</span>
        <span class="fp-cta-arrow" aria-hidden="true">→</span>
      </a>
    </section>

    <AdSlot slot="1234567890" />
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(newsStructuredData)}></script>

  <script define:vars={{ newsItems }}>
    const newsList = Array.isArray(newsItems) ? newsItems : [];
    const byId = Object.fromEntries(newsList.map((item) => [item.id, item]));
    const menu = document.getElementById('fp-news-menu');
    const dateEl = document.getElementById('fp-news-detail-date');
    const titleEl = document.getElementById('fp-news-detail-title');
    const descEl = document.getElementById('fp-news-detail-desc');
    const linkEl = document.getElementById('fp-news-detail-link');

    function renderNews(newsId) {
      const item = byId[newsId];
      if (!item || !dateEl || !titleEl || !descEl || !linkEl) return;
      dateEl.textContent = item.datePublished || '';
      titleEl.textContent = item.title || '';
      descEl.textContent = item.description || '';
      linkEl.href = item.url || '#';
      linkEl.style.display = item.url ? 'inline-flex' : 'none';

      menu?.querySelectorAll('.fp-news-menu-item').forEach((btn) => {
        btn.classList.toggle('is-active', btn.getAttribute('data-news-id') === newsId);
      });
    }

    menu?.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const button = target.closest('.fp-news-menu-item');
      if (!button) return;
      renderNews(button.getAttribute('data-news-id') || '');
    });
  </script>

  <script>
    const wall = document.querySelector('.fp-rank-wall');
    if (wall) {
      const divisionPills = Array.from(wall.querySelectorAll('.fp-division-pill'));
      const divisionPanels = Array.from(wall.querySelectorAll('.fp-division-block'));
      const panelHost = wall.querySelector('.fp-division-panels');
      let activeSlug = wall.getAttribute('data-initial-division') || divisionPanels[0]?.getAttribute('data-division-panel') || '';
      let cleanupTimer = 0;

      function syncPills(slug) {
        divisionPills.forEach((pill) => {
          const isActive = pill.getAttribute('data-division-target') === slug;
          pill.classList.toggle('is-active', isActive);
          pill.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      }

      function clearPanelState(panel) {
        panel.classList.remove('is-entering', 'is-leaving');
      }

      function setDivision(slug) {
        if (!slug) return;
        if (slug === activeSlug) return;

        const current = divisionPanels.find((panel) => panel.getAttribute('data-division-panel') === activeSlug);
        const next = divisionPanels.find((panel) => panel.getAttribute('data-division-panel') === slug);
        if (!next) return;

        activeSlug = slug;
        syncPills(slug);

        if (cleanupTimer) window.clearTimeout(cleanupTimer);

        const lockedHeight = Math.max(current?.offsetHeight || 0, next.offsetHeight || 0);
        if (panelHost && lockedHeight) panelHost.style.minHeight = `${lockedHeight}px`;

        divisionPanels.forEach((panel) => {
          if (panel !== current && panel !== next) {
            clearPanelState(panel);
            panel.classList.remove('is-active');
            panel.hidden = true;
          }
        });

        next.hidden = false;
        next.classList.add('is-active');
        clearPanelState(next);
        void next.offsetWidth;
        next.classList.add('is-entering');

        if (current && current !== next) {
          current.hidden = false;
          current.classList.add('is-active');
          clearPanelState(current);
          void current.offsetWidth;
          current.classList.add('is-leaving');
        }

        cleanupTimer = window.setTimeout(() => {
          if (current && current !== next) {
            clearPanelState(current);
            current.classList.remove('is-active');
            current.hidden = true;
          }
          clearPanelState(next);
          next.classList.add('is-active');
          panelHost?.style.removeProperty('min-height');
        }, 720);
      }

      syncPills(activeSlug);
      const initialPanel = divisionPanels.find((panel) => panel.getAttribute('data-division-panel') === activeSlug);
      if (initialPanel) {
        initialPanel.hidden = false;
        initialPanel.classList.add('is-active', 'is-entering');
        window.setTimeout(() => clearPanelState(initialPanel), 720);
      }

      divisionPills.forEach((pill) => {
        pill.addEventListener('click', () => {
          const slug = pill.getAttribute('data-division-target') || '';
          setDivision(slug);
        });
      });
    }
  </script>

  <script>
    const FP_LANG_KEY = 'fp_lang';
    const translations = {
      en: {
        heroTitle: 'AI-powered MMA rankings, stats, and fight predictions.',
        heroSub: 'Built for fans by fans. Machine-learning models help turn fight data into simple picks and rankings.',
        heroNote: 'For information and education only — not financial advice. Our predictions and estimates can be wrong.',
        ctaOpenApp: 'See predictions',
        ctaBrowse: 'Browse rankings ↓',
        rankLabel: 'GOAT Board',
        exploreLabel: 'Explore',
        exploreTitle: 'Everything Fight Prophet has',
        cta1Title: 'Predictions', cta1Desc: 'Compare model vs market probability',
        cta2Title: 'Fight Lab', cta2Desc: 'Historical picks + model metrics',
        cta3Title: 'Fighter Rankings', cta3Desc: 'Every division in one place',
        cta4Title: 'Belt Holders', cta4Desc: 'Champions and title history',
        cta5Title: 'Fighter Cards', cta5Desc: 'Open a data card for any fighter',
        cta6Title: 'Events History', cta6Desc: 'Past UFC cards and results',
        newsLabel: 'Latest news',
        finalEyebrow: 'Up next',
        finalTitle: 'Compare model picks vs. market for the upcoming fights.',
        finalCta: 'Predictions',
      },
      es: {
        heroTitle: 'Rankings, estadísticas y predicciones de MMA con IA.',
        heroSub: 'Hecho por fans para fans. Modelos de machine learning convierten la data de pelea en picks y rankings fáciles de entender.',
        heroNote: 'Solo para información y educación — no es asesoría financiera. Nuestras predicciones y estimaciones pueden estar equivocadas.',
        ctaOpenApp: 'Ver predicciones',
        ctaBrowse: 'Ver rankings ↓',
        rankLabel: 'Tablero GOAT',
        exploreLabel: 'Explorar',
        exploreTitle: 'Todo lo que tiene Fight Prophet',
        cta1Title: 'Predicciones', cta1Desc: 'Compara probabilidad del modelo vs mercado',
        cta2Title: 'Fight Lab', cta2Desc: 'Picks históricos + métricas de modelo',
        cta3Title: 'Rankings', cta3Desc: 'Rendimiento por división y ascensos',
        cta4Title: 'Campeones', cta4Desc: 'Cinturones e historial de títulos',
        cta5Title: 'Tarjetas de Peleadores', cta5Desc: 'Abre una tarjeta para cualquier peleador',
        cta6Title: 'Historial de Eventos', cta6Desc: 'Carteleras UFC pasadas',
        newsLabel: 'Últimas noticias',
        finalEyebrow: '¿Listo para profundizar?',
        finalTitle: 'Abre la app completa con predicciones, diagnóstico de modelos y fichas de peleadores.',
        finalCta: 'Abrir Fight Prophet',
      },
      pt: {
        heroTitle: 'Rankings, estatísticas e previsões de MMA com IA.',
        heroSub: 'Feito por fãs para fãs. Modelos de machine learning transformam dados de luta em picks e rankings fáceis de entender.',
        heroNote: 'Apenas para informação e educação — não é aconselhamento financeiro. Nossas previsões e estimativas podem estar erradas.',
        ctaOpenApp: 'Abrir o App',
        ctaBrowse: 'Ver rankings ↓',
        rankLabel: 'Quadro GOAT',
        exploreLabel: 'Explorar',
        exploreTitle: 'Tudo que o Fight Prophet tem',
        cta1Title: 'Previsões', cta1Desc: 'Compare probabilidade do modelo vs mercado',
        cta2Title: 'Fight Lab', cta2Desc: 'Picks históricos + métricas',
        cta3Title: 'Rankings', cta3Desc: 'Desempenho por divisão',
        cta4Title: 'Campeões', cta4Desc: 'Cinturões e histórico',
        cta5Title: 'Cards de Lutadores', cta5Desc: 'Abra um card para qualquer lutador',
        cta6Title: 'Histórico de Eventos', cta6Desc: 'Cards passados da UFC',
        newsLabel: 'Últimas notícias',
        finalEyebrow: 'Pronto para ir mais fundo?',
        finalTitle: 'Abra o app completo com previsões, diagnóstico de modelos e cards.',
        finalCta: 'Abrir Fight Prophet',
      },
    };

    const keyToId = {
      heroTitle: 'i18n-hero-title',
      heroSub: 'i18n-hero-sub',
      heroNote: 'i18n-hero-note',
      ctaOpenApp: 'i18n-cta-open-app',
      ctaBrowse: 'i18n-cta-browse',
      rankLabel: 'i18n-rank-label',
      exploreLabel: 'i18n-explore-label',
      exploreTitle: 'i18n-explore-title',
      cta1Title: 'i18n-cta-1-title', cta1Desc: 'i18n-cta-1-desc',
      cta2Title: 'i18n-cta-2-title', cta2Desc: 'i18n-cta-2-desc',
      cta3Title: 'i18n-cta-3-title', cta3Desc: 'i18n-cta-3-desc',
      cta4Title: 'i18n-cta-4-title', cta4Desc: 'i18n-cta-4-desc',
      cta5Title: 'i18n-cta-5-title', cta5Desc: 'i18n-cta-5-desc',
      cta6Title: 'i18n-cta-6-title', cta6Desc: 'i18n-cta-6-desc',
      newsLabel: 'i18n-news-label',
      finalEyebrow: 'i18n-final-eyebrow',
      finalTitle: 'i18n-final-title',
      finalCta: 'i18n-final-cta',
    };

    function applyLanguage(lang) {
      const selected = translations[lang] ? lang : 'en';
      const pack = translations[selected];
      Object.entries(keyToId).forEach(([key, id]) => {
        const el = document.getElementById(id);
        if (el && typeof pack[key] === 'string') el.textContent = pack[key];
      });
      document.querySelectorAll('.fp-lang-btn').forEach((btn) => {
        btn.classList.toggle('is-active', btn.getAttribute('data-lang') === selected);
      });
      document.documentElement.lang = selected;
      localStorage.setItem(FP_LANG_KEY, selected);
    }

    const initialLang = localStorage.getItem(FP_LANG_KEY) || 'en';
    applyLanguage(initialLang);

    document.querySelectorAll('.fp-lang-btn').forEach((btn) => {
      btn.addEventListener('click', () => applyLanguage(btn.getAttribute('data-lang') || 'en'));
    });
  </script>

