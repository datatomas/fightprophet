    };

    const statusByLang = {};
    Object.entries(translations).forEach(([lang, pack]) => {
      statusByLang[lang] = {
        invalid: pack.statusInvalid,
        noEndpoint: pack.statusNoEndpoint,
        submitting: pack.statusSubmitting,
        success: pack.statusSuccess,
        failed: pack.statusFailed,
      };
    });

    function applyLanguage(lang) {
      const selected = translations[lang] ? lang : 'en';
      const pack = translations[selected];

      const htmlKeys = new Set(['wf1', 'wf2', 'wf3', 'wf4']);
      Object.entries(keyToId).forEach(([key, id]) => {
        const el = document.getElementById(id);
        if (el && typeof pack[key] === 'string') {
          if (htmlKeys.has(key)) {
            el.innerHTML = pack[key];
          } else {
            el.textContent = pack[key];
          }
        }
      });

      document.querySelectorAll('[id^="i18n-live-"]').forEach((el) => {
        el.textContent = pack.live;
      });

      document.querySelectorAll('.fp-lang-btn').forEach((btn) => {
        btn.classList.toggle('is-active', btn.getAttribute('data-lang') === selected);
      });

      document.documentElement.lang = selected;
      localStorage.setItem(FP_LANG_KEY, selected);
      window.__fpLangStatus = statusByLang[selected] || statusByLang.en;
    }

    const initialLang = localStorage.getItem(FP_LANG_KEY) || 'en';
    applyLanguage(initialLang);

    document.querySelectorAll('.fp-lang-btn').forEach((btn) => {
      btn.addEventListener('click', () => applyLanguage(btn.getAttribute('data-lang') || 'en'));
    });
  </script>

