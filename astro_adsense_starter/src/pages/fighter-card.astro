---
import BaseLayout from '../layouts/BaseLayout.astro';
import { runtimeEnvFromLocals } from '../lib/country-master';
import { getFighterCardsData } from '../lib/dashboard-data';

const runtimeEnv = runtimeEnvFromLocals(Astro.locals);
const fighterData = await getFighterCardsData(runtimeEnv);
const pageJson = JSON.stringify(fighterData).replace(/</g, '\\u003c');

const totalProfiles = fighterData.profiles.length;
const activeProfiles = fighterData.profiles.filter((profile) => profile.fighter_status === 'active').length;
const championProfiles = fighterData.profiles.filter((profile) => profile.is_current_champion).length;
const historyRows = fighterData.debug.historyCount;
---

<BaseLayout
  title="MMA Fighter Cards — Stats, Records & Fight History | Fight Prophet"
  description="Search public MMA fighter cards with records, country, status, method breakdowns, striking and grappling stats, belt context, and recent fight history."
>
  <article class="fp-fighters-page">
    <header class="fp-tool-hero">
      <a class="fp-tool-breadcrumb" href="/">← Fight Prophet</a>
      <p class="fp-section-label">Fighter Cards</p>
      <h1>MMA Fighter Cards</h1>
      <p>
        Search tracked UFC fighters and inspect career snapshots, method mix, activity status, belt context, striking and grappling metrics, and recent fight history.
      </p>
      <div class="fp-kpi-strip" aria-label="Fighter archive summary">
        <div class="fp-kpi-strip-item">
          <div class="fp-kpi-strip-icon"><img src="/branding/b91c1c-fighterscard-emoji.png" alt="" width="42" height="42" /></div>
          <div class="fp-kpi-strip-label">Fighters</div>
          <div class="fp-kpi-strip-value" data-kpi-total>{totalProfiles.toLocaleString()}</div>
        </div>
        <div class="fp-kpi-strip-item">
          <div class="fp-kpi-strip-icon"><img src="/branding/b91c1c-correct-emoji.png" alt="" width="42" height="42" /></div>
          <div class="fp-kpi-strip-label">Active</div>
          <div class="fp-kpi-strip-value" data-kpi-active>{activeProfiles.toLocaleString()}</div>
        </div>
        <div class="fp-kpi-strip-item">
          <div class="fp-kpi-strip-icon"><img src="/branding/b91c1c-champion-emoji.png" alt="" width="42" height="42" /></div>
          <div class="fp-kpi-strip-label">Champions</div>
          <div class="fp-kpi-strip-value" data-kpi-champs>{championProfiles.toLocaleString()}</div>
        </div>
        <div class="fp-kpi-strip-item">
          <div class="fp-kpi-strip-icon"><img src="/branding/b91c1c-fights-emoji.png" alt="" width="42" height="42" /></div>
          <div class="fp-kpi-strip-label">Fight Rows</div>
          <div class="fp-kpi-strip-value" data-kpi-rows>{historyRows.toLocaleString()}</div>
        </div>
      </div>
    </header>

    {totalProfiles > 0 ? (
      <>
        <section class="fp-tool-controls" aria-label="Fighter filters">
          <label>
            <span>Search</span>
            <input type="search" data-fighter-search placeholder="Fighter, country, status" autocomplete="off" />
          </label>
          <label>
            <span>Status</span>
            <select data-fighter-status>
              <option value="All">All</option>
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
              <option value="champion">Current champions</option>
            </select>
          </label>
        </section>

        <div class="fp-fighters-layout">
          <section class="fp-fighter-picker" aria-label="Matching fighters">
            <div class="fp-panel-head">
              <h2>Fighter Index</h2>
              <span data-fighter-match-count>{totalProfiles.toLocaleString()} fighters</span>
            </div>
            <label class="fp-fighter-select-label">
              <span>Choose fighter</span>
              <select data-fighter-select aria-label="Choose fighter"></select>
            </label>
            <p class="fp-list-empty" data-fighter-empty hidden>No fighters match these filters.</p>
          </section>

          <section class="fp-fighter-detail" aria-live="polite">
            <header class="fp-fighter-header">
              <div>
                <span class="fp-fighter-status" data-profile-status></span>
                <h2 data-profile-name>Fighter</h2>
                <p data-profile-meta></p>
              </div>
              <div class="fp-record-mark" data-profile-record>—</div>
            </header>

            <div class="fp-profile-kpis">
              <div>
                <img class="fp-profile-kpi-icon" src="/branding/b91c1c-correct-emoji.png" alt="" width="46" height="46" />
                <span>Win Rate</span><strong data-kpi-win-rate>—</strong>
              </div>
              <div>
                <img class="fp-profile-kpi-icon" src="/branding/finish_rate_icon_b91c1c_transparent.png" alt="" width="46" height="46" />
                <span>Finish Rate</span><strong data-kpi-finish-rate>—</strong>
              </div>
              <div>
                <img class="fp-profile-kpi-icon" src="/branding/b91c1c-winstreak-emoji.png" alt="" width="46" height="46" />
                <span>Win Streak</span><strong data-kpi-win-streak>—</strong>
              </div>
              <div>
                <img class="fp-profile-kpi-icon" src="/branding/b91c1c-events-emoji.png" alt="" width="46" height="46" />
                <span>Last Fight</span><strong data-kpi-last-fight>—</strong>
              </div>
            </div>

            <div class="fp-meta-strip">
              <div class="fp-meta-cell">
                <img src="/branding/b91c1c-strikingdefence-emoji.png" alt="" width="40" height="40" />
                <span>Str Def</span>
                <strong data-meta-str-def>—</strong>
              </div>
              <div class="fp-meta-cell">
                <img src="/branding/b91c1c-takedowndefence-emoji.png" alt="" width="40" height="40" />
                <span>TD Def</span>
                <strong data-meta-td-def>—</strong>
              </div>
              <div class="fp-meta-cell">
                <img src="/branding/b91c1c-strikingaccuracy-emoji.png" alt="" width="40" height="40" />
                <span>SApM</span>
                <strong data-meta-sapm>—</strong>
              </div>
              <div class="fp-meta-cell">
                <img src="/branding/b91c1c-bonus-emoji.png" alt="" width="40" height="40" />
                <span>Bonuses</span>
                <strong data-meta-bonuses>—</strong>
              </div>
              <div class="fp-meta-cell">
                <img src="/branding/b91c1c-winstreak-emoji.png" alt="" width="40" height="40" />
                <span>Best Win Streak</span>
                <strong data-meta-win-streak>—</strong>
              </div>
              <div class="fp-meta-cell">
                <img src="/branding/b91c1c-incorrect-emoji.png" alt="" width="40" height="40" />
                <span>Worst Loss Streak</span>
                <strong data-meta-loss-streak>—</strong>
              </div>
            </div>

            <section class="fp-career-snapshot">
              <h3>Career Snapshot</h3>
              <div class="fp-kpi-grid" data-career-list></div>
            </section>
            <div class="fp-profile-grid">
              <section>
                <h3>Striking &amp; Grappling</h3>
                <div class="fp-kpi-grid" data-skills-list></div>
              </section>
              <section>
                <h3>Method Mix</h3>
                <div class="fp-kpi-grid" data-method-list></div>
              </section>
            </div>

            <section class="fp-history-panel">
              <div class="fp-panel-head">
                <div>
                  <h3>Recent Fight History</h3>
                  <span data-history-count></span>
                </div>
                <button type="button" class="fp-csv-btn" data-csv-download aria-label="Download fight history as CSV">
                  ↓ CSV
                </button>
              </div>
              <div class="fp-history-scroll">
                <table class="fp-history-table" data-history-table>
                  <thead>
                    <tr>
                      <th scope="col">Date</th>
                      <th scope="col">Result</th>
                      <th scope="col">Opponent</th>
                      <th scope="col">Method</th>
                      <th scope="col" class="fp-col-center">Rd</th>
                      <th scope="col" class="fp-col-center">Time</th>
                      <th scope="col" class="fp-col-center">KD</th>
                      <th scope="col" class="fp-col-center">STR</th>
                      <th scope="col" class="fp-col-center">TD</th>
                      <th scope="col" class="fp-col-center">SUB</th>
                      <th scope="col">Event</th>
                    </tr>
                  </thead>
                  <tbody data-history-body></tbody>
                </table>
              </div>
            </section>
          </section>
        </div>
      </>
    ) : (
      <section class="fp-empty-state">
        <strong>Fighter cards are temporarily unavailable.</strong>
        <span>The public cards read from the exported dashboard parquet feed. If this is empty, the latest export has not landed yet.</span>
      </section>
    )}
  </article>

  <script type="application/json" id="fp-fighter-data" set:html={pageJson}></script>
</BaseLayout>

<script is:inline>
  (() => {
    const dataNode = document.getElementById('fp-fighter-data');
    if (!dataNode) return;
    const payload = JSON.parse(dataNode.textContent || '{"profiles":[],"history":{}}');
    const profiles = Array.isArray(payload.profiles) ? payload.profiles : [];
    const history = payload.history && typeof payload.history === 'object' ? payload.history : {};
    if (!profiles.length) return;

    const search = document.querySelector('[data-fighter-search]');
    const status = document.querySelector('[data-fighter-status]');
    const fighterSelect = document.querySelector('[data-fighter-select]');
    const emptyState = document.querySelector('[data-fighter-empty]');
    const matchCount = document.querySelector('[data-fighter-match-count]');
    const profileName = document.querySelector('[data-profile-name]');
    const profileMeta = document.querySelector('[data-profile-meta]');
    const profileStatus = document.querySelector('[data-profile-status]');
    const profileRecord = document.querySelector('[data-profile-record]');
    const winRate = document.querySelector('[data-kpi-win-rate]');
    const finishRate = document.querySelector('[data-kpi-finish-rate]');
    const winStreak = document.querySelector('[data-kpi-win-streak]');
    const lastFight = document.querySelector('[data-kpi-last-fight]');
    const careerList = document.querySelector('[data-career-list]');
    const skillsList = document.querySelector('[data-skills-list]');
    const methodList = document.querySelector('[data-method-list]');
    const historyCount  = document.querySelector('[data-history-count]');
    const historyBody   = document.querySelector('[data-history-body]');
    const csvBtn        = document.querySelector('[data-csv-download]');
    const metaStrDef = document.querySelector('[data-meta-str-def]');
    const metaTdDef = document.querySelector('[data-meta-td-def]');
    const metaSapm = document.querySelector('[data-meta-sapm]');
    const metaBonuses = document.querySelector('[data-meta-bonuses]');
    const metaWinStreak = document.querySelector('[data-meta-win-streak]');
    const metaLossStreak = document.querySelector('[data-meta-loss-streak]');

    const params = new URLSearchParams(window.location.search);
    const requested = String(params.get('fighter') || '').trim().toLowerCase();
    let selectedProfile = profiles.find((profile) => profile.name.toLowerCase() === requested)
      || profiles.find((profile) => profile.name.toLowerCase().includes(requested) && requested)
      || profiles[0];

    const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g, (ch) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[ch]));
    const fmtInt = (value) => value == null || Number.isNaN(Number(value)) ? '—' : Number(value).toLocaleString();
    const fmtPct = (value, decimals = 0) => {
      if (value == null || Number.isNaN(Number(value))) return '—';
      const num = Number(value);
      const pct = num <= 1 ? num * 100 : num;
      return `${pct.toFixed(decimals)}%`;
    };
    const fmtNum = (value, decimals = 2) => value == null || Number.isNaN(Number(value)) ? '—' : Number(value).toFixed(decimals);

    // Pct (0..100) for filling a progress bar; accepts 0..1 or 0..100 source values.
    const pctValue = (value) => {
      if (value == null || Number.isNaN(Number(value))) return null;
      const num = Number(value);
      return Math.max(0, Math.min(100, num <= 1 ? num * 100 : num));
    };

    // Senior-UX KPI card. `opts.pct` (0..100) renders a progress bar; `opts.hint` appends a small footnote.
    const kpiCard = (label, value, opts = {}) => {
      const { pct = null, hint = '', tone = 'default' } = opts;
      const bar = pct == null ? '' : `<div class="fp-kpi-bar" aria-hidden="true"><span style="width:${pct.toFixed(1)}%"></span></div>`;
      const hintHtml = hint ? `<span class="fp-kpi-hint">${escapeHtml(hint)}</span>` : '';
      const valueDisplay = value === '' || value == null ? '—' : value;
      return `<article class="fp-kpi-card fp-kpi-card--${tone}">
        <span class="fp-kpi-label">${escapeHtml(label)}</span>
        <strong class="fp-kpi-value">${escapeHtml(valueDisplay)}</strong>
        ${bar}${hintHtml}
      </article>`;
    };
    const record = (profile) => `${fmtInt(profile.wins)}-${fmtInt(profile.losses)}-${fmtInt(profile.draws || 0)}`;
    const profileUrl = (profile) => `/fighter-card/?fighter=${encodeURIComponent(profile.name)}`;

    function filteredProfiles() {
      const query = String(search?.value || '').trim().toLowerCase();
      const statusValue = String(status?.value || 'All');
      return profiles.filter((profile) => {
        const statusMatch = statusValue === 'All'
          || profile.fighter_status === statusValue
          || (statusValue === 'champion' && profile.is_current_champion);
        return statusMatch && (!query || String(profile.search_text || profile.name).includes(query));
      });
    }

    function selectProfile(profile, pushState = true) {
      selectedProfile = profile;
      if (pushState) window.history.replaceState({}, '', profileUrl(profile));

      profileName.textContent = profile.name;
      profileMeta.textContent = [
        profile.country,
        profile.current_belt_weight_classes,
        profile.stance,
      ].filter(Boolean).join(' / ');
      profileStatus.textContent = profile.is_current_champion ? 'Current Champion' : (profile.fighter_status || 'Fighter');
      profileStatus.classList.toggle('is-champion', !!profile.is_current_champion);
      profileRecord.textContent = record(profile);
      winRate.textContent = fmtPct(profile.win_rate, 1);
      finishRate.textContent = fmtPct(profile.finish_rate, 1);
      winStreak.textContent = fmtInt(profile.win_streak);
      lastFight.textContent = profile.last_fight_date || '—';
      if (metaStrDef) metaStrDef.textContent = fmtPct(profile.str_def);
      if (metaTdDef) metaTdDef.textContent = fmtPct(profile.td_def);
      if (metaSapm) metaSapm.textContent = fmtNum(profile.sapm, 2);
      if (metaBonuses) metaBonuses.textContent = fmtInt(profile.bonuses_won_count);
      if (metaWinStreak) metaWinStreak.textContent = fmtInt(profile.longest_win_streak);
      if (metaLossStreak) metaLossStreak.textContent = fmtInt(profile.longest_loss_streak);

      careerList.innerHTML = [
        kpiCard('Country', profile.country || '—'),
        kpiCard('Status', (profile.fighter_status || '—').toString().replace(/^./, (c) => c.toUpperCase()), { tone: profile.fighter_status === 'active' ? 'good' : 'muted' }),
        kpiCard('Age', fmtInt(profile.age), { hint: profile.age ? 'years' : '' }),
        kpiCard('Height', profile.height || '—'),
        kpiCard('Weight', profile.weight || '—'),
        kpiCard('Reach', profile.reach || '—'),
        kpiCard('First Fight', profile.first_fight_date || '—'),
        kpiCard('Title Fights', fmtInt(profile.title_fights), { tone: Number(profile.title_fights) > 0 ? 'accent' : 'default' }),
      ].join('');

      skillsList.innerHTML = [
        kpiCard('SLpM', fmtNum(profile.slpm, 2), { hint: 'per minute' }),
        kpiCard('SApM', fmtNum(profile.sapm, 2), { hint: 'per minute' }),
        kpiCard('Str Acc', fmtPct(profile.str_acc), { pct: pctValue(profile.str_acc), tone: 'pct' }),
        kpiCard('Str Def', fmtPct(profile.str_def), { pct: pctValue(profile.str_def), tone: 'pct' }),
        kpiCard('TD Avg', fmtNum(profile.td_avg, 2), { hint: 'per 15 min' }),
        kpiCard('TD Acc', fmtPct(profile.td_acc), { pct: pctValue(profile.td_acc), tone: 'pct' }),
        kpiCard('TD Def', fmtPct(profile.td_def), { pct: pctValue(profile.td_def), tone: 'pct' }),
        kpiCard('Sub Avg', fmtNum(profile.sub_avg, 2), { hint: 'per 15 min' }),
      ].join('');

      methodList.innerHTML = [
        kpiCard('KO/TKO Wins', fmtInt(profile.ko_wins), { tone: 'count' }),
        kpiCard('Submission Wins', fmtInt(profile.sub_wins), { tone: 'count' }),
        kpiCard('Decision Wins', fmtInt(profile.dec_wins), { tone: 'count' }),
        kpiCard('Bonuses', fmtInt(profile.bonuses_won_count), { tone: 'accent' }),
        kpiCard('Bayes KO/TKO', fmtPct(profile.ko_rate_win_shrunk), { pct: pctValue(profile.ko_rate_win_shrunk), tone: 'pct' }),
        kpiCard('Bayes Sub', fmtPct(profile.sub_rate_win_shrunk), { pct: pctValue(profile.sub_rate_win_shrunk), tone: 'pct' }),
        kpiCard('Bayes Finish', fmtPct(profile.finish_rate_win_shrunk), { pct: pctValue(profile.finish_rate_win_shrunk), tone: 'pct' }),
        kpiCard('Method Sample', fmtInt(profile.wins_method_known_count), { hint: 'fights' }),
      ].join('');

      const rows = history[profile.fighter_id] || [];
      historyCount.textContent = `${rows.length.toLocaleString()} fight${rows.length === 1 ? '' : 's'}`;

      // Wire CSV download for this fighter
      if (csvBtn) {
        csvBtn.onclick = () => downloadCSV(profile.name, rows);
      }

      if (!rows.length) {
        historyBody.innerHTML = `<tr><td colspan="11" class="fp-history-empty">No fight history available yet.</td></tr>`;
        return;
      }

      const statCell = (a, b) => {
        const av = fmtInt(a);
        const bv = fmtInt(b);
        if (av === '—' && bv === '—') return '<td class="fp-col-center fp-stat-cell">—</td>';
        return `<td class="fp-col-center fp-stat-cell"><span class="fp-stat-for">${escapeHtml(av)}</span><span class="fp-stat-sep">–</span><span class="fp-stat-against">${escapeHtml(bv)}</span></td>`;
      };

      historyBody.innerHTML = rows.map((row) => {
        const res = String(row.result || '').toLowerCase();
        const resCls = res === 'win' ? 'win' : res === 'loss' ? 'loss' : 'neutral';
        const resLabel = row.result || '—';
        const method = escapeHtml(row.method || row.method_category || '—');
        const titleBadge = row.is_title_fight ? '<span class="fp-title-badge" aria-label="Title fight">★</span>' : '';
        const oppHref = `/fighter-card/?fighter=${encodeURIComponent(row.opponent_name_display || '')}`;
        const weightTag = row.weight_class ? `<span class="fp-wc-tag">${escapeHtml(row.weight_class)}</span>` : '';

        return `<tr class="fp-fight-tr fp-fight-tr--${resCls}">
          <td class="fp-cell-date">${escapeHtml(row.event_date || '—')}</td>
          <td><span class="fp-result-badge fp-result-badge--${resCls}">${escapeHtml(resLabel)}</span></td>
          <td class="fp-cell-opp">
            <a class="fp-opp-link" href="${oppHref}">${escapeHtml(row.opponent_name_display || '—')}</a>
            ${titleBadge}
          </td>
          <td class="fp-cell-method">
            <span class="fp-method-name">${method}</span>
            ${weightTag}
          </td>
          <td class="fp-col-center">${escapeHtml(String(row.round ?? '—'))}</td>
          <td class="fp-col-center fp-cell-time">${escapeHtml(row.time || '—')}</td>
          ${statCell(row.kd_for, row.kd_against)}
          ${statCell(row.str_for, row.str_against)}
          ${statCell(row.td_for, row.td_against)}
          ${statCell(row.sub_for, row.sub_against)}
          <td class="fp-cell-event">${escapeHtml(row.event_name || '—')}</td>
        </tr>`;
      }).join('');
    }

    function downloadCSV(fighterName, rows) {
      const headers = ['Date','Event','Opponent','Weight Class','Title Fight','Result','Winner','Method','Round','Time','KD For','KD Against','STR For','STR Against','TD For','TD Against','Sub For','Sub Against'];
      const csvRow = (r) => [
        r.event_date, r.event_name, r.opponent_name_display, r.weight_class,
        r.is_title_fight ? 'Yes' : 'No', r.result, r.winner_name_display,
        r.method || r.method_category, r.round ?? '', r.time,
        r.kd_for ?? '', r.kd_against ?? '', r.str_for ?? '', r.str_against ?? '',
        r.td_for ?? '', r.td_against ?? '', r.sub_for ?? '', r.sub_against ?? '',
      ].map((v) => `"${String(v ?? '').replace(/"/g, '""')}"`).join(',');

      const csv = [headers.join(','), ...rows.map(csvRow)].join('\r\n');
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href     = url;
      a.download = `${fighterName.replace(/[^a-z0-9]/gi, '_')}_fight_history.csv`;
      a.click();
      URL.revokeObjectURL(url);
    }

    function renderList() {
      const rows = filteredProfiles();
      matchCount.textContent = `${rows.length.toLocaleString()} fighters`;
      if (!rows.some((profile) => profile.fighter_id === selectedProfile.fighter_id)) {
        selectedProfile = rows[0] || profiles[0];
      }
      if (fighterSelect) {
        fighterSelect.disabled = rows.length === 0;
        fighterSelect.innerHTML = rows.slice(0, 500).map((profile) => {
          const meta = [profile.country, profile.fighter_status, record(profile)].filter(Boolean).join(' / ');
          return `<option value="${escapeHtml(profile.fighter_id)}">${escapeHtml(profile.name)}${meta ? ` — ${escapeHtml(meta)}` : ''}</option>`;
        }).join('');
        fighterSelect.value = selectedProfile?.fighter_id || '';
      }
      if (emptyState) emptyState.hidden = rows.length > 0;
      if (selectedProfile) selectProfile(selectedProfile, false);
    }

    search?.addEventListener('input', renderList);
    status?.addEventListener('change', renderList);
    fighterSelect?.addEventListener('change', () => {
      const profile = filteredProfiles().find((candidate) => candidate.fighter_id === fighterSelect.value);
      if (profile) {
        selectProfile(profile);
        renderList();
      }
    });
    if (requested) search.value = params.get('fighter') || '';
    renderList();
  })();
</script>

<style>
  .fp-fighters-page {
    display: grid;
    gap: 1rem;
  }
  .fp-tool-hero,
  .fp-tool-controls,
  .fp-fighter-picker,
  .fp-fighter-detail {
    background: linear-gradient(150deg, rgba(22, 22, 26, 0.92), rgba(36, 36, 42, 0.68));
    border: 1px solid rgba(113, 113, 122, 0.42);
    border-radius: 0.8rem;
  }
  .fp-tool-hero {
    padding: 1.35rem;
  }
  .fp-tool-breadcrumb {
    color: #fca5a5;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }
  .fp-tool-hero h1 {
    margin: 0.25rem 0 0.45rem;
    color: #fef2f2;
    font-size: clamp(1.7rem, 4vw, 2.45rem);
    line-height: 1.08;
  }
  .fp-tool-hero p {
    max-width: 72ch;
    margin: 0;
    color: #d4d4d8;
    line-height: 1.6;
  }
  /* ── Icon KPI strip ── */
  .fp-kpi-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    margin-top: 1rem;
    background: linear-gradient(145deg, rgba(28,28,32,0.92), rgba(39,39,42,0.76));
    border: 1px solid rgba(248,113,113,0.16);
    border-top: 2px solid rgba(185,28,28,0.52);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 8px 18px rgba(0,0,0,0.2);
  }
  .fp-kpi-strip-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100px;
    padding: 0.75rem 0.65rem;
    text-align: center;
    border-right: 1px solid rgba(248,113,113,0.12);
    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0));
  }
  .fp-kpi-strip-item:last-child { border-right: 0; }
  .fp-kpi-strip-icon { margin-bottom: 0.22rem; line-height: 1; }
  .fp-kpi-strip-icon img {
    object-fit: contain;
    display: block;
    filter:
      drop-shadow(0.5px 0 0 #b91c1c)
      drop-shadow(-0.5px 0 0 #b91c1c)
      drop-shadow(0 0.5px 0 #b91c1c)
      drop-shadow(0 -0.5px 0 #b91c1c);
  }
  .fp-kpi-strip-label { color: #d4d4d8; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.12rem; font-weight: 700; }
  .fp-kpi-strip-value { color: #fff; font-size: 1.08rem; font-weight: 800; line-height: 1; }

  /* ── Meta strip (Str Def, TD Def, SApM, Bonuses, Streaks) — unified row ── */
  .fp-meta-strip {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0;
    margin-bottom: 0.95rem;
    background: linear-gradient(145deg, rgba(28,28,32,0.92), rgba(39,39,42,0.76));
    border: 1px solid rgba(248,113,113,0.16);
    border-top: 2px solid rgba(185,28,28,0.52);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 6px 16px rgba(0,0,0,0.18);
  }
  .fp-meta-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.32rem;
    min-height: 112px;
    padding: 0.72rem 0.5rem;
    text-align: center;
    border-right: 1px solid rgba(248,113,113,0.12);
    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0));
  }
  .fp-meta-cell:last-child { border-right: 0; }
  .fp-meta-cell img {
    width: 38px;
    height: 38px;
    object-fit: contain;
    display: block;
    filter:
      drop-shadow(0.5px 0 0 #b91c1c)
      drop-shadow(-0.5px 0 0 #b91c1c)
      drop-shadow(0 0.5px 0 #b91c1c)
      drop-shadow(0 -0.5px 0 #b91c1c);
  }
  .fp-meta-cell span { color: #a1a1aa; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 800; line-height: 1.15; }
  .fp-meta-cell strong { color: #fef2f2; font-size: 1.1rem; font-weight: 800; letter-spacing: -0.01em; }

  /* ── Profile KPI icon (plain png, normalized weight) ── */
  .fp-profile-kpi-icon {
    object-fit: contain;
    display: block;
    margin: 0 auto 0.25rem;
    filter:
      drop-shadow(0.5px 0 0 #b91c1c)
      drop-shadow(-0.5px 0 0 #b91c1c)
      drop-shadow(0 0.5px 0 #b91c1c)
      drop-shadow(0 -0.5px 0 #b91c1c);
  }
  .fp-tool-controls {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(160px, 0.3fr);
    gap: 0.75rem;
    padding: 0.9rem;
  }
  .fp-tool-controls label {
    display: grid;
    gap: 0.35rem;
    color: #a1a1aa;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .fp-tool-controls input,
  .fp-tool-controls select {
    width: 100%;
    min-height: 2.55rem;
    border: 1px solid rgba(113, 113, 122, 0.52);
    border-radius: 0.55rem;
    color: #f4f4f5;
    background: rgba(9, 9, 11, 0.78);
    padding: 0.55rem 0.65rem;
  }
  .fp-fighters-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.9rem;
    align-items: start;
  }
  .fp-fighter-picker,
  .fp-fighter-detail {
    min-width: 0;
    padding: 0.95rem;
  }
  .fp-fighter-picker {
    display: flex;
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .fp-fighter-picker .fp-panel-head {
    flex-shrink: 0;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 0;
    gap: 0.1rem;
  }
  .fp-fighter-picker .fp-panel-head h2 {
    font-size: 0.88rem;
    color: #a1a1aa;
    white-space: nowrap;
  }
  .fp-fighter-picker .fp-panel-head span {
    font-size: 0.68rem;
    margin: 0;
  }
  .fp-fighter-picker .fp-fighter-select-label {
    flex: 1;
    min-width: 220px;
  }
  .fp-panel-head,
  .fp-fighter-header {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }
  .fp-panel-head h2,
  .fp-panel-head h3,
  .fp-fighter-header h2 {
    margin: 0;
    color: #fef2f2;
    font-size: 1.08rem;
  }
  .fp-fighter-header h2 {
    margin-top: 0.18rem;
    font-size: clamp(1.55rem, 4vw, 2.25rem);
    line-height: 1.05;
  }
  .fp-panel-head span,
  .fp-fighter-header p {
    margin: 0.16rem 0 0;
    color: #a1a1aa;
    font-size: 0.84rem;
  }
  .fp-fighter-status {
    display: inline-flex;
    border-radius: 999px;
    padding: 0.2rem 0.48rem;
    color: #d4d4d8;
    background: rgba(63, 63, 70, 0.72);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .fp-fighter-status.is-champion {
    color: #fef3c7;
    background: rgba(180, 83, 9, 0.35);
  }
  .fp-record-mark {
    border: 1px solid rgba(248, 113, 113, 0.45);
    border-radius: 0.65rem;
    padding: 0.55rem 0.7rem;
    color: #fef2f2;
    background: rgba(127, 29, 29, 0.28);
    font-size: 1.15rem;
    font-weight: 900;
    white-space: nowrap;
  }
  .fp-fighter-select-label {
    position: relative;
    display: grid;
    gap: 0.38rem;
    padding: 0.62rem;
    box-sizing: border-box;
    background: rgba(9, 9, 11, 0.62);
    border: 1px solid rgba(113, 113, 122, 0.42);
    border-radius: 0.62rem;
  }
  .fp-fighter-select-label span {
    color: #67e8f9;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .fp-fighter-select-label select {
    width: 100%;
    min-width: 0;
    min-height: 2.55rem;
    padding: 0.55rem 2.1rem 0.55rem 0.65rem;
    color: #fef2f2;
    background: rgba(9, 9, 11, 0.86);
    border: 1px solid rgba(248, 113, 113, 0.22);
    border-radius: 0.55rem;
    outline: 0;
    appearance: none;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 800;
    cursor: pointer;
    text-overflow: ellipsis;
  }
  .fp-fighter-select-label select:disabled {
    color: #71717a;
    cursor: not-allowed;
  }
  .fp-fighter-select-label select option {
    color: #fef2f2;
    background: #18181b;
  }
  .fp-fighter-select-label::after {
    content: '⌄';
    position: absolute;
    right: 1.25rem;
    bottom: 1.22rem;
    color: #fca5a5;
    font-size: 1rem;
    line-height: 1;
    pointer-events: none;
  }
  .fp-fighter-select-label:focus-within {
    border-color: rgba(248, 113, 113, 0.62);
    box-shadow: 0 0 0 3px rgba(185, 28, 28, 0.18);
  }
  /* ── Profile KPI strip (Win Rate / Finish Rate / Win Streak / Last Fight) ── */
  .fp-profile-kpis {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    margin-bottom: 0.85rem;
    background: linear-gradient(145deg, rgba(28,28,32,0.92), rgba(39,39,42,0.76));
    border: 1px solid rgba(248,113,113,0.16);
    border-top: 2px solid rgba(185,28,28,0.52);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 6px 16px rgba(0,0,0,0.18);
  }
  .fp-profile-kpis div {
    min-height: 110px;
    padding: 0.85rem 0.65rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    border-right: 1px solid rgba(248,113,113,0.12);
    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0));
  }
  .fp-profile-kpis div:last-child { border-right: 0; }
  .fp-profile-kpis span {
    display: block;
    color: #a1a1aa;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.2rem;
  }
  .fp-profile-kpis strong {
    color: #fef2f2;
    font-size: 1.45rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  /* ── Career Snapshot / Skills / Method sections ── */
  .fp-career-snapshot,
  .fp-profile-grid section {
    border: 1px solid rgba(63, 63, 70, 0.82);
    border-top: 2px solid rgba(248, 113, 113, 0.22);
    border-radius: 0.65rem;
    background: rgba(9, 9, 11, 0.45);
  }
  .fp-career-snapshot { padding: 0.85rem; margin-bottom: 0.65rem; }
  .fp-profile-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
    margin-bottom: 0;
  }
  .fp-profile-grid section { padding: 0.85rem; overflow: hidden; }
  .fp-career-snapshot h3,
  .fp-profile-grid h3 {
    margin: 0 0 0.7rem;
    color: #fef2f2;
    font-size: 0.92rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ── KPI card grid — shared by Career / Skills / Method ── */
  .fp-kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }
  .fp-kpi-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 0.32rem;
    min-height: 76px;
    padding: 0.62rem 0.68rem 0.7rem;
    border: 1px solid rgba(63, 63, 70, 0.6);
    border-radius: 0.6rem;
    background:
      linear-gradient(165deg, rgba(28, 28, 32, 0.78), rgba(15, 15, 18, 0.62));
    overflow: hidden;
    transition: border-color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
  }
  /* Thin gradient accent stripe top — gives the cards a "dashboard" feel */
  .fp-kpi-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(185, 28, 28, 0.0) 0%, rgba(185, 28, 28, 0.62) 50%, rgba(185, 28, 28, 0.0) 100%);
    opacity: 0.7;
  }
  .fp-kpi-card:hover {
    border-color: rgba(248, 113, 113, 0.42);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.3), inset 0 0 0 1px rgba(248, 113, 113, 0.08);
  }
  .fp-kpi-label {
    color: #a1a1aa;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.2;
  }
  .fp-kpi-value {
    color: #fef2f2;
    font-size: 1.18rem;
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .fp-kpi-hint {
    margin-top: -0.04rem;
    color: #71717a;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  /* Progress bar for % KPIs */
  .fp-kpi-bar {
    margin-top: auto;
    width: 100%;
    height: 4px;
    border-radius: 999px;
    background: rgba(63, 63, 70, 0.55);
    overflow: hidden;
  }
  .fp-kpi-bar > span {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #b91c1c 0%, #ef4444 60%, #f97316 100%);
    box-shadow: 0 0 8px rgba(239, 68, 68, 0.35);
    transition: width 280ms ease;
  }
  /* Tone variants */
  .fp-kpi-card--pct .fp-kpi-value { color: #fff; }
  .fp-kpi-card--accent { border-color: rgba(251, 191, 36, 0.32); background: linear-gradient(165deg, rgba(45, 28, 8, 0.82), rgba(20, 12, 4, 0.68)); }
  .fp-kpi-card--accent::before { background: linear-gradient(90deg, rgba(251,191,36,0), rgba(251,191,36,0.7), rgba(251,191,36,0)); opacity: 0.9; }
  .fp-kpi-card--accent .fp-kpi-value { color: #fde68a; }
  .fp-kpi-card--good { border-color: rgba(34, 197, 94, 0.32); }
  .fp-kpi-card--good::before { background: linear-gradient(90deg, rgba(34,197,94,0), rgba(34,197,94,0.6), rgba(34,197,94,0)); }
  .fp-kpi-card--good .fp-kpi-value { color: #bbf7d0; }
  .fp-kpi-card--muted .fp-kpi-value { color: #d4d4d8; }
  .fp-kpi-card--count .fp-kpi-value { font-size: 1.45rem; color: #fef2f2; }
  /* ── History panel ── */
  .fp-history-panel {
    margin-top: 0.75rem;
    padding: 0.75rem;
  }
  .fp-history-scroll {
    overflow-x: auto;
    border: 1px solid rgba(63, 63, 70, 0.55);
    border-radius: 0.65rem;
    background: rgba(9, 9, 11, 0.42);
    -webkit-overflow-scrolling: touch;
  }

  /* ── CSV download button ── */
  .fp-csv-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.78rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(185, 28, 28, 0.45);
    background: rgba(127, 29, 29, 0.18);
    color: #fca5a5;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 120ms, border-color 120ms, color 120ms;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .fp-csv-btn:hover {
    background: rgba(185, 28, 28, 0.32);
    border-color: rgba(248, 113, 113, 0.65);
    color: #fef2f2;
  }

  /* ── Fight history table ── */
  .fp-history-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    color: #e4e4e7;
  }
  .fp-history-table thead th {
    position: sticky;
    top: 0;
    background: linear-gradient(180deg, rgba(24,24,27,0.96), rgba(15,15,18,0.96));
    color: #fca5a5;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: left;
    padding: 0.6rem 0.7rem;
    border-bottom: 1px solid rgba(185, 28, 28, 0.32);
    white-space: nowrap;
  }
  .fp-history-table tbody td {
    padding: 0.55rem 0.7rem;
    border-bottom: 1px solid rgba(63, 63, 70, 0.28);
    vertical-align: middle;
    white-space: nowrap;
  }
  .fp-history-table tbody tr:last-child td { border-bottom: 0; }
  .fp-history-table tbody tr:hover td {
    background: rgba(185, 28, 28, 0.08);
  }
  .fp-col-center { text-align: center; }

  /* Result-tinted row strip — a thin colored left border on the date cell */
  .fp-fight-tr td:first-child {
    border-left: 3px solid transparent;
  }
  .fp-fight-tr--win  td:first-child { border-left-color: rgba(34,197,94,0.7); }
  .fp-fight-tr--loss td:first-child { border-left-color: rgba(248,113,113,0.78); }
  .fp-fight-tr--neutral td:first-child { border-left-color: rgba(113,113,122,0.6); }

  .fp-cell-date { color: #a1a1aa; font-size: 0.78rem; font-variant-numeric: tabular-nums; }
  .fp-cell-time { color: #a1a1aa; font-variant-numeric: tabular-nums; }
  .fp-cell-event { color: #71717a; font-size: 0.76rem; max-width: 22ch; overflow: hidden; text-overflow: ellipsis; }
  .fp-cell-method { min-width: 0; }
  .fp-method-name { color: #e4e4e7; font-weight: 600; margin-right: 0.4rem; }
  .fp-wc-tag {
    display: inline-block;
    padding: 0.08rem 0.4rem;
    border-radius: 999px;
    border: 1px solid rgba(63, 63, 70, 0.65);
    background: rgba(39, 39, 42, 0.5);
    color: #a1a1aa;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .fp-cell-opp { min-width: 0; }
  .fp-opp-link {
    color: #fef2f2;
    font-weight: 700;
    font-size: 0.88rem;
    text-decoration: none;
  }
  .fp-opp-link:hover { color: #fca5a5; text-decoration: underline; }
  .fp-title-badge {
    display: inline-block;
    margin-left: 0.3rem;
    padding: 0.06rem 0.36rem;
    border-radius: 999px;
    background: rgba(180, 83, 9, 0.32);
    border: 1px solid rgba(251, 191, 36, 0.38);
    color: #fde68a;
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
    vertical-align: middle;
  }

  /* Result badge */
  .fp-result-badge {
    display: inline-block;
    padding: 0.18rem 0.55rem;
    border-radius: 0.4rem;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1;
  }
  .fp-result-badge--win  { color: #bbf7d0; background: rgba(21,128,61,0.32); border: 1px solid rgba(34,197,94,0.42); }
  .fp-result-badge--loss { color: #fecaca; background: rgba(185,28,28,0.32); border: 1px solid rgba(248,113,113,0.42); }
  .fp-result-badge--neutral { color: #a1a1aa; background: rgba(39,39,42,0.55); border: 1px solid rgba(63,63,70,0.55); }

  /* Stat cells (for–against) */
  .fp-stat-cell {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.78rem;
    color: #d4d4d8;
    font-variant-numeric: tabular-nums;
  }
  .fp-stat-for { color: #fef2f2; font-weight: 700; }
  .fp-stat-against { color: #a1a1aa; }
  .fp-stat-sep { color: rgba(113, 113, 122, 0.6); margin: 0 0.2rem; }

  .fp-history-empty {
    color: #a1a1aa;
    padding: 1rem 0.5rem;
    font-size: 0.88rem;
    text-align: center;
  }

  .fp-list-empty { color: #a1a1aa; font-size: 0.88rem; }
  @media (max-width: 1020px) {
    .fp-profile-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .fp-meta-strip { grid-template-columns: repeat(3, minmax(0,1fr)); }
    .fp-meta-cell:nth-child(3) { border-right: 0; }
    .fp-meta-cell:nth-child(4),
    .fp-meta-cell:nth-child(5),
    .fp-meta-cell:nth-child(6) { border-top: 1px solid rgba(248,113,113,0.12); }
    .fp-kpi-strip { grid-template-columns: repeat(2, minmax(0,1fr)); }
    .fp-kpi-strip-item:nth-child(2) { border-right: 0; }
    .fp-kpi-strip-item:nth-child(3) { border-right: 1px solid rgba(248,113,113,0.12); }
    .fp-kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 760px) {
    .fp-tool-controls,
    .fp-fighter-header { grid-template-columns: 1fr; }
    .fp-fighter-header { display: grid; }
    .fp-record-mark { width: fit-content; }
    .fp-profile-kpis {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border-radius: 0.75rem;
    }
    .fp-profile-kpis div {
      min-height: 100px;
      padding: 0.7rem 0.5rem;
    }
    .fp-profile-kpis div:nth-child(2) { border-right: 0; }
    .fp-profile-kpis div:nth-child(3) { border-right: 1px solid rgba(248,113,113,0.12); }
    .fp-profile-kpis div:nth-child(3),
    .fp-profile-kpis div:nth-child(4) {
      border-top: 1px solid rgba(248,113,113,0.12);
    }
    .fp-profile-kpi-icon { width: 38px; height: 38px; }
