---
import BaseLayout from '../layouts/BaseLayout.astro';
import { runtimeEnvFromLocals } from '../lib/country-master';
import { getEventsHistoryData } from '../lib/dashboard-data';

const runtimeEnv = runtimeEnvFromLocals(Astro.locals);
const eventsData = await getEventsHistoryData(runtimeEnv);
const pageJson = JSON.stringify(eventsData).replace(/</g, '\\u003c');

const totalEvents = eventsData.events.length;
const totalFights = eventsData.fights.length;
const upcomingEvents = eventsData.events.filter((event) => event.event_phase === 'Upcoming').length;
const pastEvents = totalEvents - upcomingEvents;
---

<BaseLayout
  title="UFC & MMA Events History | Fight Prophet"
  description="Browse historical UFC and MMA events with fight cards, results, model probabilities, signal strength, and event-level summaries."
>
  <article class="fp-events-page">
    <header class="fp-tool-hero">
      <a class="fp-tool-breadcrumb" href="/">← Fight Prophet</a>
      <p class="fp-section-label" data-i18n="events.eyebrow">Events History</p>
      <h1 data-i18n="events.title">UFC &amp; MMA Events History</h1>
      <p data-i18n="events.intro">
        Browse tracked cards with fight-level results, model signal, market context, and event summaries from the same dashboard exports that power the analytics app.
      </p>
      <div class="fp-kpi-strip" aria-label="Events archive summary">
        <div class="fp-kpi-item">
          <div class="fp-kpi-icon"><img src="/branding/b91c1c-events-emoji.png" alt="" width="42" height="42" /></div>
          <div class="fp-kpi-label" data-i18n="events.kpi.events">Events</div>
          <div class="fp-kpi-value">{totalEvents.toLocaleString()}</div>
        </div>
        <div class="fp-kpi-item">
          <div class="fp-kpi-icon"><img src="/branding/b91c1c-fights-emoji.png" alt="" width="42" height="42" /></div>
          <div class="fp-kpi-label" data-i18n="events.kpi.fightRows">Fight Rows</div>
          <div class="fp-kpi-value">{totalFights.toLocaleString()}</div>
        </div>
        <div class="fp-kpi-item">
          <div class="fp-kpi-icon"><img src="/branding/b91c1c-predictions-emoji.png" alt="" width="42" height="42" /></div>
          <div class="fp-kpi-label" data-i18n="events.kpi.upcoming">Upcoming</div>
          <div class="fp-kpi-value">{upcomingEvents.toLocaleString()}</div>
        </div>
        <div class="fp-kpi-item">
          <div class="fp-kpi-icon"><img src="/branding/b91c1c-accuracy-emoji.png" alt="" width="42" height="42" /></div>
          <div class="fp-kpi-label" data-i18n="events.kpi.past">Past</div>
          <div class="fp-kpi-value">{pastEvents.toLocaleString()}</div>
        </div>
      </div>
    </header>

    {totalEvents > 0 ? (
      <>
        <section class="fp-tool-controls" aria-label="Event filters">
          <label>
            <span data-i18n="events.controls.search">Search</span>
            <input type="search" data-event-search placeholder="UFC 300, London, Holloway" data-i18n-placeholder="events.controls.searchPlaceholder" autocomplete="off" />
          </label>
          <label>
            <span data-i18n="events.controls.window">Window</span>
            <select data-event-phase>
              <option value="All" data-i18n="events.controls.all">All</option>
              <option value="Upcoming" data-i18n="events.controls.upcoming">Upcoming</option>
              <option value="Past" data-i18n="events.controls.past">Past</option>
            </select>
          </label>
          <label>
            <span data-i18n="events.controls.location">Location</span>
            <select data-event-location>
              <option value="All" data-i18n="events.controls.allLocations">All locations</option>
            </select>
          </label>
        </section>

        <div class="fp-events-layout">
          <section class="fp-events-list-panel" aria-label="Matching events">
            <div class="fp-panel-head">
              <h2 data-i18n="events.archive.title">Event Archive</h2>
              <span data-event-match-count>{totalEvents.toLocaleString()} events</span>
            </div>
            <label class="fp-event-select-label">
              <span data-i18n="events.archive.choose">Choose event</span>
              <select data-event-select aria-label="Choose event" data-i18n-aria-label="events.archive.choose"></select>
            </label>
            <p class="fp-list-empty" data-event-empty data-i18n="events.archive.empty" hidden>No events match these filters.</p>
          </section>

          <section class="fp-event-detail" aria-live="polite">
            <div class="fp-panel-head">
              <div>
                <h2 data-selected-event-name translate="no">Event</h2>
                <p data-selected-event-meta></p>
              </div>
              <span class="fp-phase-badge" data-selected-event-phase></span>
            </div>

            <div class="fp-event-kpis">
              <div><span data-i18n="events.detail.date">Date</span><strong data-kpi-date>—</strong></div>
              <div><span data-i18n="events.detail.fights">Fights</span><strong data-kpi-fights>—</strong></div>
              <div><span data-i18n="events.detail.fighters">Fighters</span><strong data-kpi-fighters>—</strong></div>
              <div><span data-i18n="events.detail.modelHitRate">Model Hit Rate</span><strong data-kpi-model>—</strong></div>
            </div>

            <div class="fp-table-wrap">
              <table>
                <thead>
                  <tr>
                    <th data-i18n="events.table.date">Date</th>
                    <th data-i18n="events.table.fight">Fight</th>
                    <th data-i18n="events.table.winner">Winner</th>
                    <th data-i18n="events.table.signal">Signal</th>
                    <th data-i18n="events.table.model">Model</th>
                    <th data-i18n="events.table.market">Market</th>
                    <th data-i18n="events.table.edge">Edge</th>
                    <th title="Realized return on a 1-unit bet on the model's pick, at the captured odds" data-i18n="events.table.betRoi" data-i18n-title="events.table.betRoiTitle">Bet ROI</th>
                  </tr>
                </thead>
                <tbody data-fight-table></tbody>
              </table>
            </div>
          </section>
        </div>
      </>
    ) : (
      <section class="fp-empty-state">
        <strong data-i18n="events.empty.title">Events history is temporarily unavailable.</strong>
        <span data-i18n="events.empty.copy">The public archive reads from the exported dashboard parquet feed. If this is empty, the latest export has not landed yet.</span>
      </section>
    )}
  </article>

  <script type="application/json" id="fp-events-data" set:html={pageJson}></script>
</BaseLayout>

<script is:inline>
  (() => {
    const dataNode = document.getElementById('fp-events-data');
    if (!dataNode) return;
    const payload = JSON.parse(dataNode.textContent || '{"events":[],"fights":[]}');
    const events = Array.isArray(payload.events) ? payload.events : [];
    const fights = Array.isArray(payload.fights) ? payload.fights : [];
    if (!events.length) return;

    const search = document.querySelector('[data-event-search]');
    const phase = document.querySelector('[data-event-phase]');
    const location = document.querySelector('[data-event-location]');
    const eventSelect = document.querySelector('[data-event-select]');
    const emptyState = document.querySelector('[data-event-empty]');
    const matchCount = document.querySelector('[data-event-match-count]');
    const fightTable = document.querySelector('[data-fight-table]');
    const selectedName = document.querySelector('[data-selected-event-name]');
    const selectedMeta = document.querySelector('[data-selected-event-meta]');
    const selectedPhase = document.querySelector('[data-selected-event-phase]');
    const kpiDate = document.querySelector('[data-kpi-date]');
    const kpiFights = document.querySelector('[data-kpi-fights]');
    const kpiFighters = document.querySelector('[data-kpi-fighters]');
    const kpiModel = document.querySelector('[data-kpi-model]');

    const tr = (key, fallback) => window.__fpT ? window.__fpT(key, fallback) : fallback;

    let selectedEvent = events.find((event) => event.event_phase === 'Upcoming') || events[0];

    const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g, (ch) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[ch]));
    const pct = (value) => {
      if (value == null || Number.isNaN(Number(value))) return '—';
      const num = Number(value);
      return `${Math.round((num <= 1 ? num * 100 : num) * 10) / 10}%`;
    };
    const edge = (value) => {
      if (value == null || Number.isNaN(Number(value))) return '—';
      const num = Number(value);
      const shown = Math.round((num <= 1 && num >= -1 ? num * 100 : num) * 10) / 10;
      return `${shown > 0 ? '+' : ''}${shown}%`;
    };
    // realized ROI is a return ratio (+1.5 = +150%, -1 = -100%); always ×100
    const roiPct = (value) => {
      if (value == null || Number.isNaN(Number(value))) return '—';
      const shown = Math.round(Number(value) * 1000) / 10;
      return `${shown > 0 ? '+' : ''}${shown}%`;
    };
    const modelHitRate = (event) => {
      if (!event || !event.model_total_count) return '—';
      return `${Math.round((event.model_correct_count / event.model_total_count) * 100)}%`;
    };

    const locations = [...new Set(events.map((event) => event.location).filter(Boolean))].sort((a, b) => a.localeCompare(b));
    for (const loc of locations) {
      const opt = document.createElement('option');
      opt.value = loc;
      opt.textContent = loc;
      opt.setAttribute('translate', 'no');
      location?.append(opt);
    }

    function filteredEvents() {
      const query = String(search?.value || '').trim().toLowerCase();
      const phaseValue = String(phase?.value || 'All');
      const locValue = String(location?.value || 'All');
      return events.filter((event) => {
        const haystack = `${event.event_name} ${event.location} ${event.event_phase}`.toLowerCase();
        return (!query || haystack.includes(query))
          && (phaseValue === 'All' || event.event_phase === phaseValue)
          && (locValue === 'All' || event.location === locValue);
      });
    }

    function selectEvent(event) {
      selectedEvent = event;
      selectedName.textContent = event.event_name || tr('events.detail.eventFallback', 'Event');
      selectedMeta.textContent = [event.location, event.event_phase].filter(Boolean).join(' / ');
      selectedPhase.textContent = event.event_phase || '';
      selectedPhase.classList.toggle('is-upcoming', event.event_phase === 'Upcoming');
      kpiDate.textContent = event.event_date || '—';
      kpiFights.textContent = Number(event.fight_count || 0).toLocaleString();
      kpiFighters.textContent = Number(event.unique_fighters || 0).toLocaleString();
      kpiModel.textContent = modelHitRate(event);

      const rows = fights.filter((fight) => fight.event_name === event.event_name);
      if (!rows.length) {
        fightTable.innerHTML = `<tr><td colspan="8">${escapeHtml(tr('events.detail.noFights', 'Fight-level rows are not available for this event yet.'))}</td></tr>`;
        return;
      }
      const isUpcoming = event.event_phase === 'Upcoming';
      fightTable.innerHTML = rows.map((fight) => {
        const winner = fight.winner_name_display || '';
        const fLink = (n) => n ? `<a class="fp-ft-link" href="/fighter-stats/?fighter=${encodeURIComponent(n)}">${escapeHtml(n)}</a>` : escapeHtml(n) || '—';
        const winnerCell = isUpcoming || !winner
          ? `<span class="fp-winner-tbd">${winner ? escapeHtml(winner) : escapeHtml(tr('events.detail.tbd', 'TBD'))}</span>`
          : `<span class="fp-winner-badge">✓ ${fLink(winner)}</span>`;
        const sigCls = { STRONG: 'sig-s', MEDIUM: 'sig-m', WEAK: 'sig-w' }[String(fight.signal_strength).toUpperCase()] || '';
        const sigBadge = fight.signal_strength
          ? `<span class="fp-sig ${sigCls}">${escapeHtml(fight.signal_strength)}</span>`
          : '—';
        return `<tr>
          <td>${escapeHtml(fight.event_date || event.event_date || '')}</td>
          <td>
            <span class="fp-matchup-fighters">${fLink(fight.fighter_name_display || 'TBD')}</span>
            ${fight.opponent_name_display ? `<span class="fp-matchup-vs">${escapeHtml(tr('events.table.vs', 'vs'))} ${fLink(fight.opponent_name_display)}</span>` : ''}
          </td>
          <td>${winnerCell}</td>
          <td>${sigBadge}</td>
          <td>${pct(fight.model_prob)}</td>
          <td>${pct(fight.market_prob)}</td>
          <td class="${Number(fight.edge) > 0.05 ? 'pos' : Number(fight.edge) < -0.05 ? 'neg' : ''}">${edge(fight.edge)}</td>
          <td class="${fight.realized_roi == null ? '' : Number(fight.realized_roi) > 0 ? 'pos' : 'neg'}">${roiPct(fight.realized_roi)}</td>
        </tr>`;
      }).join('');
    }

    function renderList() {
      const rows = filteredEvents();
      matchCount.textContent = `${rows.length.toLocaleString()} ${tr('events.count.events', 'events')}`;
      if (!rows.some((event) => event.event_name === selectedEvent.event_name)) {
        selectedEvent = rows[0] || events[0];
      }
      if (eventSelect) {
        eventSelect.disabled = rows.length === 0;
        eventSelect.innerHTML = rows.slice(0, 500).map((event) => {
          const meta = [event.event_date, event.location, event.event_phase].filter(Boolean).join(' / ');
          return `<option value="${escapeHtml(event.event_name)}" translate="no">${escapeHtml(event.event_name)}${meta ? ` — ${escapeHtml(meta)}` : ''}</option>`;
        }).join('');
        eventSelect.value = selectedEvent?.event_name || '';
      }
      if (emptyState) emptyState.hidden = rows.length > 0;
      if (selectedEvent) selectEvent(selectedEvent);
    }

    search?.addEventListener('input', renderList);
    phase?.addEventListener('change', renderList);
    location?.addEventListener('change', renderList);
    window.addEventListener('fp-lang-change', renderList);
    eventSelect?.addEventListener('change', () => {
      const event = filteredEvents().find((candidate) => candidate.event_name === eventSelect.value);
      if (event) {
        selectEvent(event);
        renderList();
      }
    });
    renderList();
  })();
</script>

<style>
  .fp-events-page {
    display: grid;
    gap: 1rem;
  }
  .fp-tool-hero,
  .fp-tool-controls,
  .fp-events-list-panel,
  .fp-event-detail {
    background: linear-gradient(150deg, rgba(22, 22, 26, 0.92), rgba(36, 36, 42, 0.68));
    border: 1px solid rgba(113, 113, 122, 0.42);
    border-radius: 0.8rem;
  }
  .fp-tool-hero {
    padding: 1.35rem;
  }
  .fp-tool-breadcrumb {
    color: #fca5a5;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }
  .fp-tool-hero h1 {
    margin: 0.25rem 0 0.45rem;
    color: #fef2f2;
    font-size: clamp(1.7rem, 4vw, 2.45rem);
    line-height: 1.08;
  }
  .fp-tool-hero p {
    max-width: 72ch;
    margin: 0;
    color: #d4d4d8;
    line-height: 1.6;
  }
  .fp-kpi-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0,1fr));
    gap: 0;
    margin-top: 1rem;
    background: linear-gradient(145deg, rgba(28,28,32,0.92), rgba(39,39,42,0.76));
    border: 1px solid rgba(248,113,113,0.16);
    border-top: 2px solid rgba(185,28,28,0.52);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 8px 18px rgba(0,0,0,0.2);
  }
  .fp-kpi-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100px;
    padding: 0.75rem 0.65rem;
    text-align: center;
    border-right: 1px solid rgba(248,113,113,0.12);
    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0));
  }
  .fp-kpi-item:last-child { border-right: 0; }
  .fp-kpi-icon { margin-bottom: 0.22rem; line-height: 1; }
  .fp-kpi-icon img { object-fit: contain; display: block; }
  .fp-kpi-label { color: #d4d4d8; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.12rem; font-weight: 700; }
  .fp-kpi-value { color: #fff; font-size: 1.08rem; font-weight: 800; line-height: 1; }
  .fp-tool-controls {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(150px, 0.28fr) minmax(180px, 0.38fr);
    gap: 0.75rem;
    padding: 0.9rem;
  }
  .fp-tool-controls label {
    display: grid;
    gap: 0.35rem;
    color: #a1a1aa;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .fp-tool-controls input,
  .fp-tool-controls select {
    width: 100%;
    min-height: 2.55rem;
    border: 1px solid rgba(113, 113, 122, 0.52);
    border-radius: 0.55rem;
    color: #f4f4f5;
    background: rgba(9, 9, 11, 0.78);
    padding: 0.55rem 0.65rem;
  }
  .fp-events-layout {
    display: grid;
    grid-template-columns: minmax(260px, 0.42fr) minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
  }
  .fp-events-list-panel,
  .fp-event-detail {
    padding: 0.95rem;
    min-width: 0;
  }
  .fp-panel-head {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }
  .fp-panel-head h2 {
    margin: 0;
    color: #fef2f2;
    font-size: 1.05rem;
  }
  .fp-panel-head p,
  .fp-panel-head span {
    margin: 0.16rem 0 0;
    color: #a1a1aa;
    font-size: 0.84rem;
  }
  .fp-event-select-label {
    position: relative;
    display: grid;
    gap: 0.38rem;
    padding: 0.62rem;
    box-sizing: border-box;
    background: rgba(9, 9, 11, 0.62);
    border: 1px solid rgba(113, 113, 122, 0.42);
    border-radius: 0.62rem;
  }
  .fp-event-select-label span {
    color: #67e8f9;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .fp-event-select-label select {
    width: 100%;
    min-width: 0;
    min-height: 2.55rem;
    padding: 0.55rem 2.1rem 0.55rem 0.65rem;
    color: #fef2f2;
    background: rgba(9, 9, 11, 0.86);
    border: 1px solid rgba(248, 113, 113, 0.22);
    border-radius: 0.55rem;
    outline: 0;
    appearance: none;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 800;
    cursor: pointer;
    text-overflow: ellipsis;
  }
  .fp-event-select-label select:disabled {
    color: #71717a;
    cursor: not-allowed;
  }
  .fp-event-select-label select option {
    color: #fef2f2;
    background: #18181b;
  }
  .fp-event-select-label::after {
    content: '⌄';
    position: absolute;
    right: 1.25rem;
    bottom: 1.22rem;
    color: #fca5a5;
    font-size: 1rem;
    line-height: 1;
    pointer-events: none;
  }
  .fp-event-select-label:focus-within {
    border-color: rgba(248, 113, 113, 0.62);
    box-shadow: 0 0 0 3px rgba(185, 28, 28, 0.18);
  }

  .fp-phase-badge {
    flex-shrink: 0;
    border-radius: 999px;
    padding: 0.14rem 0.42rem;
    color: #fca5a5;
    background: rgba(127, 29, 29, 0.38);
    border: 1px solid rgba(185,28,28,0.28);
    font-size: 0.68rem;
    font-weight: 700;
    white-space: nowrap;
  }
  .fp-phase-badge.is-upcoming {
    color: #bbf7d0;
    background: rgba(21, 128, 61, 0.25);
    border-color: rgba(34,197,94,0.28);
  }
  .fp-event-kpis {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.55rem;
    margin-bottom: 0.9rem;
  }
  .fp-event-kpis div {
    border: 1px solid rgba(63, 63, 70, 0.82);
    border-radius: 0.6rem;
    padding: 0.65rem;
    background: rgba(9, 9, 11, 0.45);
  }
  .fp-event-kpis span {
    display: block;
    color: #a1a1aa;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .fp-event-kpis strong {
    color: #fef2f2;
    font-size: 1rem;
  }
  .fp-table-wrap {
    overflow: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    color: #d4d4d8;
    font-size: 0.88rem;
  }
  th,
  td {
    border-bottom: 1px solid rgba(63, 63, 70, 0.78);
    padding: 0.58rem 0.5rem;
    text-align: left;
    vertical-align: top;
  }
  th {
    color: #fca5a5;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  td span { display: block; }

  /* Fighter links in table */
  .fp-ft-link { color: #e4e4e7; text-decoration: none; }
  .fp-ft-link:hover { color: #fef2f2; text-decoration: underline; }
  .fp-matchup-fighters { display: block; color: #fef2f2; font-weight: 600; font-size: 0.86rem; }
  .fp-matchup-vs { display: block; color: #71717a; font-size: 0.76rem; margin-top: 0.1rem; }

  /* Winner badges */
  .fp-winner-badge {
    display: inline-flex; align-items: center; gap: 0.25rem;
    color: #bbf7d0; font-size: 0.82rem; font-weight: 600;
  }
  .fp-winner-tbd {
    color: #71717a; font-size: 0.82rem; font-style: italic;
  }

  /* Signal badges */
  .fp-sig { display: inline-flex; align-items: center; padding: 0.12rem 0.38rem; border-radius: 999px; font-size: 0.68rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; border: 1px solid; white-space: nowrap; }
  .sig-s { color: #bbf7d0; border-color: rgba(34,197,94,0.32);  background: rgba(34,197,94,0.12); }
  .sig-m { color: #fde68a; border-color: rgba(234,179,8,0.32);   background: rgba(234,179,8,0.12); }
  .sig-w { color: #d4d4d8; border-color: rgba(161,161,170,0.32); background: rgba(161,161,170,0.1); }

  /* Edge positive/negative colouring */
  td.pos { color: #86efac; font-weight: 600; }
  td.neg { color: #fca5a5; font-weight: 600; }

  .fp-list-empty { color: #a1a1aa; }
  @media (max-width: 900px) {
    .fp-tool-controls,
    .fp-events-layout,
    .fp-event-kpis { grid-template-columns: 1fr; }
