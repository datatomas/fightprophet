---
import BaseLayout from '../layouts/BaseLayout.astro';
import { runtimeEnvFromLocals } from '../lib/country-master';
import { getBeltHoldersData } from '../lib/champions';
import { fighterImageUrlForFighter, getFighterImagesBaseUrl } from '../lib/fighter-images';

const runtimeEnv = runtimeEnvFromLocals(Astro.locals);
const beltData = await getBeltHoldersData(runtimeEnv);
const fighterImagesBaseUrl = getFighterImagesBaseUrl(runtimeEnv);
const { champions, titleHistory, manualVacates } = beltData;
const pageJson = JSON.stringify({ titleHistory }).replace(/</g, '\\u003c');

const totalDivisions = champions.length;
const activeChampions = champions.filter((champ) => !champ.is_vacant).length;
const totalTitleFights = titleHistory.length;
const initialTitleHistoryLimit = 30;
const hasData = totalDivisions > 0;

function flagEmoji(iso2?: string): string {
  const code = String(iso2 || '').trim().toUpperCase();
  if (!/^[A-Z]{2}$/.test(code)) return '';
  return [...code].map((char) => String.fromCodePoint(127397 + char.charCodeAt(0))).join('');
}

function fighterHref(name?: string): string {
  return `/fighter-stats/?fighter=${encodeURIComponent(String(name || ''))}`;
}

// Freshness anchor: the most recent title fight in the data (real, not a faked
// build date). Drives the visible "Champions current as of …" line + SEO intent
// for "current ufc belt holders".
const latestTitleFightDate = titleHistory
  .map((t) => t.event_date)
  .filter(Boolean)
  .sort()
  .at(-1) || '';
const lastUpdatedLabel = latestTitleFightDate
  ? new Date(latestTitleFightDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

// FAQ structured data — "Who is the current UFC <division> champion?" answered
// for each held belt. Helps topical relevance / People-Also-Ask for the exact
// queries Search Console shows (ufc belt holders, current ufc <div> champion).
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: champions
    .filter((c) => !c.is_vacant && c.name && c.weight_class)
    .map((c) => ({
      '@type': 'Question',
      name: `Who is the current UFC ${c.weight_class} champion?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${c.name} is the current UFC ${c.weight_class} champion`
          + ((c.title_defenses ?? 0) > 0 ? ` with ${c.title_defenses} title defense${c.title_defenses === 1 ? '' : 's'}.` : '.'),
      },
    })),
};
---

<BaseLayout
  title="Current UFC Belt Holders & Title History | Fight Prophet"
  description="Current UFC champions across every division plus full title history — title fights, defenses, vacancies, and lineage. Tracked and updated as belts change hands."
>
  <article class="fp-belts-page">
    <header class="fp-tool-hero">
      <a class="fp-tool-breadcrumb" href="/">← Fight Prophet</a>
      <p class="fp-section-label" data-i18n="belts.eyebrow">Belt Holders</p>
      <h1 data-i18n="belts.title">UFC Belt Holders & Title History</h1>
      <p class="fp-hero-copy" data-i18n="belts.intro">
        The current champions board and title lineage lives directly in Fight Prophet:
        active belts first, then manual title vacates and full title-fight history.
      </p>
      {lastUpdatedLabel && (
        <p class="fp-hero-updated">Champions current as of {lastUpdatedLabel}</p>
      )}
    </header>
    {faqSchema.mainEntity.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}

    {hasData ? (
      <>
        <section class="fp-kpi-grid" aria-label="Belt holder summary">
          <div class="fp-kpi-card">
            <img src="/branding/b91c1c-weights-emoji.png" alt="" width="46" height="46" />
            <span data-i18n="belts.kpi.divisions">Divisions</span>
            <strong>{totalDivisions.toLocaleString()}</strong>
          </div>
          <div class="fp-kpi-card">
            <img src="/branding/b91c1c-activechampions-emoji.png" alt="" width="46" height="46" />
            <span data-i18n="belts.kpi.activeChampions">Active Champions</span>
            <strong>{activeChampions.toLocaleString()}</strong>
          </div>
          <div class="fp-kpi-card">
            <img src="/branding/b91c1c-tittlefight-emoji.png" alt="" width="46" height="46" />
            <span data-i18n="belts.kpi.titleFights">Title Fights</span>
            <strong>{totalTitleFights.toLocaleString()}</strong>
          </div>
        </section>

        <section class="fp-panel">
          <div class="fp-panel-head">
            <div>
              <p class="fp-section-label" data-i18n="belts.current.eyebrow">Current Champions</p>
              <h2 data-i18n="belts.current.title">Current Champions</h2>
            </div>
          </div>
          <div class="fp-champion-grid">
            {champions.map((champ) => {
              const flag = flagEmoji(champ.country_iso2);
              const imageUrl = champ.is_vacant ? '' : fighterImageUrlForFighter(champ.fighter_id, champ.name, fighterImagesBaseUrl);
              return (
                <a class={`fp-champion-card${champ.is_vacant ? ' is-vacant' : ''}`} href={champ.is_vacant ? '/belt-holders/' : fighterHref(champ.name)}>
                  <span class="fp-champ-topline">
                    <span class={`fp-champ-portrait${imageUrl ? ' has-image' : ''}`} aria-hidden="true">
                      {imageUrl ? (
                        <img class="fp-champ-image" src={imageUrl} alt="" loading="lazy" decoding="async" />
                      ) : (
                        <span>{flag || 'C'}</span>
                      )}
                    </span>
                    <span class="fp-champ-division">{champ.weight_class || 'Division'}</span>
                  </span>
                  <strong>{champ.name}</strong>
                  <span class="fp-champ-meta">
                    {flag && <span aria-hidden="true">{flag}</span>}
                    {champ.country || (champ.is_vacant ? 'Vacant title' : 'Country pending')}
                  </span>
                  <span class="fp-champ-detail">
                    <span data-i18n="belts.card.won">Won</span>
                    <b>{champ.title_won_date || '—'}</b>
                  </span>
                  <span class="fp-champ-detail">
                    <span data-i18n="belts.card.defenses">Defenses</span>
                    <b>{champ.title_defenses ?? 0}</b>
                  </span>
                </a>
              );
            })}
          </div>
        </section>

        <section class="fp-panel">
          <div class="fp-panel-head">
            <div>
              <p class="fp-section-label" data-i18n="belts.table.eyebrow">Champion Table</p>
              <h2 data-i18n="belts.table.title">Current Belt Table</h2>
            </div>
          </div>
          <div class="fp-table-wrap">
            <table class="fp-data-table">
              <thead>
                <tr>
                  <th data-i18n="belts.table.ftr">Ftr</th>
                  <th data-i18n="belts.table.division">Division</th>
                  <th data-i18n="belts.table.champion">Champion</th>
                  <th data-i18n="belts.table.titleWon">Title Won</th>
                  <th data-i18n="belts.table.titleEvent">Title Event</th>
                  <th data-i18n="belts.table.defenses">Defenses</th>
                  <th data-i18n="belts.table.lastTitleFight">Last Title Fight</th>
                  <th data-i18n="belts.table.vacant">Vacant</th>
                </tr>
              </thead>
              <tbody>
                {champions.map((champ) => (
                  <tr>
                    <td class="fp-ftr-cell">{champ.is_vacant ? '—' : (flagEmoji(champ.country_iso2) || '•')}</td>
                    <td>{champ.weight_class || '—'}</td>
                    <td>
                      {champ.is_vacant ? (
                        <span class="fp-vacant">VACANT</span>
                      ) : (
                        <a href={fighterHref(champ.name)}>{champ.name}</a>
                      )}
                    </td>
                    <td>{champ.title_won_date || '—'}</td>
                    <td>{champ.title_won_event || '—'}</td>
                    <td>{champ.title_defenses ?? 0}</td>
                    <td>{champ.last_title_fight_date || '—'}</td>
                    <td>{champ.is_vacant ? 'Yes' : 'No'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <section class="fp-panel">
          <div class="fp-panel-head">
            <div>
              <p class="fp-section-label" data-i18n="belts.history.eyebrow">Lineage</p>
              <h2 data-i18n="belts.history.title">Title Fight History</h2>
              <p class="fp-muted" data-history-count>Showing {Math.min(initialTitleHistoryLimit, titleHistory.length).toLocaleString()} of {titleHistory.length.toLocaleString()} title fights.</p>
            </div>
            <label class="fp-filter-label">
              <span data-i18n="belts.history.filter">Filter by division</span>
              <select data-history-filter>
                <option value="__all__" data-i18n="belts.history.allDivisions">All Divisions</option>
                {[...new Set(titleHistory.map((row) => row.weight_class).filter(Boolean))].sort().map((division) => (
                  <option value={division}>{division}</option>
                ))}
              </select>
            </label>
          </div>
          <div class="fp-table-wrap">
            <table class="fp-data-table">
              <thead>
                <tr>
                  <th data-i18n="belts.history.winner">Winner</th>
                  <th data-i18n="belts.history.loser">Loser</th>
                  <th data-i18n="belts.history.date">Date</th>
                  <th data-i18n="belts.history.division">Division</th>
                  <th data-i18n="belts.history.method">Method</th>
                  <th data-i18n="belts.history.round">Rd</th>
                  <th data-i18n="belts.history.time">Time</th>
                  <th data-i18n="belts.history.titleChanged">Title Changed</th>
                  <th data-i18n="belts.history.vacant">Vacant</th>
                  <th data-i18n="belts.history.defenseNumber">Defense #</th>
                  <th data-i18n="belts.history.event">Event</th>
                </tr>
              </thead>
              <tbody data-history-body>
                {titleHistory.slice(0, initialTitleHistoryLimit).map((row) => (
                  <tr>
                    <td>{row.winner_name || '—'}</td>
                    <td>{row.loser_name || '—'}</td>
                    <td>{row.event_date || '—'}</td>
                    <td>{row.weight_class || '—'}</td>
                    <td>{row.method || '—'}</td>
                    <td>{row.fight_round ?? '—'}</td>
                    <td>{row.fight_time || '—'}</td>
                    <td>{row.title_changed_hands ? 'Yes' : 'No'}</td>
                    <td>{row.was_vacant ? 'Yes' : 'No'}</td>
                    <td>{row.title_defense_number ?? '—'}</td>
                    <td>{row.event_name || '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {titleHistory.length > initialTitleHistoryLimit && (
            <button type="button" class="fp-show-more-btn" data-history-show-more>
              Show more title fights
            </button>
          )}
        </section>

        <details class="fp-panel fp-collapsible-panel">
          <summary>
            <span>
              <span class="fp-section-label">Title Vacates</span>
              <strong>Manual Title Vacates</strong>
            </span>
            <em>{manualVacates.length.toLocaleString()} record{manualVacates.length === 1 ? '' : 's'}</em>
          </summary>
          {manualVacates.length > 0 ? (
            <div class="fp-table-wrap">
              <table class="fp-data-table">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Division</th>
                    <th>Champion</th>
                    <th>Reason</th>
                    <th>Notes</th>
                  </tr>
                </thead>
                <tbody>
                  {manualVacates.map((row) => (
                    <tr>
                      <td>{row.vacated_on || '—'}</td>
                      <td>{row.weight_class || '—'}</td>
                      <td>{row.champion_name || '—'}</td>
                      <td>{row.reason || '—'}</td>
                      <td>{row.notes || '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <p class="fp-muted">No title vacates dataset found.</p>
          )}
        </details>
      </>
    ) : (
      <section class="fp-empty-state">
        <strong>No belt holders data available.</strong>
        <span>Run the belt holders ETL first, then Astro will render the current champions, title vacates, and lineage tables here.</span>
      </section>
    )}
  </article>
  <script type="application/json" id="fp-title-history-data" set:html={pageJson}></script>
</BaseLayout>

<script is:inline>
  (() => {
    const dataNode = document.getElementById('fp-title-history-data');
    const filter = document.querySelector('[data-history-filter]');
    const body = document.querySelector('[data-history-body]');
    const count = document.querySelector('[data-history-count]');
    const showMore = document.querySelector('[data-history-show-more]');
    if (!dataNode || !filter || !body) return;
    const payload = JSON.parse(dataNode.textContent || '{}');
    const titleHistory = Array.isArray(payload.titleHistory) ? payload.titleHistory : [];
    const pageSize = 30;
    let visibleLimit = pageSize;
    const esc = (v) => String(v ?? '').replace(/[&<>"']/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));
    const cell = (v) => esc(v || '—');
    const render = () => {
      const division = filter.value;
      const filtered = titleHistory.filter((row) => division === '__all__' || row.weight_class === division);
      const rows = filtered.slice(0, visibleLimit);
      body.innerHTML = rows.map((row) => `<tr>
        <td>${cell(row.winner_name)}</td>
        <td>${cell(row.loser_name)}</td>
        <td>${cell(row.event_date)}</td>
        <td>${cell(row.weight_class)}</td>
        <td>${cell(row.method)}</td>
        <td>${row.fight_round ?? '—'}</td>
        <td>${cell(row.fight_time)}</td>
        <td>${row.title_changed_hands ? 'Yes' : 'No'}</td>
        <td>${row.was_vacant ? 'Yes' : 'No'}</td>
        <td>${row.title_defense_number ?? '—'}</td>
        <td>${cell(row.event_name)}</td>
      </tr>`).join('');
      if (count) {
        count.textContent = `Showing ${rows.length.toLocaleString()} of ${filtered.length.toLocaleString()} title fights.`;
      }
      if (showMore) {
        showMore.hidden = rows.length >= filtered.length;
      }
    };
    filter.addEventListener('change', () => {
      visibleLimit = pageSize;
      render();
    });
    showMore?.addEventListener('click', () => {
      visibleLimit += pageSize;
      render();
    });
    render();
  })();
</script>

<style>
  .fp-belts-page { display: grid; gap: 1rem; }
  .fp-tool-hero {
    background: linear-gradient(150deg, rgba(22,22,26,0.92), rgba(36,36,42,0.68));
    border: 1px solid rgba(113,113,122,0.42);
    border-radius: 0.8rem;
    padding: 1.35rem;
  }
  .fp-tool-breadcrumb { color: #fca5a5; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.08em; text-decoration: none; text-transform: uppercase; }
  .fp-section-label { margin: 0; color: #a1a1aa; font-size: 0.74rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
  .fp-tool-hero .fp-section-label { margin-top: 0.45rem; }
  .fp-tool-hero h1 { margin: 0.25rem 0 0.45rem; color: #fef2f2; font-size: clamp(1.7rem, 4vw, 2.45rem); line-height: 1.08; }
  .fp-hero-copy { max-width: 76ch; margin: 0; color: #d4d4d8; line-height: 1.6; }
  .fp-hero-updated { margin: 0.5rem 0 0; font-size: 0.82rem; color: #a1a1aa; font-weight: 600; }

  .fp-kpi-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); border: 1px solid rgba(248,113,113,0.16); border-top: 2px solid rgba(185,28,28,0.52); border-radius: 1rem; overflow: hidden; background: linear-gradient(145deg, rgba(28,28,32,0.92), rgba(39,39,42,0.76)); }
  .fp-kpi-card { min-height: 118px; display: grid; place-items: center; align-content: center; gap: 0.25rem; padding: 0.85rem; text-align: center; border-right: 1px solid rgba(248,113,113,0.12); }
  .fp-kpi-card:last-child { border-right: 0; }
  .fp-kpi-card span { color: #d4d4d8; font-size: 0.66rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
  .fp-kpi-card strong { color: #fff; font-size: 1.25rem; line-height: 1; }

  .fp-panel { display: grid; gap: 0.85rem; padding: 1rem; border-radius: 1rem; border: 1px solid rgba(248,113,113,0.16); background: linear-gradient(145deg, rgba(24,24,27,0.92), rgba(39,39,42,0.74)); box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 8px 18px rgba(0,0,0,0.18); }
  .fp-panel-head { display: flex; align-items: end; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .fp-panel h2 { margin: 0.16rem 0 0; color: #fef2f2; font-size: 1.24rem; }

  .fp-champion-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 0.7rem; }
  .fp-champion-card { position: relative; display: grid; grid-template-rows: auto auto 1fr auto auto; gap: 0.42rem; min-height: 188px; padding: 0.85rem; border-radius: 0.7rem; text-decoration: none; color: #fef2f2; border: 1px solid rgba(255,240,170,0.28); background: radial-gradient(130% 90% at 20% 0%, rgba(255,224,128,0.18), transparent 56%), linear-gradient(160deg, #4a311a, #1a0c0c 62%, #0f0606); overflow: hidden; isolation: isolate; }
  .fp-champ-topline { display: grid; grid-template-columns: 4.5rem minmax(0, 1fr); align-items: start; gap: 0.68rem; min-width: 0; }
  .fp-champ-portrait { position: relative; display: flex; align-items: center; justify-content: center; width: 4.5rem; aspect-ratio: 4 / 5; border-radius: 0.36rem; overflow: hidden; border: 1.5px solid rgba(255,240,170,0.62); background: radial-gradient(circle at 50% 28%, rgba(255,240,170,0.22), transparent 58%), linear-gradient(180deg, #3a2610 0%, #160909 100%); box-shadow: inset 0 0 0 1px rgba(0,0,0,0.5), 0 8px 18px rgba(0,0,0,0.34); }
  .fp-champ-portrait::after { content: ''; position: absolute; inset: 0; border-radius: inherit; box-shadow: inset 0 0 18px rgba(255,220,140,0.12); pointer-events: none; }
  .fp-champ-portrait > span { color: #fde68a; font-size: 1.25rem; font-weight: 900; line-height: 1; }
  .fp-champ-image { position: absolute; inset: 0.08rem; width: calc(100% - 0.16rem); height: calc(100% - 0.16rem); object-fit: contain; object-position: center bottom; filter: drop-shadow(0 10px 12px rgba(0,0,0,0.62)); pointer-events: none; }
  .fp-champion-card.is-vacant { color: #e4e4e7; border-color: rgba(161,161,170,0.22); background: linear-gradient(160deg, rgba(39,39,42,0.92), rgba(15,15,18,0.96)); pointer-events: none; }
  .fp-champ-division { color: #fde68a; font-size: 0.68rem; font-weight: 900; letter-spacing: 0.08em; line-height: 1.25; text-transform: uppercase; overflow-wrap: anywhere; }
  .fp-champion-card strong { font-size: 1.05rem; line-height: 1.15; }
  .fp-champ-meta { color: #d4d4d8; font-size: 0.82rem; }
  .fp-champ-detail { display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; color: #a1a1aa; font-size: 0.78rem; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 0.38rem; }
  .fp-champ-detail b { color: #fff; }

  .fp-table-wrap { overflow-x: auto; border: 1px solid rgba(113,113,122,0.28); border-radius: 0.7rem; }
  .fp-data-table { width: 100%; min-width: 820px; border-collapse: collapse; color: #d4d4d8; font-size: 0.82rem; }
  .fp-data-table th, .fp-data-table td { padding: 0.68rem 0.72rem; text-align: left; border-bottom: 1px solid rgba(113,113,122,0.22); vertical-align: top; }
  .fp-data-table th { position: sticky; top: 0; background: #18181b; color: #fca5a5; font-size: 0.68rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }
  .fp-data-table tbody tr:nth-child(odd) { background: rgba(255,255,255,0.018); }
  .fp-data-table tbody tr:hover { background: rgba(248,113,113,0.06); }
  .fp-data-table a { color: #fef2f2; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.24); }
  .fp-ftr-cell { font-size: 1.18rem; line-height: 1; }
  .fp-vacant { color: #fca5a5; font-weight: 900; letter-spacing: 0.06em; }
  .fp-muted { margin: 0; color: #a1a1aa; font-size: 0.86rem; }
  .fp-filter-label { display: grid; gap: 0.35rem; color: #a1a1aa; font-size: 0.74rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; }
  .fp-filter-label select { min-width: 220px; min-height: 2.45rem; border: 1px solid rgba(113,113,122,0.52); border-radius: 0.55rem; color: #f4f4f5; background: rgba(9,9,11,0.78); padding: 0.55rem 0.65rem; }
  .fp-show-more-btn {
    justify-self: center;
    min-height: 2.45rem;
    padding: 0.55rem 0.9rem;
    border: 1px solid rgba(248,113,113,0.36);
    border-radius: 0.55rem;
    color: #fef2f2;
    background: rgba(127,29,29,0.34);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .fp-show-more-btn:hover {
    background: rgba(185,28,28,0.48);
    border-color: rgba(248,113,113,0.58);
  }
  .fp-collapsible-panel {
    padding: 0;
    overflow: hidden;
  }
  .fp-collapsible-panel summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 1rem;
    color: #fef2f2;
    cursor: pointer;
    list-style: none;
  }
  .fp-collapsible-panel summary::-webkit-details-marker { display: none; }
  .fp-collapsible-panel summary::after {
    content: '+';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 999px;
    border: 1px solid rgba(248,113,113,0.34);
    color: #fca5a5;
    font-weight: 900;
    flex-shrink: 0;
  }
  .fp-collapsible-panel[open] summary::after { content: '−'; }
  .fp-collapsible-panel summary > span {
    display: grid;
    gap: 0.14rem;
  }
  .fp-collapsible-panel summary strong {
    font-size: 1.02rem;
  }
  .fp-collapsible-panel summary em {
    margin-left: auto;
    color: #a1a1aa;
    font-size: 0.82rem;
    font-style: normal;
    white-space: nowrap;
  }
  .fp-collapsible-panel > .fp-table-wrap,
  .fp-collapsible-panel > .fp-muted {
